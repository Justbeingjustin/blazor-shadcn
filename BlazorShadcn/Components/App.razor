<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <ImportMap />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body class="min-h-screen font-sans antialiased">
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.server.js"></script>
    <script>
        window.toggleDarkMode = function () {
            document.documentElement.classList.toggle('dark');
            return document.documentElement.classList.contains('dark');
        };
        window.isDarkMode = function () {
            return document.documentElement.classList.contains('dark');
        };
        window.copyToClipboard = function (text) {
            return navigator.clipboard.writeText(text);
        };
        window.copyDocsPage = async function (url) {
            if (!navigator.clipboard || !navigator.clipboard.writeText) {
                return false;
            }

            const docsRoot = document.querySelector('div[data-slot="docs"]');
            if (!docsRoot) {
                return false;
            }

            const contentColumn = docsRoot.querySelector(':scope > div:first-child');
            const copySource = contentColumn || docsRoot;
            const clone = copySource.cloneNode(true);

            clone.querySelectorAll('[data-copy-exclude="true"]').forEach(el => el.remove());
            clone.querySelectorAll('script, style, noscript').forEach(el => el.remove());

            const text = (clone.innerText || clone.textContent || '')
                .replace(/\r\n/g, '\n')
                .replace(/\n{3,}/g, '\n\n')
                .trim();

            if (!text) {
                return false;
            }

            const payload = url ? `${url}\n\n${text}` : text;
            await navigator.clipboard.writeText(payload);
            return true;
        };
        window.blazorShadcnCarousel = (function () {
            const carousels = new Map();

            function getState(id) {
                return carousels.get(id) || null;
            }

            function getAxis(axis) {
                return axis === 'y' ? 'top' : 'left';
            }

            function getSizeProp(axis) {
                return axis === 'y' ? 'clientHeight' : 'clientWidth';
            }

            function getScrollProp(axis) {
                return axis === 'y' ? 'scrollTop' : 'scrollLeft';
            }

            function getMaxScroll(viewport, axis) {
                return axis === 'y'
                    ? Math.max(0, viewport.scrollHeight - viewport.clientHeight)
                    : Math.max(0, viewport.scrollWidth - viewport.clientWidth);
            }

            function getSlides(viewport) {
                return Array.from(viewport.children || []);
            }

            function getSlidePositions(viewport, axis) {
                const offsetProp = 'offset' + (axis === 'y' ? 'Top' : 'Left');
                return getSlides(viewport).map(slide => slide[offsetProp] || 0);
            }

            function notify(id) {
                const state = getState(id);
                if (!state) return;

                const viewport = state.viewport;
                const axis = state.axis;
                const current = viewport[getScrollProp(axis)];
                const max = getMaxScroll(viewport, axis);
                const epsilon = 2;

                state.dotNet.invokeMethodAsync('UpdateState', current > epsilon, current < max - epsilon);
            }

            function scrollToIndex(id, direction) {
                const state = getState(id);
                if (!state) return;

                const viewport = state.viewport;
                const axis = state.axis;
                const positions = getSlidePositions(viewport, axis);
                if (!positions.length) return;

                const scrollProp = getScrollProp(axis);
                const current = viewport[scrollProp];
                const epsilon = 2;
                let target = current;

                if (direction < 0) {
                    for (let i = positions.length - 1; i >= 0; i -= 1) {
                        if (positions[i] < current - epsilon) {
                            target = positions[i];
                            break;
                        }
                    }
                } else {
                    for (let i = 0; i < positions.length; i += 1) {
                        if (positions[i] > current + epsilon) {
                            target = positions[i];
                            break;
                        }
                    }
                }

                viewport.scrollTo({
                    [getAxis(axis)]: target,
                    behavior: 'smooth'
                });
            }

            function init(id, viewport, dotNet, axis) {
                dispose(id);

                const onScroll = () => notify(id);
                const onResize = () => notify(id);
                const resizeObserver = new ResizeObserver(onResize);

                viewport.addEventListener('scroll', onScroll, { passive: true });
                resizeObserver.observe(viewport);
                getSlides(viewport).forEach(slide => resizeObserver.observe(slide));

                carousels.set(id, {
                    viewport,
                    dotNet,
                    axis,
                    onScroll,
                    resizeObserver
                });

                notify(id);
            }

            function refresh(id, axis) {
                const state = getState(id);
                if (!state) return;
                state.axis = axis;
                notify(id);
            }

            function dispose(id) {
                const state = getState(id);
                if (!state) return;

                state.viewport.removeEventListener('scroll', state.onScroll);
                state.resizeObserver.disconnect();
                carousels.delete(id);
            }

            return {
                init,
                refresh,
                dispose,
                scrollPrev: (id) => scrollToIndex(id, -1),
                scrollNext: (id) => scrollToIndex(id, 1)
            };
        })();

        (function () {
            function getTargetFromHash(hash) {
                if (!hash || hash[0] !== '#') return null;
                var id = hash.slice(1);
                if (!id) return null;
                try { id = decodeURIComponent(id); } catch { }
                return document.getElementById(id);
            }

            function scrollToHashOnce(hash) {
                var el = getTargetFromHash(hash);
                if (!el) return false;
                try {
                    el.scrollIntoView({
                        behavior: 'auto',
                        block: 'start',
                        inline: 'nearest'
                    });
                } catch {
                    el.scrollIntoView(true);
                }
                return true;
            }

            // Exposed for debugging and manual calls.
            window.scrollToHash = function (hash) {
                var attempts = 0;
                var maxAttempts = 25;
                var delayMs = 30;

                function tryScroll() {
                    attempts += 1;
                    if (scrollToHashOnce(hash)) return;
                    if (attempts >= maxAttempts) return;
                    setTimeout(tryScroll, delayMs);
                }

                tryScroll();
            };

            // Handle direct hash navigation / back-forward hash changes.
            window.addEventListener('hashchange', function () {
                window.scrollToHash(window.location.hash);
            });

            // Ensure in-page anchors scroll even when enhanced navigation intercepts clicks.
            document.addEventListener('click', function (e) {
                var a = e.target && e.target.closest ? e.target.closest('a[href^="#"]') : null;
                if (!a) return;
                var href = a.getAttribute('href');
                if (!href || href === '#') return;
                e.preventDefault();
                if (window.location.hash !== href) {
                    history.replaceState(null, '', href);
                }
                window.scrollToHash(href);
            }, true);

            // Best-effort: if a route loads with a hash already present, scroll after first paint.
            window.requestAnimationFrame(function () {
                if (window.location.hash) window.scrollToHash(window.location.hash);
            });
        })();
    </script>
</body>

</html>
