@inject IJSRuntime JS
@inject NavigationManager Nav

@* Mirrors reference `apps/v4/components/docs-page-links.tsx` (simplified: Copy page only). *@

<div class="@GetRootClass()">
    <ul class="text-muted-foreground flex flex-col gap-2 text-[0.8rem]">
        <li>
            <button type="button"
                    @onclick="CopyPage"
                    class="hover:text-foreground inline-flex items-center gap-2 transition-colors">
                @if (_copied)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <path d="M20 6 9 17l-5-5" />
                    </svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                        <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
                    </svg>
                }
                Copy page
            </button>
        </li>
    </ul>
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public bool Padded { get; set; } = true;

    private bool _copied;

    private string GetRootClass()
        => Tw.Merge("flex flex-col gap-3", Padded ? "px-6" : null, Class);

    private async Task CopyPage()
    {
        try
        {
            // Show "copied" state even if the clipboard API is blocked (common in automated browsers).
            _copied = true;
            StateHasChanged();
            await JS.InvokeVoidAsync("copyToClipboard", Nav.Uri);
            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
        catch
        {
            // Clipboard may be unavailable (permissions, older browsers). Still allow the UI state to flip.
            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
    }
}
