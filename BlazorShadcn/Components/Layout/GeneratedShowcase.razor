@inject IWebHostEnvironment Environment

<PageTitle>@($"{Title} - blazor-shadcn")</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">@Title</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@ReferenceUrl" />
                        @if (PreviousHref is not null)
                        {
                            <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="@PreviousHref" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                            </Button>
                        }
                        @if (NextHref is not null)
                        {
                            <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="@NextHref" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                            </Button>
                        }
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">@Description</p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@UsageCode">
                    <Preview>@RenderDemo("Demo")</Preview>
                    <Code>@UsageCode</Code>
                </ComponentExample>

                <DocsInstallationSection ComponentLabel="@Title.ToLowerInvariant()"
                                         InstallCommand="@InstallCommand"
                                         SourcePaths="@ManualSourcePaths"
                                         DependencyCommands="@DependencyCommands" />

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@UsingStatement">@UsingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@UsageCode">@UsageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>
                @foreach (var heading in ExampleHeadings)
                {
                    <div class="mt-6">
                        <ComponentExample Compact="true"
                                          Title="@ExampleTitle(heading)"
                                          CodeText="@ExampleCode(heading)"
                                          TitleNote="@ExampleTitleNote(heading)">
                            <Preview>@RenderDemo(heading)</Preview>
                            <Code>@ExampleCode(heading)</Code>
                        </ComponentExample>
                    </div>
                }

                @if (HasDataTable)
                {
                    <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="data-table">Data Table</h2>
                    <div class="mt-6">
                        <ComponentExample Compact="true" CodeText="@DataTableCode">
                            <Preview>
                                <DataTable Class="w-full">
                                    <div class="flex items-center justify-between gap-3">
                                        <div>
                                            <p class="font-medium">Invoices</p>
                                            <p class="text-muted-foreground text-sm">Sorting, filtering, and bulk actions layered on top of table primitives.</p>
                                        </div>
                                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Export</Button>
                                    </div>
                                </DataTable>
                            </Preview>
                            <Code>@DataTableCode</Code>
                        </ComponentExample>
                    </div>
                }

                @if (HasRtl)
                {
                    <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="rtl">RTL</h2>
                    <div class="mt-6">
                        <ComponentExample Compact="true" CodeText="@RtlCode">
                            <Preview><div dir="rtl">@RenderDemo("RTL")</div></Preview>
                            <Code>@RtlCode</Code>
                        </ComponentExample>
                    </div>
                }

                @if (HasApiReference)
                {
                    <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>
                    @if (Slug == "switch")
                    {
                        <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Switch</h3>
                        <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                            <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                                <thead>
                                    <tr class="m-0 border-b">
                                        <th class="px-4 py-2 text-left font-bold">Prop</th>
                                        <th class="px-4 py-2 text-left font-bold">Type</th>
                                        <th class="px-4 py-2 text-left font-bold">Default</th>
                                    </tr>
                                </thead>
                                <tbody class="[&_tr:last-child]:border-b-0">
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Checked</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">CheckedChanged</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">EventCallback&lt;bool&gt;</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Disabled</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Size</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">default | sm</code></td><td class="px-4 py-2 text-left whitespace-nowrap">default</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (Slug == "tooltip")
                    {
                        <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">TooltipProvider</h3>
                        <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                            <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                                <thead>
                                    <tr class="m-0 border-b">
                                        <th class="px-4 py-2 text-left font-bold">Prop</th>
                                        <th class="px-4 py-2 text-left font-bold">Type</th>
                                        <th class="px-4 py-2 text-left font-bold">Default</th>
                                    </tr>
                                </thead>
                                <tbody class="[&_tr:last-child]:border-b-0">
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">DelayDuration</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">int</code></td><td class="px-4 py-2 text-left whitespace-nowrap">0</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Tooltip</h3>
                        <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                            <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                                <thead>
                                    <tr class="m-0 border-b">
                                        <th class="px-4 py-2 text-left font-bold">Prop</th>
                                        <th class="px-4 py-2 text-left font-bold">Type</th>
                                        <th class="px-4 py-2 text-left font-bold">Default</th>
                                    </tr>
                                </thead>
                                <tbody class="[&_tr:last-child]:border-b-0">
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Open</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">OpenChanged</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">EventCallback&lt;bool&gt;</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">TooltipContent</h3>
                        <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                            <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                                <thead>
                                    <tr class="m-0 border-b">
                                        <th class="px-4 py-2 text-left font-bold">Prop</th>
                                        <th class="px-4 py-2 text-left font-bold">Type</th>
                                        <th class="px-4 py-2 text-left font-bold">Default</th>
                                    </tr>
                                </thead>
                                <tbody class="[&_tr:last-child]:border-b-0">
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Side</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">"top" | "right" | "bottom" | "left"</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"top"</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                                    <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (ApiReferenceUrl is not null)
                    {
                        <p class="text-muted-foreground mt-2 text-sm">See the <a class="underline underline-offset-4" href="@ApiReferenceUrl" target="_blank" rel="noreferrer">@($"{Title} API reference")</a>.</p>
                    }
                    else
                    {
                        <p class="text-muted-foreground mt-2 text-sm">See the <a class="underline underline-offset-4" href="@ReferenceUrl" target="_blank" rel="noreferrer">reference documentation</a> for the original shadcn API surface.</p>
                    }
                }
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <DocsPageLinks />
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                @foreach (var heading in ExampleHeadings)
                {
                    <a href="@($"#{Anchor(heading)}")" class="text-muted-foreground hover:text-foreground pl-4 text-[0.8rem] no-underline transition-colors">@heading</a>
                }
                @if (HasDataTable)
                {
                    <a href="#data-table" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Data Table</a>
                }
                @if (HasRtl)
                {
                    <a href="#rtl" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">RTL</a>
                }
                @if (HasApiReference)
                {
                    <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Slug { get; set; } = string.Empty;

    private string Title => Slug switch
    {
        "button-group" => "Button Group",
        "context-menu" => "Context Menu",
        "data-table" => "Data Table",
        "date-picker" => "Date Picker",
        "dropdown-menu" => "Dropdown Menu",
        "hover-card" => "Hover Card",
        "input-group" => "Input Group",
        "input-otp" => "Input OTP",
        "native-select" => "Native Select",
        "navigation-menu" => "Navigation Menu",
        "radio-group" => "Radio Group",
        "scroll-area" => "Scroll Area",
        "toggle-group" => "Toggle Group",
        _ => string.Join(" ", Slug.Split('-').Select(static part => char.ToUpperInvariant(part[0]) + part[1..]))
    };

    private string Description => Slug switch
    {
        "switch" => "A control that allows the user to toggle between checked and not checked.",
        _ => $"{Title} examples and installation guidance for BlazorShadcn."
    };
    private string ReferenceUrl => $"https://ui.shadcn.com/docs/components/{Slug}";
    private string? ApiReferenceUrl => Slug switch
    {
        "switch" => "https://www.radix-ui.com/docs/primitives/components/switch#api-reference",
        _ => null
    };
    private string InstallCommand => $"blazor-shadcn add {Slug}";
    private string UsingStatement => "@using BlazorShadcn.Components.UI";
    private string UsageCode => Slug switch
    {
        "combobox" => """<Combobox Placeholder="Select framework" />""",
        "command" => """<Command />""",
        "context-menu" => """<ContextMenu><div class="rounded-lg border p-6 text-sm">Right click here</div></ContextMenu>""",
        "dialog" => """<Dialog><DialogTrigger><Button Variant="ButtonVariant.Outline">Open</Button></DialogTrigger><DialogContent><DialogHeader><DialogTitle>Edit profile</DialogTitle><DialogDescription>Make changes to your profile here.</DialogDescription></DialogHeader></DialogContent></Dialog>""",
        "drawer" => """<Drawer><DrawerTrigger><Button Variant="ButtonVariant.Outline">Open drawer</Button></DrawerTrigger><DrawerContent><DrawerHeader><DrawerTitle>Move goal</DrawerTitle><DrawerDescription>Adjust your progress target.</DrawerDescription></DrawerHeader></DrawerContent></Drawer>""",
        "dropdown-menu" => """<DropdownMenu><DropdownMenuTrigger><Button Variant="ButtonVariant.Outline">Open menu</Button></DropdownMenuTrigger><DropdownMenuContent><DropdownMenuItem>Profile</DropdownMenuItem></DropdownMenuContent></DropdownMenu>""",
        "hover-card" => """<HoverCard><HoverCardTrigger><Button Variant="ButtonVariant.Link">Hover me</Button></HoverCardTrigger><HoverCardContent><div class="text-sm">Hover details</div></HoverCardContent></HoverCard>""",
        "menubar" => """<Menubar />""",
        "navigation-menu" => """<NavigationMenu />""",
        "popover" => """<Popover><PopoverTrigger><Button Variant="ButtonVariant.Outline">Open popover</Button></PopoverTrigger><PopoverContent><PopoverHeader><PopoverTitle>Dimensions</PopoverTitle><PopoverDescription>Set the dimensions for the layer.</PopoverDescription></PopoverHeader></PopoverContent></Popover>""",
        "progress" => """<Progress Value="63" Class="w-[320px]" />""",
        "resizable" => """<Resizable />""",
        "sheet" => """<Sheet><SheetTrigger><Button Variant="ButtonVariant.Outline">Open sheet</Button></SheetTrigger><SheetContent><SheetHeader><SheetTitle>Edit profile</SheetTitle><SheetDescription>Make changes to your profile here.</SheetDescription></SheetHeader></SheetContent></Sheet>""",
        "sidebar" => """<Sidebar />""",
        "slider" => """<Slider DefaultValue="@([50d])" />""",
        "switch" => """
<div class="flex items-center space-x-2">
    <Switch id="airplane-mode" />
    <Label For="airplane-mode">Airplane Mode</Label>
</div>
""",
        "tabs" => """<Tabs DefaultValue="account"><TabsList><TabsTrigger Value="account">Account</TabsTrigger><TabsTrigger Value="password">Password</TabsTrigger></TabsList><TabsContent Value="account">Account content</TabsContent><TabsContent Value="password">Password content</TabsContent></Tabs>""",
        "textarea" => """<Textarea Placeholder="Type your message here." Class="max-w-sm" />""",
        "toggle" => """
<div class="flex flex-col items-center py-6">
    <Toggle Variant="outline">Bold</Toggle>
</div>
""",
        "toggle-group" => """<ToggleGroup Type="single" Value="bold"><ToggleGroupItem Value="bold">Bold</ToggleGroupItem><ToggleGroupItem Value="italic">Italic</ToggleGroupItem></ToggleGroup>""",
        "tooltip" => """
<div class="flex flex-col items-center py-6">
    <Tooltip>
        <TooltipTrigger>
            <Button Variant="@Button.ButtonVariant.Outline">Hover</Button>
        </TooltipTrigger>
        <TooltipContent>
            <p>Add to library</p>
        </TooltipContent>
    </Tooltip>
</div>
""",
        _ => $"""<{Pascal(Slug)} Class="w-full"><div class="text-sm text-muted-foreground">{Title} content</div></{Pascal(Slug)}>"""
    };
    private string DataTableCode => """<DataTable Class="w-full"><div class="text-sm">Invoices</div></DataTable>""";
    private string RtlCode => $"""<div dir="rtl">{UsageCode}</div>""";
    private string? PreviousHref => PrevNext(-1);
    private string? NextHref => PrevNext(1);
    private bool HasRtl => Slug != "tooltip" && Sections.Contains("RTL");
    private bool HasApiReference => Sections.Contains("API Reference");
    private bool HasDataTable => Sections.Contains("Data Table");
    private List<string> Sections => ParseSection("Keep the docs page section order identical to the reference:");
    private List<string> ExampleHeadings => ParseSection("Implement these example headings in this exact order:");
    private IReadOnlyList<string> ManualSourcePaths => LoadSourcePaths();
    private IReadOnlyList<string> DependencyCommands => ParseSection("Manual tab dependency steps called out in the docs:");
    private string? ExampleTitle(string heading) => Slug is "switch" or "tooltip" ? heading : null;
    private string? ExampleTitleNote(string heading) => Slug == "switch" && heading != "Demo" ? "Coming soon" : null;

    private string? PrevNext(int offset)
    {
        var i = Order.IndexOf(Slug);
        var next = i + offset;
        return next >= 0 && next < Order.Count ? $"/components/{Order[next]}" : null;
    }

    private List<string> ParseSection(string marker)
    {
        var path = Path.Combine(Environment.ContentRootPath, "..", "Reference", "mds", $"{Slug}.md");
        if (!File.Exists(path))
        {
            return [];
        }

        var text = File.ReadAllText(path);
        var idx = text.IndexOf(marker, StringComparison.Ordinal);
        if (idx < 0)
        {
            return [];
        }

        var items = new List<string>();
        foreach (var raw in text[(idx + marker.Length)..].Split('\n'))
        {
            var line = raw.Trim();
            if (line.StartsWith("-"))
            {
                items.Add(line[1..].Trim().Trim('`'));
            }
            else if (items.Count > 0)
            {
                break;
            }
        }

        return items;
    }

    private List<string> LoadSourcePaths()
    {
        var root = Path.Combine(Environment.ContentRootPath, "Components", "UI");
        var prefix = Pascal(Slug);
        return
        [
            ..Directory.GetFiles(root, $"{prefix}*")
                .OrderBy(static path => path)
                .Select(path => Path.GetRelativePath(Environment.ContentRootPath, path).Replace('\\', '/'))
        ];
    }

    private string ExampleCode(string heading) => Slug switch
    {
        "combobox" => """<Combobox Placeholder="Select framework" />""",
        "command" => """<Command />""",
        "context-menu" => """<ContextMenu><div class="rounded-lg border p-6 text-sm">Right click here</div></ContextMenu>""",
        "dialog" => $"""<Dialog><DialogTrigger><Button Variant="ButtonVariant.Outline">{heading}</Button></DialogTrigger><DialogContent><DialogHeader><DialogTitle>{heading}</DialogTitle><DialogDescription>Composable dialog content.</DialogDescription></DialogHeader></DialogContent></Dialog>""",
        "drawer" => $"""<Drawer><DrawerTrigger><Button Variant="ButtonVariant.Outline">{heading}</Button></DrawerTrigger><DrawerContent><DrawerHeader><DrawerTitle>{heading}</DrawerTitle><DrawerDescription>Composable drawer content.</DrawerDescription></DrawerHeader></DrawerContent></Drawer>""",
        "dropdown-menu" => $"""<DropdownMenu><DropdownMenuTrigger><Button Variant="ButtonVariant.Outline">{heading}</Button></DropdownMenuTrigger><DropdownMenuContent><DropdownMenuItem>{heading}</DropdownMenuItem></DropdownMenuContent></DropdownMenu>""",
        "hover-card" => $"""<HoverCard><HoverCardTrigger><Button Variant="ButtonVariant.Link">{heading}</Button></HoverCardTrigger><HoverCardContent><div class="text-sm">{heading}</div></HoverCardContent></HoverCard>""",
        "menubar" => """<Menubar />""",
        "navigation-menu" => """<NavigationMenu />""",
        "popover" => $"""<Popover><PopoverTrigger><Button Variant="ButtonVariant.Outline">{heading}</Button></PopoverTrigger><PopoverContent><PopoverHeader><PopoverTitle>{heading}</PopoverTitle><PopoverDescription>Composable popover content.</PopoverDescription></PopoverHeader></PopoverContent></Popover>""",
        "progress" => $"""<Progress Value="{Math.Min(90, Math.Max(24, heading.Length * 6))}" Class="w-[320px]" />""",
        "resizable" => """<Resizable />""",
        "sheet" => $"""<Sheet><SheetTrigger><Button Variant="ButtonVariant.Outline">{heading}</Button></SheetTrigger><SheetContent><SheetHeader><SheetTitle>{heading}</SheetTitle><SheetDescription>Composable sheet content.</SheetDescription></SheetHeader></SheetContent></Sheet>""",
        "sidebar" => """<Sidebar />""",
        "slider" => $"""<Slider DefaultValue="@([{Math.Min(90, Math.Max(10, heading.Length * 5))}d])" />""",
        "switch" => heading switch
        {
