@inject IJSRuntime JS
@* Exact shadcn ComponentPreviewTabs + CodeCollapsibleWrapper pattern *@

<div class="space-y-4">
    @if (!string.IsNullOrEmpty(Title))
    {
        <h3 class="font-heading scroll-m-20 text-xl font-semibold tracking-tight" id="@Title?.ToLower().Replace(" ", "-")">@Title</h3>
    }
    @if (Description != null)
    {
        @Description
    }
    <div data-slot="component-preview"
         class="group relative mt-4 mb-12 flex flex-col overflow-hidden rounded-xl border">
        @* Preview area - exact shadcn: h-72, flex center *@
        <div data-slot="preview"
             class="preview relative flex w-full justify-center p-10 items-center @(Compact ? "h-auto min-h-40" : "h-72")">
            @Preview
        </div>
        @* Code area *@
        <div data-slot="code" class="relative overflow-hidden">
            @if (!string.IsNullOrEmpty(CodeText))
            {
                <button @onclick="CopyCode"
                        class="absolute right-3 top-3 z-10 inline-flex size-7 items-center justify-center rounded-md text-muted-foreground hover:bg-accent hover:text-foreground transition-colors border-t border-l bg-code"
                        title="Copy code">
                    @if (_copied)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                    }
                </button>
            }
            @if (_expanded)
            {
                @* Full code shown *@
                <div class="border-t bg-code">
                    <pre class="max-h-72 overflow-auto p-4 pr-12"><code class="text-sm font-mono">@Code</code></pre>
                </div>
            }
            else
            {
                @* Collapsed code with gradient overlay *@
                <div class="relative">
                    <div class="border-t bg-code">
                        <pre class="max-h-24 overflow-hidden p-4 @(string.IsNullOrEmpty(CodeText) ? "" : "pr-12")"><code class="text-sm font-mono">@Code</code></pre>
                    </div>
                    <div class="absolute inset-0 flex items-center justify-center pb-4"
                         style="background: linear-gradient(to top, var(--color-code), color-mix(in oklab, var(--color-code) 60%, transparent), transparent);">
                        <button @onclick="() => _expanded = true"
                                class="bg-background text-foreground hover:bg-muted relative z-10 inline-flex items-center justify-center gap-2 rounded-lg border px-3 py-1.5 text-sm font-medium shadow-none transition-colors">
                            View Code
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? Description { get; set; }
    [Parameter] public RenderFragment? Preview { get; set; }
    [Parameter] public RenderFragment? Code { get; set; }
    /// <summary>When set, a copy button is shown and copies this exact string (use for usage snippets).</summary>
    [Parameter] public string? CodeText { get; set; }
    [Parameter] public bool Compact { get; set; }

    private bool _expanded;
    private bool _copied;

    private async Task CopyCode()
    {
        if (string.IsNullOrEmpty(CodeText)) return;
        try
        {
            await JS.InvokeVoidAsync("copyToClipboard", CodeText);
            _copied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
        catch { /* clipboard may be unavailable */ }
    }
}
