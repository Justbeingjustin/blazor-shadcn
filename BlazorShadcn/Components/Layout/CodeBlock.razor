@inject IJSRuntime JS

<div class="relative rounded-xl bg-code">
    <button @onclick="CopyCode"
            data-slot="copy-button"
            class="absolute right-3 top-3 z-10 inline-flex items-center justify-center size-7 rounded-md text-muted-foreground hover:bg-accent hover:text-foreground transition-colors"
            title="Copy">
        @if (_copied)
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        }
    </button>
    <div class="overflow-x-auto p-4 pr-12">
        <pre class="text-sm font-mono"><code>@ChildContent</code></pre>
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? RawText { get; set; }

    private bool _copied;

    private async Task CopyCode()
    {
        if (!string.IsNullOrEmpty(RawText))
        {
            await JS.InvokeVoidAsync("copyToClipboard", RawText);
            _copied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
    }
}
