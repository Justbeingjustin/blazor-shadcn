<CascadingValue Name="TabsContext" Value="@_context">
    <div data-slot="tabs"
         data-orientation="@Orientation"
         class="@Tw.Merge("group/tabs flex gap-2", Orientation == "vertical" ? "flex-row" : "flex-col", Class)"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public string Orientation { get; set; } = "horizontal";
    [Parameter] public string Variant { get; set; } = "default";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string? _activeValue;
    private TabsContext _context = default!;

    protected override void OnParametersSet()
    {
        _activeValue = Value ?? _activeValue ?? DefaultValue;
        _context = new TabsContext
        {
            ActiveValue = _activeValue,
            Orientation = Orientation,
            Variant = Variant,
            ActivateAsync = ActivateAsync
        };
    }

    private async Task ActivateAsync(string value)
    {
        _activeValue = value;
        if (ValueChanged.HasDelegate)
        {
            await ValueChanged.InvokeAsync(value);
        }

        StateHasChanged();
    }
}
