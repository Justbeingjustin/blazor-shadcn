<CascadingValue Name="TabsContext" Value="@_context">
    <div data-slot="tabs"
         data-orientation="@Orientation"
         class="@Tw.Merge("group/tabs flex gap-2", Orientation == "vertical" ? "flex-row" : "flex-col", Class)"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public string Orientation { get; set; } = "horizontal";
    [Parameter] public string Variant { get; set; } = "default";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly TabsContext _context = new();
    private bool _defaultsInitialized;

    protected override void OnParametersSet()
    {
        _context.Configure(
            Orientation,
            Variant,
            Value,
            ValueChanged,
            () => InvokeAsync(StateHasChanged));

        if (!_defaultsInitialized)
        {
            _context.InitializeDefault(DefaultValue);
            _defaultsInitialized = true;
        }
    }
}
