<div data-slot="command"
     class="@Tw.Merge("bg-popover text-popover-foreground flex w-full max-w-md flex-col overflow-hidden rounded-lg border shadow-md", Class)"
     @attributes="AdditionalAttributes">
    <div class="border-b px-3">
        <Input Placeholder="@Placeholder" Value="@Query" @oninput="OnInput" Class="border-0 shadow-none focus-visible:ring-0 px-0" />
    </div>
    <div class="max-h-72 overflow-y-auto p-2">
        @if (FilteredItems.Count == 0)
        {
            <p class="text-muted-foreground px-2 py-6 text-center text-sm">No results found.</p>
        }
        else
        {
            @foreach (var group in FilteredItems.GroupBy(static item => item.Group))
            {
                <div class="px-2 py-1.5 text-xs font-medium text-muted-foreground">@group.Key</div>
                @foreach (var item in group)
                {
                    <button type="button"
                            class="hover:bg-accent hover:text-accent-foreground flex w-full items-center justify-between rounded-md px-2 py-2 text-sm text-left"
                            @onclick="() => SelectAsync(item)">
                        <span>@item.Label</span>
                        @if (!string.IsNullOrWhiteSpace(item.Shortcut))
                        {
                            <Kbd>@item.Shortcut</Kbd>
                        }
                    </button>
                }
            }
        }
    </div>
</div>

@code {
    [Parameter] public IEnumerable<CommandItemModel>? Items { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Type a command or search...";
    [Parameter] public EventCallback<string> OnSelect { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string Query { get; set; } = string.Empty;

    private List<CommandItemModel> FilteredItems =>
        (Items ?? DefaultItems)
            .Where(item => string.IsNullOrWhiteSpace(Query) || item.Label.Contains(Query, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private void OnInput(ChangeEventArgs args) => Query = args.Value?.ToString() ?? string.Empty;

    private async Task SelectAsync(CommandItemModel item)
    {
        if (OnSelect.HasDelegate)
        {
            await OnSelect.InvokeAsync(item.Value);
        }
    }

    private static readonly List<CommandItemModel> DefaultItems =
    [
        new("Suggestions", "Calendar", "calendar", "⌘K"),
        new("Suggestions", "Search Emoji", "emoji", "⌘E"),
        new("Settings", "Profile", "profile", "⌘P"),
        new("Settings", "Billing", "billing", "⌘B")
    ];

    public sealed record CommandItemModel(string Group, string Label, string Value, string? Shortcut = null);
}
