<CascadingValue Name="ToggleGroupContext" Value="@_context">
    <div data-slot="toggle-group"
         class="@Tw.Merge("group/toggle-group inline-flex w-fit items-center justify-center", GetSpacingClass(), GetConnectedGroupClasses(), Orientation == "vertical" ? "flex-col" : "flex-row", Class)"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter] public string Type { get; set; } = "single";
    [Parameter] public string? Value { get; set; }
    [Parameter] public IEnumerable<string>? Values { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public EventCallback<IEnumerable<string>> ValuesChanged { get; set; }
    [Parameter] public string Variant { get; set; } = "default";
    [Parameter] public string Size { get; set; } = "default";
    [Parameter] public string Orientation { get; set; } = "horizontal";
    [Parameter] public int Spacing { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private HashSet<string> _values = [];
    private ToggleGroupContext _context = default!;

    protected override void OnParametersSet()
    {
        _values = Type == "multiple"
            ? Values?.ToHashSet(StringComparer.Ordinal) ?? []
            : string.IsNullOrWhiteSpace(Value) ? [] : [Value];

        _context = new ToggleGroupContext
        {
            Type = Type,
            Values = _values,
            Variant = Variant,
            Size = Size,
            Spacing = Spacing,
            Disabled = Disabled,
            ToggleAsync = ToggleAsync
        };
    }

    private async Task ToggleAsync(string value)
    {
        if (Disabled)
        {
            return;
        }

        if (Type == "multiple")
        {
            if (!_values.Add(value))
            {
                _values.Remove(value);
            }

            if (ValuesChanged.HasDelegate)
            {
                await ValuesChanged.InvokeAsync(_values);
            }
        }
        else
        {
            var next = _values.Contains(value) ? null : value;
            _values = next is null ? [] : [next];
            if (ValueChanged.HasDelegate)
            {
                await ValueChanged.InvokeAsync(next);
            }
        }

        StateHasChanged();
    }

    private string GetSpacingClass() => Spacing switch
    {
        0 => "gap-0",
        2 => "gap-2",
        3 => "gap-3",
        4 => "gap-4",
        _ => "gap-1"
    };

    private string? GetConnectedGroupClasses()
        => Spacing == 0 && Variant == "outline" ? "rounded-md shadow-xs" : null;
}
