<div data-slot="select"
     class="@Tw.Merge("relative inline-flex w-fit flex-col", Class)"
     @attributes="AdditionalAttributes">
    <CascadingValue Value="_context" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    private readonly SelectContext _context = new();
    private bool _defaultsInitialized;

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnParametersSet()
    {
        _context.Configure(
            Disabled,
            Value,
            ValueChanged,
            () => InvokeAsync(StateHasChanged));

        if (!_defaultsInitialized)
        {
            _context.InitializeDefault(DefaultValue);
            _defaultsInitialized = true;
        }
    }
}
