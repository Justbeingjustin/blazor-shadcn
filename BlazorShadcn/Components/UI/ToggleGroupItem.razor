<Toggle Variant="@ResolvedVariant"
        Size="@ResolvedSize"
        Pressed="@Pressed"
        PressedChanged="OnPressedChanged"
        Disabled="@ResolvedDisabled"
        Class="@Tw.Merge("w-auto min-w-0 shrink-0 px-3 focus:z-10 focus-visible:z-10", GetGroupItemClasses(), Class)"
        @attributes="AdditionalAttributes">
    @ChildContent
</Toggle>

@code {
    [CascadingParameter(Name = "ToggleGroupContext")] private ToggleGroupContext? Context { get; set; }
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool Pressed => Context?.Values.Contains(Value) ?? false;
    private string ResolvedVariant => Context?.Variant ?? "default";
    private string ResolvedSize => Context?.Size ?? "default";
    private int ResolvedSpacing => Context?.Spacing ?? 0;
    private bool ResolvedDisabled => Disabled || (Context?.Disabled ?? false);

    private Task OnPressedChanged(bool _)
        => Context?.ToggleAsync.Invoke(Value) ?? Task.CompletedTask;

    private string? GetGroupItemClasses()
    {
        if (ResolvedSpacing != 0)
        {
            return null;
        }

        if (ResolvedVariant != "outline")
        {
            return "rounded-none first:rounded-l-md last:rounded-r-md";
        }

        return "rounded-none shadow-none border-l-0 first:rounded-l-md last:rounded-r-md first:border-l";
    }
}
