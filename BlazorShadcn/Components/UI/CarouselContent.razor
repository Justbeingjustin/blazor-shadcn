<div id="@Carousel?.ViewportId"
     @ref="_viewportRef"
     data-slot="carousel-content"
     class="@GetViewportClasses()">
    <div class="@GetTrackClasses()"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
</div>

@code {
    [CascadingParameter] private CarouselContext? CarouselContext { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private ElementReference _viewportRef;
    private Carousel? Carousel => CarouselContext?.Root;

    protected override void OnParametersSet()
    {
        if (CarouselContext is null)
        {
            throw new InvalidOperationException($"{nameof(CarouselContent)} must be used inside {nameof(Carousel)}.");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Carousel is not null)
        {
            await Carousel.RegisterViewportAsync(_viewportRef);
        }
    }

    private string GetViewportClasses()
        => Tw.Merge(
            "overflow-hidden no-scrollbar scroll-smooth",
            CarouselContext?.GetOrientation() == Carousel.CarouselOrientation.Horizontal
                ? "overflow-x-auto overflow-y-hidden touch-pan-y"
                : "h-full overflow-y-auto overflow-x-hidden touch-pan-x");

    private string GetTrackClasses()
        => Tw.Merge(
            "flex",
            CarouselContext?.GetOrientation() == Carousel.CarouselOrientation.Horizontal
                ? "-ml-4"
                : "-mt-4 h-full flex-col",
            Class);
}
