@page "/components/avatar"

<PageTitle>Avatar - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Avatar</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/aspect-ratio" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/badge" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    An image element with a fallback for representing the user.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@mainDemoCode">
                    <Preview>
                        <div class="flex flex-row flex-wrap items-center gap-6 md:gap-12">
                            <Avatar>
                                <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" Class="grayscale" />
                                <AvatarFallback>CN</AvatarFallback>
                            </Avatar>
                            <Avatar>
                                <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")" />
                                <AvatarFallback>ER</AvatarFallback>
                                <AvatarBadge Class="bg-green-600 dark:bg-green-800" />
                            </Avatar>
                            <AvatarGroup Class="grayscale">
                                <Avatar>
                                    <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" />
                                    <AvatarFallback>CN</AvatarFallback>
                                </Avatar>
                                <Avatar>
                                    <AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")" />
                                    <AvatarFallback>LR</AvatarFallback>
                                </Avatar>
                                <Avatar>
                                    <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")" />
                                    <AvatarFallback>ER</AvatarFallback>
                                </Avatar>
                                <AvatarGroupCount>+3</AvatarGroupCount>
                            </AvatarGroup>
                        </div>
                    </Preview>
                    <Code>@mainDemoCode</Code>
                </ComponentExample>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight first:mt-0 lg:mt-12" id="installation">Installation</h2>
                <p class="leading-relaxed mt-6">Install the avatar component using the command or manual steps.</p>
                <div class="mt-4">
                    <div class="inline-flex w-fit items-center justify-start gap-4 rounded-none bg-transparent px-0">
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Command"
                                data-state="@(_installationTab == InstallationTab.Command ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Command
                        </button>
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Manual"
                                data-state="@(_installationTab == InstallationTab.Manual ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Manual
                        </button>
                    </div>
                </div>

                @if (_installationTab == InstallationTab.Command)
                {
                    <div class="mt-4">
                        <CodeBlock RawText="@installCommand">@installCommand</CodeBlock>
                    </div>
                }
                else
                {
                    <div class="mt-6 space-y-6">
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">1</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Copy and paste the following files into your project.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/UI/Avatar.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarRazor">@_sourceAvatarRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarImage.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarImageRazor">@_sourceAvatarImageRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarFallback.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarFallbackRazor">@_sourceAvatarFallbackRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarBadge.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarBadgeRazor">@_sourceAvatarBadgeRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarGroup.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarGroupRazor">@_sourceAvatarGroupRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarGroupCount.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarGroupCountRazor">@_sourceAvatarGroupCountRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarContext.cs</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarContextCs">@_sourceAvatarContextCs</CodeBlock>
                                </div>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">2</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Update the import paths to match your project setup.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/_Imports.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@manualImportsCode">@manualImportsCode</CodeBlock>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6"><CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock></div>
                <div class="mt-4"><CodeBlock RawText="@usageCode">@usageCode</CodeBlock></div>

