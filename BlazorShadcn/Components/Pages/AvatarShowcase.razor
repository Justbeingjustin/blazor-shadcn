@page "/components/avatar"

<PageTitle>Avatar - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Avatar</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/aspect-ratio" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/badge" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    An image element with a fallback for representing the user.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@mainDemoCode">
                    <Preview>
                        <Avatar>
                            <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" Class="grayscale" />
                            <AvatarFallback>CN</AvatarFallback>
                        </Avatar>
                    </Preview>
                    <Code>@mainDemoCode</Code>
                </ComponentExample>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight first:mt-0 lg:mt-12" id="installation">Installation</h2>
                <p class="leading-relaxed mt-6">Install the avatar component using the command or manual steps.</p>
                <div class="mt-4">
                    <div class="inline-flex w-fit items-center justify-start gap-4 rounded-none border-b bg-transparent px-0">
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Command"
                                data-state="@(_installationTab == InstallationTab.Command ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Command
                        </button>
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Manual"
                                data-state="@(_installationTab == InstallationTab.Manual ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Manual
                        </button>
                    </div>
                </div>

                @if (_installationTab == InstallationTab.Command)
                {
                    <div class="mt-4">
                        <CodeBlock RawText="@installCommand">@installCommand</CodeBlock>
                    </div>
                }
                else
                {
                    <div class="mt-6 space-y-6">
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">1</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Copy and paste the following files into your project.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/UI/Avatar.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarRazor">@_sourceAvatarRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarImage.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarImageRazor">@_sourceAvatarImageRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarFallback.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarFallbackRazor">@_sourceAvatarFallbackRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarBadge.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarBadgeRazor">@_sourceAvatarBadgeRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarGroup.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarGroupRazor">@_sourceAvatarGroupRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarGroupCount.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarGroupCountRazor">@_sourceAvatarGroupCountRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">Components/UI/AvatarContext.cs</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAvatarContextCs">@_sourceAvatarContextCs</CodeBlock>
                                </div>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">2</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Update the import paths to match your project setup.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/_Imports.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@manualImportsCode">@manualImportsCode</CodeBlock>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6"><CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock></div>
                <div class="mt-4"><CodeBlock RawText="@usageCode">@usageCode</CodeBlock></div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>
                <div class="mt-6">
                    <ComponentExample Title="Basic" Compact="true" CodeText="@basicCode">
                        <Preview>
                            <Avatar>
                                <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" />
                                <AvatarFallback>CN</AvatarFallback>
                            </Avatar>
                        </Preview>
                        <Code>@basicCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Badge" Compact="true" CodeText="@badgeCode">
                        <Preview>
                            <Avatar>
                                <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" />
                                <AvatarFallback>CN</AvatarFallback>
                                <AvatarBadge Class="bg-green-600 dark:bg-green-800" />
                            </Avatar>
                        </Preview>
                        <Code>@badgeCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Avatar Group" Compact="true" CodeText="@groupCode">
                        <Preview>
                            <AvatarGroup Class="grayscale">
                                <Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" /><AvatarFallback>CN</AvatarFallback></Avatar>
                                <Avatar><AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")" /><AvatarFallback>LR</AvatarFallback></Avatar>
                                <Avatar><AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")" /><AvatarFallback>ER</AvatarFallback></Avatar>
                            </AvatarGroup>
                        </Preview>
                        <Code>@groupCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Sizes" Compact="true" CodeText="@sizesCode">
                        <Preview>
                            <div class="flex flex-wrap items-center gap-2 grayscale">
                                <Avatar Size="sm"><AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" /><AvatarFallback>CN</AvatarFallback></Avatar>
                                <Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" /><AvatarFallback>CN</AvatarFallback></Avatar>
                                <Avatar Size="lg"><AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" /><AvatarFallback>CN</AvatarFallback></Avatar>
                            </div>
                        </Preview>
                        <Code>@sizesCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Dropdown" Compact="true" CodeText="@dropdownCode">
                        <Preview>
                            <div class="grid w-full place-items-center">
                                <div class="relative">
                                    <Button Variant="ButtonVariant.Ghost"
                                            Size="ButtonSize.Icon"
                                            Class="rounded-full"
                                            aria-haspopup="menu"
                                            aria-expanded="@(_avatarMenuOpen ? "true" : "false")"
                                            @onclick="ToggleAvatarMenu">
                                        <Avatar>
                                            <AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn" />
                                            <AvatarFallback>CN</AvatarFallback>
                                        </Avatar>
                                    </Button>
                                    @if (_avatarMenuOpen)
                                    {
                                        <button type="button" class="fixed inset-0 z-40 cursor-default" @onclick="CloseAvatarMenu" aria-label="Close avatar menu"></button>
                                        <div class="bg-popover text-popover-foreground absolute right-0 z-50 mt-2 w-32 rounded-md border p-1 shadow-md">
                                            <button type="button" class="hover:bg-accent hover:text-accent-foreground flex w-full items-center rounded-sm px-2 py-1.5 text-sm text-left">Profile</button>
                                            <button type="button" class="hover:bg-accent hover:text-accent-foreground flex w-full items-center rounded-sm px-2 py-1.5 text-sm text-left">Billing</button>
                                            <button type="button" class="hover:bg-accent hover:text-accent-foreground flex w-full items-center rounded-sm px-2 py-1.5 text-sm text-left">Settings</button>
                                            <div class="bg-border my-1 h-px"></div>
                                            <button type="button" class="text-destructive hover:bg-destructive/10 flex w-full items-center rounded-sm px-2 py-1.5 text-sm text-left">Log out</button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </Preview>
                        <Code>@dropdownCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="RTL" Compact="true" CodeText="@rtlCode">
                        <Preview>
                            <div dir="rtl" class="flex flex-row flex-wrap items-center gap-6 md:gap-12">
                                <Avatar>
                                    <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" Class="grayscale" />
                                    <AvatarFallback>CN</AvatarFallback>
                                </Avatar>
                                <Avatar>
                                    <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")" />
                                    <AvatarFallback>ER</AvatarFallback>
                                    <AvatarBadge Class="bg-green-600 dark:bg-green-800" />
                                </Avatar>
                                <AvatarGroup Class="grayscale">
                                    <Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" /><AvatarFallback>CN</AvatarFallback></Avatar>
                                    <Avatar><AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")" /><AvatarFallback>LR</AvatarFallback></Avatar>
                                    <Avatar><AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")" /><AvatarFallback>ER</AvatarFallback></Avatar>
                                    <AvatarGroupCount>+3</AvatarGroupCount>
                                </AvatarGroup>
                            </div>
                        </Preview>
                        <Code>@rtlCode</Code>
                    </ComponentExample>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <DocsPageLinks />
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#dropdown" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Dropdown</a>
                <a href="#rtl" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">RTL</a>
            </div>
        </div>
    </div>
</div>

@code {
    private InstallationTab _installationTab = InstallationTab.Command;
    private bool _avatarMenuOpen;

    private enum InstallationTab
    {
        Command,
        Manual
    }

    private static readonly string _sourceAvatarRazor = """
<div data-slot="avatar"
     data-size="@Size"
     class="@Tw.Merge("group/avatar relative flex size-8 shrink-0 select-none overflow-hidden rounded-full data-[size=sm]:size-6 data-[size=lg]:size-10", Class)"
     @attributes="AdditionalAttributes">
    <CascadingValue Value="_context" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    private readonly AvatarContext _context = new();

    [Parameter] public string Size { get; set; } = "default";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnParametersSet()
    {
        _context.Configure(() => InvokeAsync(StateHasChanged));
    }
}
""";

    private static readonly string _sourceAvatarImageRazor = """
<img data-slot="avatar-image"
     src="@Src"
     alt="@Alt"
     class="@Tw.Merge("aspect-square size-full", !IsVisible ? "hidden" : null, Class)"
     @onload="OnLoaded"
     @onerror="OnError"
     @attributes="AdditionalAttributes" />

@code {
    [CascadingParameter] private AvatarContext? AvatarContext { get; set; }

    [Parameter] public string? Src { get; set; }
    [Parameter] public string? Alt { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsVisible => AvatarContext?.IsImageLoaded == true;

    protected override Task OnParametersSetAsync()
    {
        if (AvatarContext is not null && string.IsNullOrWhiteSpace(Src))
        {
            return AvatarContext.SetImageLoadedAsync(false);
        }

        return Task.CompletedTask;
    }

    private Task OnLoaded(EventArgs _)
        => AvatarContext?.SetImageLoadedAsync(true) ?? Task.CompletedTask;

    private Task OnError(EventArgs _)
        => AvatarContext?.SetImageLoadedAsync(false) ?? Task.CompletedTask;
}
""";

    private static readonly string _sourceAvatarFallbackRazor = """
@if (IsVisible)
{
    <div data-slot="avatar-fallback"
         class="@Tw.Merge("bg-muted text-muted-foreground flex size-full items-center justify-center rounded-full text-sm group-data-[size=sm]/avatar:text-xs", Class)"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}

@code {
    [CascadingParameter] private AvatarContext? AvatarContext { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsVisible => AvatarContext?.IsImageLoaded != true;
}
""";

    private static readonly string _sourceAvatarBadgeRazor = """
<span data-slot="avatar-badge"
      class="@Tw.Merge("bg-primary text-primary-foreground ring-background absolute right-0 bottom-0 z-10 inline-flex items-center justify-center rounded-full ring-2 select-none group-data-[size=sm]/avatar:size-2 group-data-[size=sm]/avatar:[&>svg]:hidden group-data-[size=default]/avatar:size-2.5 group-data-[size=default]/avatar:[&>svg]:size-2 group-data-[size=lg]/avatar:size-3 group-data-[size=lg]/avatar:[&>svg]:size-2", Class)"
      @attributes="AdditionalAttributes">
    @ChildContent
</span>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
""";

    private static readonly string _sourceAvatarGroupRazor = """
<div data-slot="avatar-group"
     class="@Tw.Merge("*:data-[slot=avatar]:ring-background group/avatar-group flex -space-x-2 *:data-[slot=avatar]:ring-2", Class)"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
""";

    private static readonly string _sourceAvatarGroupCountRazor = """
<div data-slot="avatar-group-count"
     class="@Tw.Merge("bg-muted text-muted-foreground ring-background relative flex size-8 shrink-0 items-center justify-center rounded-full text-sm ring-2 group-has-data-[size=lg]/avatar-group:size-10 group-has-data-[size=sm]/avatar-group:size-6 [&>svg]:size-4 group-has-data-[size=lg]/avatar-group:[&>svg]:size-5 group-has-data-[size=sm]/avatar-group:[&>svg]:size-3", Class)"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
""";

    private static readonly string _sourceAvatarContextCs = """
namespace MyApp.Components.UI;

internal sealed class AvatarContext
{
    private Func<Task>? _stateChanged;

    public bool IsImageLoaded { get; private set; }

    public void Configure(Func<Task> stateChanged)
    {
        _stateChanged = stateChanged;
    }

    public Task SetImageLoadedAsync(bool loaded)
    {
        if (IsImageLoaded == loaded)
        {
            return Task.CompletedTask;
        }

        IsImageLoaded = loaded;
        return _stateChanged is null ? Task.CompletedTask : _stateChanged();
    }
}
""";

    private const string installCommand = "npx shadcn@latest add avatar";
    private const string manualImportsCode = "@using MyApp.Components.UI";
    private const string usingStatement = "@using BlazorShadcn.Components.UI";
    private const string usageCode = """
<Avatar>
    <AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" />
    <AvatarFallback>CN</AvatarFallback>
</Avatar>
""";
    private const string mainDemoCode = """<Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" Class="grayscale" /><AvatarFallback>CN</AvatarFallback></Avatar>""";
    private const string basicCode = """<Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" /><AvatarFallback>CN</AvatarFallback></Avatar>""";
    private const string badgeCode = """<Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" /><AvatarFallback>CN</AvatarFallback><AvatarBadge Class="bg-green-600 dark:bg-green-800" /></Avatar>""";
    private const string groupCode = """<AvatarGroup Class="grayscale"><Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" /><AvatarFallback>CN</AvatarFallback></Avatar><Avatar><AvatarImage Src="https://github.com/maxleiter.png" Alt="@maxleiter" /><AvatarFallback>LR</AvatarFallback></Avatar><Avatar><AvatarImage Src="https://github.com/evilrabbit.png" Alt="@evilrabbit" /><AvatarFallback>ER</AvatarFallback></Avatar></AvatarGroup>""";
    private const string sizesCode = """<div class="flex flex-wrap items-center gap-2 grayscale"><Avatar Size="sm"><AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" /><AvatarFallback>CN</AvatarFallback></Avatar><Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" /><AvatarFallback>CN</AvatarFallback></Avatar><Avatar Size="lg"><AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" /><AvatarFallback>CN</AvatarFallback></Avatar></div>""";
    private const string dropdownCode = """<div class="relative"><Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="rounded-full"><Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn" /><AvatarFallback>CN</AvatarFallback></Avatar></Button><!-- Render a popover-style menu panel with Profile, Billing, Settings, and Log out actions when open --></div>""";
    private const string rtlCode = """<div dir="rtl" class="flex flex-row flex-wrap items-center gap-6 md:gap-12"><Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" Class="grayscale" /><AvatarFallback>CN</AvatarFallback></Avatar><Avatar><AvatarImage Src="https://github.com/evilrabbit.png" Alt="@evilrabbit" /><AvatarFallback>ER</AvatarFallback><AvatarBadge Class="bg-green-600 dark:bg-green-800" /></Avatar><AvatarGroup Class="grayscale"><Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@shadcn" /><AvatarFallback>CN</AvatarFallback></Avatar><Avatar><AvatarImage Src="https://github.com/maxleiter.png" Alt="@maxleiter" /><AvatarFallback>LR</AvatarFallback></Avatar><Avatar><AvatarImage Src="https://github.com/evilrabbit.png" Alt="@evilrabbit" /><AvatarFallback>ER</AvatarFallback></Avatar><AvatarGroupCount>+3</AvatarGroupCount></AvatarGroup></div>""";

    private void ToggleAvatarMenu()
    {
        _avatarMenuOpen = !_avatarMenuOpen;
    }

    private void CloseAvatarMenu()
    {
        _avatarMenuOpen = false;
    }
}
