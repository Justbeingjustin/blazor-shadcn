                    <ComponentExample Compact="true" CodeText="@sizesCode">
                        <Preview>
                            <div class="flex flex-wrap items-center gap-2 grayscale">
                                <Avatar Size="sm"><AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" /><AvatarFallback>CN</AvatarFallback></Avatar>
