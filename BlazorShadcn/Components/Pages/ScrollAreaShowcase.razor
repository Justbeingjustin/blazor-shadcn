@page "/components/scroll-area"
@inject IWebHostEnvironment Environment

<PageTitle>Scroll Area - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <div class="flex items-center gap-2">
                        <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Scroll Area</h1>
                    </div>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="ButtonVariant.Secondary"
                                Size="ButtonSize.Icon"
                                Href="/components/resizable"
                                Class="extend-touch-target size-8 shadow-none md:size-7"
                                aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12l14 0" />
                                <path d="M5 12l6 6" />
                                <path d="M5 12l6 -6" />
                            </svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary"
                                Size="ButtonSize.Icon"
                                Href="/components/select"
                                Class="extend-touch-target size-8 shadow-none md:size-7"
                                aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12l14 0" />
                                <path d="M13 18l6 -6" />
                                <path d="M13 6l6 6" />
                            </svg>
                        </Button>
                    </div>
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    Augments native scroll functionality for custom, cross-browser styling.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@codeMainDemo">
                    <Preview>
                        <ScrollArea Class="h-72 w-48 rounded-md border">
                            <div class="p-4">
                                <h4 class="mb-4 text-sm leading-none font-medium">Tags</h4>
                                @foreach (var tag in Tags)
                                {
                                    <div class="text-sm">@tag</div>
                                    <Separator Class="my-2" />
                                }
                            </div>
                        </ScrollArea>
                    </Preview>
                    <Code>@codeMainDemo</Code>
                </ComponentExample>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight first:mt-0 lg:mt-12" id="installation">Installation</h2>
                <div class="mt-4">
                    <div class="inline-flex w-fit items-center justify-start gap-4 rounded-none bg-transparent px-0">
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Command"
                                data-state="@(_installationTab == InstallationTab.Command ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Command
                        </button>
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Manual"
                                data-state="@(_installationTab == InstallationTab.Manual ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Manual
                        </button>
                    </div>
                </div>

                @if (_installationTab == InstallationTab.Command)
                {
                    <div class="mt-4">
                        <CodeBlock RawText="@installCommand">@installCommand</CodeBlock>
                    </div>
                }
                else
                {
                    <div class="mt-6 space-y-6">
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">1</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Copy and paste the following code into your project.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/UI/ScrollArea.razor</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_scrollAreaManualSource">@_scrollAreaManualSource</CodeBlock>
                                </div>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">2</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Copy and paste the following code into your project.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/UI/ScrollBar.razor</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_scrollBarManualSource">@_scrollBarManualSource</CodeBlock>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>

                <div id="horizontal" class="scroll-m-28"></div>
                <div class="mt-6">
                    <ComponentExample Title="Horizontal" Compact="true" CodeText="@codeHorizontal">
                        <Description>
                            <p class="text-muted-foreground text-sm">Use <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">ScrollBar</code> with <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Orientation="ScrollBar.ScrollBarOrientation.Horizontal"</code> for horizontal scrolling.</p>
                        </Description>
                        <Preview>
                            <ScrollArea Class="w-96 rounded-md border whitespace-nowrap" ShowDefaultScrollbar="false">
                                <div class="flex w-max space-x-4 p-4">
                                    @foreach (var artwork in Works)
                                    {
                                        <figure class="shrink-0">
                                            <div class="overflow-hidden rounded-md">
                                                <img src="@artwork.Art"
                                                     alt="Photo by @artwork.Artist"
                                                     class="aspect-[3/4] h-fit w-fit object-cover"
                                                     width="300"
                                                     height="400" />
                                            </div>
                                        </figure>
                                    }
                                </div>
                                <ScrollBar Orientation="ScrollBar.ScrollBarOrientation.Horizontal" />
                            </ScrollArea>
                        </Preview>
                        <Code>@codeHorizontal</Code>
                    </ComponentExample>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>
                <p class="text-muted-foreground mt-4 text-sm">
                    See the <a href="https://www.radix-ui.com/docs/primitives/components/scroll-area#api-reference" class="underline underline-offset-4">Radix UI Scroll Area</a> documentation.
                </p>
                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">ScrollArea</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ViewportClass</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ShowDefaultScrollbar</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">true</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">ScrollBar</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Orientation</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">Vertical | Horizontal</code></td><td class="px-4 py-2 text-left whitespace-nowrap">Vertical</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#horizontal" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Horizontal</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

@code {
    private const string canonicalScrollAreaSourcePath = "components/scroll-area/ScrollArea.razor";
    private const string canonicalScrollBarSourcePath = "components/scroll-area/ScrollBar.razor";
    private const string referenceUrl = "https://ui.shadcn.com/docs/components/radix/scroll-area";
    private const string installCommand = "blazor-shadcn add scroll-area";
    private const string usingStatement = "@using BlazorShadcn.Components.UI";
    private const string usageCode = """
<ScrollArea Class="h-[200px] w-[350px] rounded-md border p-4">
    Your scrollable content here.
</ScrollArea>
""";
    private const string codeMainDemo = """
<ScrollArea Class="h-72 w-48 rounded-md border">
    <div class="p-4">
        <h4 class="mb-4 text-sm leading-none font-medium">Tags</h4>
        @foreach (var tag in Tags)
        {
            <div class="text-sm">@tag</div>
            <Separator Class="my-2" />
        }
    </div>
</ScrollArea>

@code {
    private static readonly string[] Tags =
    [
        "v1.2.0-beta.50",
        "v1.2.0-beta.49",
        "v1.2.0-beta.48",
        "v1.2.0-beta.47",
        "v1.2.0-beta.46"
    ];
}
""";
    private const string codeHorizontal = """
<ScrollArea Class="w-96 rounded-md border whitespace-nowrap" ShowDefaultScrollbar="false">
    <div class="flex w-max space-x-4 p-4">
        @foreach (var artwork in Works)
        {
            <figure class="shrink-0">
                <div class="overflow-hidden rounded-md">
                    <img src="@artwork.Art"
                         alt="Photo by @artwork.Artist"
                         class="aspect-[3/4] h-fit w-fit object-cover"
                         width="300"
                         height="400" />
                </div>
            </figure>
        }
    </div>
    <ScrollBar Orientation="ScrollBar.ScrollBarOrientation.Horizontal" />
</ScrollArea>

@code {
    private static readonly Artwork[] Works =
    [
        new("Ornella Binni", "https://images.unsplash.com/photo-1465869185982-5a1a7522cbcb?auto=format&fit=crop&w=300&q=80"),
        new("Tom Byrom", "https://images.unsplash.com/photo-1548516173-3cabfa4607e9?auto=format&fit=crop&w=300&q=80"),
        new("Vladimir Malyavko", "https://images.unsplash.com/photo-1494337480532-3725c85fd2ab?auto=format&fit=crop&w=300&q=80")
    ];

    private sealed record Artwork(string Artist, string Art);
}
""";
    private const string apiScrollAreaCode = """
<ScrollArea Class="h-72 w-48 rounded-md border">
    @* Scrollable content *@
</ScrollArea>
""";
    private const string fallbackScrollAreaSource = """
<div data-slot="scroll-area"
     class="@Tw.Merge("relative", Class)"
     @attributes="AdditionalAttributes">
    <div data-slot="scroll-area-viewport"
         tabindex="0"
         class="@Tw.Merge("focus-visible:ring-ring/50 size-full overflow-auto rounded-[inherit] outline-none transition-[color,box-shadow] focus-visible:ring-[3px] focus-visible:outline-1", ViewportClass)">
        @ChildContent
    </div>

    @if (ShowDefaultScrollbar)
    {
        <ScrollBar />
    }
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? ViewportClass { get; set; }
    [Parameter] public bool ShowDefaultScrollbar { get; set; } = true;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
""";
    private const string fallbackScrollBarSource = """
<div data-slot="scroll-area-scrollbar"
     data-orientation="@OrientationValue"
     aria-hidden="true"
     class="@Tw.Merge(
         "pointer-events-none absolute select-none p-px transition-colors",
         Orientation == ScrollBarOrientation.Vertical
             ? "top-0 right-0 h-full w-2.5 border-l border-l-transparent"
             : "right-0 bottom-0 left-0 h-2.5 flex-col border-t border-t-transparent",
         Class)"
     @attributes="AdditionalAttributes">
    <div data-slot="scroll-area-thumb"
         class="bg-border relative flex-1 rounded-full"></div>
</div>

@code {
    [Parameter] public ScrollBarOrientation Orientation { get; set; } = ScrollBarOrientation.Vertical;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string OrientationValue => Orientation.ToString().ToLowerInvariant();

    public enum ScrollBarOrientation
    {
        Vertical,
        Horizontal
    }
}
""";

    private InstallationTab _installationTab = InstallationTab.Command;
    private string _scrollAreaManualSource = string.Empty;
    private string _scrollBarManualSource = string.Empty;

    private static readonly string[] Tags = Enumerable.Range(1, 50)
        .Select(i => $"v1.2.0-beta.{51 - i}")
        .ToArray();

    private static readonly Artwork[] Works =
    [
        new("Ornella Binni", "https://images.unsplash.com/photo-1465869185982-5a1a7522cbcb?auto=format&fit=crop&w=300&q=80"),
        new("Tom Byrom", "https://images.unsplash.com/photo-1548516173-3cabfa4607e9?auto=format&fit=crop&w=300&q=80"),
        new("Vladimir Malyavko", "https://images.unsplash.com/photo-1494337480532-3725c85fd2ab?auto=format&fit=crop&w=300&q=80")
    ];

    protected override void OnInitialized()
    {
        _scrollAreaManualSource = ReadManualSource(canonicalScrollAreaSourcePath, fallbackScrollAreaSource);
        _scrollBarManualSource = ReadManualSource(canonicalScrollBarSourcePath, fallbackScrollBarSource);
    }

    private string ReadManualSource(string relativePath, string fallback)
    {
        var sourcePath = Path.Combine(Environment.ContentRootPath, relativePath.Replace('/', Path.DirectorySeparatorChar));
        return File.Exists(sourcePath)
            ? File.ReadAllText(sourcePath)
            : fallback;
    }

    private enum InstallationTab
    {
        Command,
        Manual
    }

    private sealed record Artwork(string Artist, string Art);
}
