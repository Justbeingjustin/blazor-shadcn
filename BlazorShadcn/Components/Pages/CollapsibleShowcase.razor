                                    </Collapsible>
                                </CardContent>
                            </Card>
                        </Preview>
                        <Code>@codeSettings</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="File Tree" Compact="true" CodeText="@codeFileTree">
                        <Description><p class="text-muted-foreground text-sm">Fallback example until <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Tabs</code> is implemented.</p></Description>
