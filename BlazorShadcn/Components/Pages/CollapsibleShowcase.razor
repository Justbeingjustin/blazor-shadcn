                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>
                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Collapsible</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead><tr class="m-0 border-b"><th class="px-4 py-2 text-left font-bold">Prop</th><th class="px-4 py-2 text-left font-bold">Type</th><th class="px-4 py-2 text-left font-bold">Default</th></tr></thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Open</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">DefaultOpen</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">OpenChanged</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">EventCallback&lt;bool&gt;</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#basic" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Basic</a>
                <a href="#settings-panel" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Settings Panel</a>
                <a href="#file-tree" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">File Tree</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

@code {
    private InstallationTab _installationTab = InstallationTab.Command;
    private bool _settingsOpen;
    private FileTreeTab _fileTreeTab = FileTreeTab.Explorer;

    private enum InstallationTab { Command, Manual }
    private enum FileTreeTab { Explorer, Outline }

    private const string installCommand = "npx shadcn@latest add collapsible";
    private const string referenceUrl = "https://ui.shadcn.com/docs/components/radix/collapsible";
    private const string manualImportStep = "Add @using MyApp.Components.UI to Components/_Imports.razor";

    private static readonly string _sourceContext = """
namespace BlazorShadcn.Components.UI;

public sealed class CollapsibleContext
{
    public required Func<bool> GetOpen { get; init; }
    public required Func<Task> ToggleAsync { get; init; }
}
""";

    private static readonly string _sourceRoot = """
<CascadingValue Value="@_context" IsFixed="true">
    <div data-slot="collapsible"
         data-state="@(_currentOpen ? "open" : "closed")"
         class="@GetClasses()"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
</CascadingValue>
""";

    private static readonly string _sourceTrigger = """
<button type="@Type"
        data-slot="collapsible-trigger"
        data-state="@(_context?.GetOpen() == true ? "open" : "closed")"
        aria-expanded="@(_context?.GetOpen() == true)"
        disabled="@Disabled"
        class="@Class"
        @onclick="OnClick"
        @attributes="AdditionalAttributes">
    @ChildContent
</button>
""";

    private static readonly string _sourceContent = """
<div data-slot="collapsible-content"
     data-state="@(_context?.GetOpen() == true ? "open" : "closed")"
     hidden="@(!_forceMount && _context?.GetOpen() != true)"
     class="@Class"
     @attributes="AdditionalAttributes">
    @if (_forceMount || _context?.GetOpen() == true)
    {
        @ChildContent
    }
</div>
""";

    private const string usingStatement = @"@using BlazorShadcn.Components.UI";
    private const string usageCode = @"<Collapsible>
    <CollapsibleTrigger>Can I use this in my project?</CollapsibleTrigger>
    <CollapsibleContent>
        Yes. Free to use for personal and commercial projects.
