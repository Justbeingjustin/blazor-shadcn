                                        <button @onclick="() => _fileTreeTab = FileTreeTab.Outline"
                                                class="@(_fileTreeTab == FileTreeTab.Outline ? "bg-muted text-foreground flex-1 rounded-sm px-2 py-1 text-xs font-medium" : "text-muted-foreground flex-1 rounded-sm px-2 py-1 text-xs font-medium hover:text-foreground")">
                                            Outline
