<Badge Variant=""BadgeVariant.Ghost"">Ghost</Badge>
<Badge Variant=""BadgeVariant.Link"" Href=""#"" onclick=""return false;"">Link</Badge>";

    private const string codeWithIcon = @"<Badge Variant=""BadgeVariant.Secondary"">
