@page "/components/badge"
@inject IWebHostEnvironment Environment

<PageTitle>Badge - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <div class="flex items-center gap-2">
                        <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Badge</h1>
                    </div>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="ButtonVariant.Secondary"
                                Size="ButtonSize.Icon"
                                Href="/components/avatar"
                                Class="extend-touch-target size-8 shadow-none md:size-7"
                                aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                                <path d="M5 12l14 0" />
                                <path d="M5 12l6 6" />
                                <path d="M5 12l6 -6" />
                            </svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary"
                                Size="ButtonSize.Icon"
                                Href="/components/breadcrumb"
                                Class="extend-touch-target size-8 shadow-none md:size-7"
                                aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4">
                                <path d="M5 12l14 0" />
                                <path d="M13 18l6 -6" />
                                <path d="M13 6l6 6" />
                            </svg>
                        </Button>
                    </div>
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    Displays a badge or a component that looks like a badge.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample CodeText="@codeMainDemo">
                    <Preview>
                        <div class="flex w-full flex-wrap justify-center gap-2">
                            <Badge>Badge</Badge>
                            <Badge Variant="BadgeVariant.Secondary">Secondary</Badge>
                            <Badge Variant="BadgeVariant.Destructive">Destructive</Badge>
                            <Badge Variant="BadgeVariant.Outline">Outline</Badge>
                        </div>
                    </Preview>
                    <Code>@codeMainDemo</Code>
                </ComponentExample>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight first:mt-0 lg:mt-12" id="installation">Installation</h2>
                <p class="leading-relaxed mt-6">Install the badge component using the command or manual steps.</p>
                <div class="mt-4">
                    <div class="inline-flex w-fit items-center justify-start gap-4 rounded-none bg-transparent px-0">
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Command"
                                data-state="@(_installationTab == InstallationTab.Command ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Command
                        </button>
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Manual"
                                data-state="@(_installationTab == InstallationTab.Manual ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Manual
                        </button>
                    </div>
                </div>

                @if (_installationTab == InstallationTab.Command)
                {
                    <div class="mt-4">
                        <CodeBlock RawText="@installCommand">@installCommand</CodeBlock>
                    </div>
                }
                else
                {
                    <div class="mt-6 space-y-6">
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">1</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Copy and paste the following code into your project.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/UI/Badge.razor</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_badgeManualSource">@_badgeManualSource</CodeBlock>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>

                <div class="mt-6">
                    <ComponentExample Title="Variants" Compact="true" CodeText="@codeVariants">
                        <Description>
                            <p class="text-muted-foreground text-sm">Use the <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Variant</code> parameter to change badge styles.</p>
                        </Description>
                        <Preview>
                            <div class="flex flex-wrap gap-2">
                                <Badge>Default</Badge>
                                <Badge Variant="BadgeVariant.Secondary">Secondary</Badge>
                                <Badge Variant="BadgeVariant.Destructive">Destructive</Badge>
                                <Badge Variant="BadgeVariant.Outline">Outline</Badge>
                                <Badge Variant="BadgeVariant.Ghost">Ghost</Badge>
                                <Badge Variant="BadgeVariant.Link" Href="#" onclick="return false;">Link</Badge>
                            </div>
                        </Preview>
                        <Code>@codeVariants</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="With Icon" Compact="true" CodeText="@codeWithIcon">
                        <Preview>
                            <div class="flex flex-wrap gap-2">
                                <Badge Variant="BadgeVariant.Secondary">
                                    <svg data-icon="inline-start" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z" />
                                        <path d="m9 12 2 2 4-4" />
                                    </svg>
                                    Verified
                                </Badge>
                                <Badge Variant="BadgeVariant.Outline">
                                    Bookmark
                                    <svg data-icon="inline-end" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17 3a2 2 0 0 1 2 2v15a1 1 0 0 1-1.496.868l-4.512-2.578a2 2 0 0 0-1.984 0l-4.512 2.578A1 1 0 0 1 5 20V5a2 2 0 0 1 2-2z" />
                                    </svg>
                                </Badge>
                            </div>
                        </Preview>
                        <Code>@codeWithIcon</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="With Spinner" Compact="true" CodeText="@codeWithSpinner">
                        <Preview>
                            <div class="flex flex-wrap gap-2">
                                <Badge Variant="BadgeVariant.Destructive" Class="bg-red-50 text-red-700 dark:bg-red-950 dark:text-red-300">
                                    <svg role="status" aria-label="Loading" data-icon="inline-start" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-spin">
                                        <path d="M21 12a9 9 0 1 1-6.219-8.56" />
                                    </svg>
                                    Deleting
                                </Badge>
                                <Badge Variant="BadgeVariant.Secondary">
                                    Generating
                                    <svg role="status" aria-label="Loading" data-icon="inline-end" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-spin">
                                        <path d="M21 12a9 9 0 1 1-6.219-8.56" />
                                    </svg>
                                </Badge>
                            </div>
                        </Preview>
                        <Code>@codeWithSpinner</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Link" Compact="true" CodeText="@codeLink">
                        <Preview>
                            <div class="flex flex-wrap gap-2">
                                <Badge Href="#" onclick="return false;">
                                    Open Link
                                    <svg data-icon="inline-end" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M7 7h10v10" />
                                        <path d="M7 17 17 7" />
                                    </svg>
                                </Badge>
                            </div>
                        </Preview>
                        <Code>@codeLink</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Custom Colors" Compact="true" CodeText="@codeCustomColors">
                        <Preview>
                            <div class="flex flex-wrap gap-2">
                                <Badge Class="bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300">Blue</Badge>
                                <Badge Class="bg-green-50 text-green-700 dark:bg-green-950 dark:text-green-300">Green</Badge>
                                <Badge Class="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300">Sky</Badge>
                                <Badge Class="bg-purple-50 text-purple-700 dark:bg-purple-950 dark:text-purple-300">Purple</Badge>
                                <Badge Class="bg-red-50 text-red-700 dark:bg-red-950 dark:text-red-300">Red</Badge>
                            </div>
                        </Preview>
                        <Code>@codeCustomColors</Code>
                    </ComponentExample>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>
                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Badge</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Variant</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">Default | Secondary | Destructive | Outline | Ghost | Link</code></td><td class="px-4 py-2 text-left whitespace-nowrap">Default</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Href</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#variants" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Variants</a>
                <a href="#with-icon" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">With Icon</a>
                <a href="#with-spinner" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">With Spinner</a>
                <a href="#link" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Link</a>
                <a href="#custom-colors" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Custom Colors</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

@code {
    private const string canonicalBadgeSourcePath = "components/badge/Badge.razor";
    private string _badgeManualSource = string.Empty;

    protected override void OnInitialized()
    {
        var canonicalPath = Path.Combine(Environment.ContentRootPath, canonicalBadgeSourcePath.Replace('/', Path.DirectorySeparatorChar));
        _badgeManualSource = File.Exists(canonicalPath)
            ? File.ReadAllText(canonicalPath)
            : _sourceBadgeRazor;
    }

    private InstallationTab _installationTab = InstallationTab.Command;

    private enum InstallationTab
    {
        Command,
        Manual
    }

    private const string installCommand = "blazor-shadcn add badge";
    private const string referenceUrl = "https://ui.shadcn.com/docs/components/radix/badge";

    private static readonly string _sourceBadgeRazor = """
@if (string.IsNullOrEmpty(Href))
{
    <span data-slot="badge" data-variant="@Variant.ToString().ToLowerInvariant()" class="@GetClasses()" @attributes="AdditionalAttributes">
        @ChildContent
    </span>
}
else
{
    <a href="@Href" data-slot="badge" data-variant="@Variant.ToString().ToLowerInvariant()" class="@GetClasses()" @attributes="AdditionalAttributes">
        @ChildContent
    </a>
}

@code {
    [Parameter] public BadgeVariant Variant { get; set; } = BadgeVariant.Default;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Href { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const string BaseClasses =
        "inline-flex w-fit shrink-0 items-center justify-center whitespace-nowrap overflow-hidden " +
        "h-5 gap-1 rounded-4xl border border-transparent px-2 py-0.5 text-xs font-medium transition-all " +
        "has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&>svg]:size-3 [&>svg]:pointer-events-none " +
        "focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] " +
        "aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive";

    private string GetClasses() => Tw.Merge(BaseClasses, GetVariantClasses(), Class);

    private string GetVariantClasses() => Variant switch
    {
        BadgeVariant.Default => "bg-primary text-primary-foreground [a&]:hover:bg-primary/90",
        BadgeVariant.Secondary => "bg-secondary text-secondary-foreground [a&]:hover:bg-secondary/90",
        BadgeVariant.Destructive => "bg-destructive/10 [a]:hover:bg-destructive/20 focus-visible:ring-destructive/20 dark:focus-visible:ring-destructive/40 text-destructive dark:bg-destructive/20",
        BadgeVariant.Outline => "border-border text-foreground [a&]:hover:bg-accent [a&]:hover:text-accent-foreground",
        BadgeVariant.Ghost => "[a&]:hover:bg-accent [a&]:hover:text-accent-foreground",
        BadgeVariant.Link => "text-primary underline-offset-4 [a&]:hover:underline",
        _ => ""
    };

    public enum BadgeVariant
    {
        Default,
        Secondary,
        Destructive,
        Outline,
        Ghost,
        Link
    }
}
""";

    private const string usingStatement = "@using BlazorShadcn.Components.UI";
    private const string usageCode = "<Badge Variant=\"BadgeVariant.Outline\">Badge</Badge>";

    private const string codeMainDemo = @"<div class=""flex w-full flex-wrap justify-center gap-2"">
    <Badge>Badge</Badge>
    <Badge Variant=""BadgeVariant.Secondary"">Secondary</Badge>
    <Badge Variant=""BadgeVariant.Destructive"">Destructive</Badge>
    <Badge Variant=""BadgeVariant.Outline"">Outline</Badge>
</div>";

    private const string codeVariants = @"<Badge>Default</Badge>
<Badge Variant=""BadgeVariant.Secondary"">Secondary</Badge>
<Badge Variant=""BadgeVariant.Destructive"">Destructive</Badge>
