@page "/components/select"

<PageTitle>Select - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Select</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="@Button.ButtonVariant.Secondary" Size="@Button.ButtonSize.Icon" Href="/components/scroll-area" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="@Button.ButtonVariant.Secondary" Size="@Button.ButtonSize.Icon" Href="/components/separator" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    Displays a list of options for the user to pick from, triggered by a button.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@mainDemoCode">
                    <Preview>
                        <Select>
                            <SelectTrigger Class="w-full max-w-48">
                                <SelectValue Placeholder="Select a fruit" />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectGroup>
                                    <SelectLabel>Fruits</SelectLabel>
                                    <SelectItem Value="apple" Text="Apple">Apple</SelectItem>
                                    <SelectItem Value="banana" Text="Banana">Banana</SelectItem>
                                    <SelectItem Value="blueberry" Text="Blueberry">Blueberry</SelectItem>
                                    <SelectItem Value="grapes" Text="Grapes">Grapes</SelectItem>
                                    <SelectItem Value="pineapple" Text="Pineapple">Pineapple</SelectItem>
                                </SelectGroup>
                            </SelectContent>
                        </Select>
                    </Preview>
                    <Code>@mainDemoCode</Code>
                </ComponentExample>

                <DocsInstallationSection ComponentLabel="select"
                                         InstallCommand="blazor-shadcn add select"
                                         SourcePaths="@_manualSourcePaths"
                                         DependencyCommands="@_dependencyCommands"
                                         ImportStep="@manualImportStep" />

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>

                <div class="mt-6">
                    <ComponentExample Title="Align Item With Trigger" Compact="true" CodeText="@alignItemCode">
                        <Description>
                            <p class="text-muted-foreground text-sm">Use the <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Position</code> parameter on <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SelectContent</code> to control alignment.</p>
                        </Description>
                        <Preview>
                            <div class="grid w-full max-w-xs gap-4">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="grid gap-1">
                                        <Label for="select-align-item" Class="font-medium">Align Item</Label>
                                        <p class="text-muted-foreground text-sm">Toggle to align the item with the trigger.</p>
                                    </div>
                                    <Switch id="select-align-item" Checked="@_alignItemWithTrigger" CheckedChanged="(value) => _alignItemWithTrigger = value" />
                                </div>
                                <Select DefaultValue="banana">
                                    <SelectTrigger Class="w-full">
                                        <SelectValue />
                                    </SelectTrigger>
                                    <SelectContent Position="@(_alignItemWithTrigger ? "item-aligned" : "popper")">
                                        <SelectGroup>
                                            <SelectItem Value="apple" Text="Apple">Apple</SelectItem>
                                            <SelectItem Value="banana" Text="Banana">Banana</SelectItem>
                                            <SelectItem Value="blueberry" Text="Blueberry">Blueberry</SelectItem>
                                            <SelectItem Value="grapes" Text="Grapes">Grapes</SelectItem>
                                            <SelectItem Value="pineapple" Text="Pineapple">Pineapple</SelectItem>
                                        </SelectGroup>
                                    </SelectContent>
                                </Select>
                            </div>
                        </Preview>
                        <Code>@alignItemCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Groups" Compact="true" CodeText="@groupsCode">
                        <Description>
                            <p class="text-muted-foreground text-sm">Use <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SelectGroup</code>, <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SelectLabel</code>, and <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SelectSeparator</code> to organize items.</p>
                        </Description>
                        <Preview>
                            <Select>
                                <SelectTrigger Class="w-full max-w-48">
                                    <SelectValue Placeholder="Select a fruit" />
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectGroup>
                                        <SelectLabel>Fruits</SelectLabel>
                                        <SelectItem Value="apple" Text="Apple">Apple</SelectItem>
                                        <SelectItem Value="banana" Text="Banana">Banana</SelectItem>
                                        <SelectItem Value="blueberry" Text="Blueberry">Blueberry</SelectItem>
                                    </SelectGroup>
                                    <SelectSeparator />
                                    <SelectGroup>
                                        <SelectLabel>Vegetables</SelectLabel>
                                        <SelectItem Value="carrot" Text="Carrot">Carrot</SelectItem>
                                        <SelectItem Value="broccoli" Text="Broccoli">Broccoli</SelectItem>
                                        <SelectItem Value="spinach" Text="Spinach">Spinach</SelectItem>
                                    </SelectGroup>
                                </SelectContent>
                            </Select>
                        </Preview>
                        <Code>@groupsCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Scrollable" Compact="true" CodeText="@scrollableCode">
                        <Description>
                            <p class="text-muted-foreground text-sm">A select with many items that scrolls.</p>
                        </Description>
                        <Preview>
                            <Select>
                                <SelectTrigger Class="w-full max-w-64">
                                    <SelectValue Placeholder="Select a timezone" />
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectGroup>
                                        <SelectLabel>North America</SelectLabel>
                                        <SelectItem Value="est" Text="Eastern Standard Time">Eastern Standard Time</SelectItem>
                                        <SelectItem Value="cst" Text="Central Standard Time">Central Standard Time</SelectItem>
                                        <SelectItem Value="mst" Text="Mountain Standard Time">Mountain Standard Time</SelectItem>
                                        <SelectItem Value="pst" Text="Pacific Standard Time">Pacific Standard Time</SelectItem>
                                        <SelectItem Value="akst" Text="Alaska Standard Time">Alaska Standard Time</SelectItem>
                                        <SelectItem Value="hst" Text="Hawaii Standard Time">Hawaii Standard Time</SelectItem>
                                    </SelectGroup>
                                    <SelectGroup>
                                        <SelectLabel>Europe &amp; Africa</SelectLabel>
                                        <SelectItem Value="gmt" Text="Greenwich Mean Time">Greenwich Mean Time</SelectItem>
                                        <SelectItem Value="cet" Text="Central European Time">Central European Time</SelectItem>
                                        <SelectItem Value="eet" Text="Eastern European Time">Eastern European Time</SelectItem>
                                        <SelectItem Value="west" Text="Western European Summer Time">Western European Summer Time</SelectItem>
                                        <SelectItem Value="cat" Text="Central Africa Time">Central Africa Time</SelectItem>
                                        <SelectItem Value="eat" Text="East Africa Time">East Africa Time</SelectItem>
                                    </SelectGroup>
                                    <SelectGroup>
                                        <SelectLabel>Asia</SelectLabel>
                                        <SelectItem Value="msk" Text="Moscow Time">Moscow Time</SelectItem>
                                        <SelectItem Value="ist" Text="India Standard Time">India Standard Time</SelectItem>
                                        <SelectItem Value="cst_china" Text="China Standard Time">China Standard Time</SelectItem>
                                        <SelectItem Value="jst" Text="Japan Standard Time">Japan Standard Time</SelectItem>
                                        <SelectItem Value="kst" Text="Korea Standard Time">Korea Standard Time</SelectItem>
                                        <SelectItem Value="ist_indonesia" Text="Indonesia Central Standard Time">Indonesia Central Standard Time</SelectItem>
                                    </SelectGroup>
                                    <SelectGroup>
                                        <SelectLabel>Australia &amp; Pacific</SelectLabel>
                                        <SelectItem Value="awst" Text="Australian Western Standard Time">Australian Western Standard Time</SelectItem>
                                        <SelectItem Value="acst" Text="Australian Central Standard Time">Australian Central Standard Time</SelectItem>
                                        <SelectItem Value="aest" Text="Australian Eastern Standard Time">Australian Eastern Standard Time</SelectItem>
                                        <SelectItem Value="nzst" Text="New Zealand Standard Time">New Zealand Standard Time</SelectItem>
                                        <SelectItem Value="fjt" Text="Fiji Time">Fiji Time</SelectItem>
                                    </SelectGroup>
                                    <SelectGroup>
                                        <SelectLabel>South America</SelectLabel>
                                        <SelectItem Value="art" Text="Argentina Time">Argentina Time</SelectItem>
                                        <SelectItem Value="bot" Text="Bolivia Time">Bolivia Time</SelectItem>
                                        <SelectItem Value="brt" Text="Brasilia Time">Brasilia Time</SelectItem>
                                        <SelectItem Value="clt" Text="Chile Standard Time">Chile Standard Time</SelectItem>
                                    </SelectGroup>
                                </SelectContent>
                            </Select>
                        </Preview>
                        <Code>@scrollableCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Disabled" Compact="true" CodeText="@disabledCode">
                        <Preview>
                            <Select Disabled="true">
                                <SelectTrigger Class="w-full max-w-48">
                                    <SelectValue Placeholder="Select a fruit" />
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectGroup>
                                        <SelectItem Value="apple" Text="Apple">Apple</SelectItem>
                                        <SelectItem Value="banana" Text="Banana">Banana</SelectItem>
                                        <SelectItem Value="blueberry" Text="Blueberry">Blueberry</SelectItem>
                                        <SelectItem Value="grapes" Text="Grapes" Disabled="true">Grapes</SelectItem>
                                        <SelectItem Value="pineapple" Text="Pineapple">Pineapple</SelectItem>
                                    </SelectGroup>
                                </SelectContent>
                            </Select>
                        </Preview>
                        <Code>@disabledCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Invalid" Compact="true" CodeText="@invalidCode">
                        <Description>
                            <p class="text-muted-foreground text-sm">Add <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">data-invalid</code> to the field wrapper and <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">aria-invalid="true"</code> to <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SelectTrigger</code> to show an error state.</p>
                        </Description>
                        <Preview>
                            <div class="grid w-full max-w-48 gap-2" data-invalid>
                                <Label for="invalid-select" Class="text-destructive">Fruit</Label>
                                <Select>
                                    <SelectTrigger Id="invalid-select" Class="w-full" aria-invalid="true">
                                        <SelectValue Placeholder="Select a fruit" />
                                    </SelectTrigger>
                                    <SelectContent>
                                        <SelectGroup>
                                            <SelectItem Value="apple" Text="Apple">Apple</SelectItem>
                                            <SelectItem Value="banana" Text="Banana">Banana</SelectItem>
                                            <SelectItem Value="blueberry" Text="Blueberry">Blueberry</SelectItem>
                                        </SelectGroup>
                                    </SelectContent>
                                </Select>
                                <p class="text-destructive text-sm">Please select a fruit.</p>
                            </div>
                        </Preview>
                        <Code>@invalidCode</Code>
                    </ComponentExample>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Select</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead><tr class="m-0 border-b"><th class="px-4 py-2 text-left font-bold">Prop</th><th class="px-4 py-2 text-left font-bold">Type</th><th class="px-4 py-2 text-left font-bold">Default</th></tr></thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Value</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ValueChanged</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">EventCallback&lt;string?&gt;</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">DefaultValue</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Disabled</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">SelectTrigger</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead><tr class="m-0 border-b"><th class="px-4 py-2 text-left font-bold">Prop</th><th class="px-4 py-2 text-left font-bold">Type</th><th class="px-4 py-2 text-left font-bold">Default</th></tr></thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Id</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Placeholder</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Size</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">Default | Sm</code></td><td class="px-4 py-2 text-left whitespace-nowrap">Default</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">SelectValue</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead><tr class="m-0 border-b"><th class="px-4 py-2 text-left font-bold">Prop</th><th class="px-4 py-2 text-left font-bold">Type</th><th class="px-4 py-2 text-left font-bold">Default</th></tr></thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Placeholder</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">SelectContent</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead><tr class="m-0 border-b"><th class="px-4 py-2 text-left font-bold">Prop</th><th class="px-4 py-2 text-left font-bold">Type</th><th class="px-4 py-2 text-left font-bold">Default</th></tr></thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Position</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string</code></td><td class="px-4 py-2 text-left whitespace-nowrap">item-aligned</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Align</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string</code></td><td class="px-4 py-2 text-left whitespace-nowrap">center</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">SelectItem</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead><tr class="m-0 border-b"><th class="px-4 py-2 text-left font-bold">Prop</th><th class="px-4 py-2 text-left font-bold">Type</th><th class="px-4 py-2 text-left font-bold">Default</th></tr></thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Value</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Text</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Disabled</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">SelectGroup, SelectLabel, SelectSeparator</h3>
                <p class="text-muted-foreground mt-2 text-sm">These are structural helpers for organizing content inside <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SelectContent</code>. They do not expose additional public parameters beyond standard <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Class</code> and unmatched attributes.</p>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <DocsPageLinks />
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _alignItemWithTrigger = true;

    private const string referenceUrl = "https://ui.shadcn.com/docs/components/radix/select";
    private const string manualImportStep = "Add @using ShadcnBlazor.Components.UI to Components/_Imports.razor";
    private const string usingStatement = "@using ShadcnBlazor.Components.UI";

    private static readonly string[] _dependencyCommands =
    [
        "npm install radix-ui"
    ];

    private static readonly string[] _manualSourcePaths =
    [
        "components/select/Select.razor",
        "components/select/SelectContext.cs",
        "components/select/SelectTrigger.razor",
        "components/select/SelectValue.razor",
        "components/select/SelectContent.razor",
        "components/select/SelectGroup.razor",
        "components/select/SelectLabel.razor",
        "components/select/SelectItem.razor",
        "components/select/SelectSeparator.razor"
    ];

    private const string usageCode = """
<Select>
    <SelectTrigger Class="w-[180px]">
        <SelectValue Placeholder="Theme" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectItem Value="light" Text="Light">Light</SelectItem>
            <SelectItem Value="dark" Text="Dark">Dark</SelectItem>
            <SelectItem Value="system" Text="System">System</SelectItem>
        </SelectGroup>
    </SelectContent>
</Select>
""";

    private const string mainDemoCode = """
<Select>
    <SelectTrigger Class="w-full max-w-48">
        <SelectValue Placeholder="Select a fruit" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectLabel>Fruits</SelectLabel>
            <SelectItem Value="apple" Text="Apple">Apple</SelectItem>
            <SelectItem Value="banana" Text="Banana">Banana</SelectItem>
            <SelectItem Value="blueberry" Text="Blueberry">Blueberry</SelectItem>
            <SelectItem Value="grapes" Text="Grapes">Grapes</SelectItem>
            <SelectItem Value="pineapple" Text="Pineapple">Pineapple</SelectItem>
        </SelectGroup>
    </SelectContent>
</Select>
""";

    private const string alignItemCode = """
<div class="grid w-full max-w-xs gap-4">
    <div class="flex items-start justify-between gap-4">
        <div class="grid gap-1">
            <Label for="select-align-item" Class="font-medium">Align Item</Label>
            <p class="text-muted-foreground text-sm">Toggle to align the item with the trigger.</p>
        </div>
        <Switch id="select-align-item" Checked="@_alignItemWithTrigger" CheckedChanged="(value) => _alignItemWithTrigger = value" />
    </div>
    <Select DefaultValue="banana">
        <SelectTrigger Class="w-full">
            <SelectValue />
        </SelectTrigger>
        <SelectContent Position="@(_alignItemWithTrigger ? "item-aligned" : "popper")">
            <SelectGroup>
                <SelectItem Value="apple" Text="Apple">Apple</SelectItem>
                <SelectItem Value="banana" Text="Banana">Banana</SelectItem>
                <SelectItem Value="blueberry" Text="Blueberry">Blueberry</SelectItem>
                <SelectItem Value="grapes" Text="Grapes">Grapes</SelectItem>
                <SelectItem Value="pineapple" Text="Pineapple">Pineapple</SelectItem>
            </SelectGroup>
        </SelectContent>
    </Select>
</div>

@code {
    private bool _alignItemWithTrigger = true;
}
""";

