""";
    private const string rtlCode = """
<div dir="rtl">
    <Select>
        <SelectTrigger Class="w-[180px]">
            <SelectValue Placeholder="Select a fruit" />
        </SelectTrigger>
        <SelectContent>
            <SelectGroup>
                <SelectLabel>Fruits</SelectLabel>
                <SelectItem Value="apple" Text="Apple">Apple</SelectItem>
                <SelectItem Value="banana" Text="Banana">Banana</SelectItem>
                <SelectItem Value="blueberry" Text="Blueberry">Blueberry</SelectItem>
            </SelectGroup>
        </SelectContent>
    </Select>
</div>
""";

    private readonly List<ManualSource> _manualSources = [];

    protected override void OnInitialized()
    {
        foreach (var path in new[]
        {
            "Components/UI/Select.razor",
            "Components/UI/SelectContext.cs",
            "Components/UI/SelectTrigger.razor",
            "Components/UI/SelectValue.razor",
            "Components/UI/SelectContent.razor",
            "Components/UI/SelectGroup.razor",
            "Components/UI/SelectLabel.razor",
            "Components/UI/SelectItem.razor",
            "Components/UI/SelectSeparator.razor"
        })
        {
            _manualSources.Add(new ManualSource(path, ReadSource(path)));
        }
    }

    private string ReadSource(string relativePath)
    {
        var path = Path.Combine(Environment.ContentRootPath, relativePath.Replace('/', Path.DirectorySeparatorChar));
        return File.Exists(path) ? File.ReadAllText(path) : $"Missing source: {relativePath}";
    }

    private enum InstallationTab
    {
        Command,
        Manual
    }

    private sealed record ManualSource(string Path, string Content);
}

