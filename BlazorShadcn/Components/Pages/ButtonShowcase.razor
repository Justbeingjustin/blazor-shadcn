                <div class="mt-6">
                    <ComponentExample Title="Size" Compact="true" CodeText="@codeSizeExample">
                        <Description>
                            <p class="text-muted-foreground text-sm">Use the <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Size</code> parameter to change the size of the button.</p>
                        </Description>
                        <Preview>
                            <div class="flex flex-col items-start gap-8 sm:flex-row">
                                <div class="flex items-start gap-2">
                                    <Button Size="ButtonSize.Xs" Variant="ButtonVariant.Outline">Extra Small</Button>
                                    <Button Size="ButtonSize.IconXs" Variant="ButtonVariant.Outline"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 7 10 10"/><path d="M17 7v10H7"/></svg></Button>
                                </div>
                                <div class="flex items-start gap-2">
                                    <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Small</Button>
                                    <Button Size="ButtonSize.IconSm" Variant="ButtonVariant.Outline"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 7 10 10"/><path d="M17 7v10H7"/></svg></Button>
                                </div>
                                <div class="flex items-start gap-2">
                                    <Button Variant="ButtonVariant.Outline">Default</Button>
                                    <Button Size="ButtonSize.Icon" Variant="ButtonVariant.Outline"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 7 10 10"/><path d="M17 7v10H7"/></svg></Button>
                                </div>
                                <div class="flex items-start gap-2">
                                    <Button Size="ButtonSize.Lg" Variant="ButtonVariant.Outline">Large</Button>
                                    <Button Size="ButtonSize.IconLg" Variant="ButtonVariant.Outline"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 7 10 10"/><path d="M17 7v10H7"/></svg></Button>
                                </div>
                            </div>
                        </Preview>
                        <Code>@codeSizeExample</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Default" Compact="true" CodeText="@codeDefault">
