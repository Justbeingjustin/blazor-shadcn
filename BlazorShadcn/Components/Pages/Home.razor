@page "/"

<PageTitle>blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <div class="flex items-center gap-2">
                        <h1 class="font-heading mt-2 scroll-m-28 text-3xl font-semibold tracking-tight focus:outline-none">Introduction</h1>
                    </div>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                    </div>
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    Beautifully designed components for Blazor.
                </p>
            </div>

            <div class="w-full flex-1">
                <p class="leading-relaxed mt-6">
                    This is not a component library. It is how you build your component library.
                </p>

                <p class="leading-relaxed mt-6">
                    Blazor ShadCN brings the <a href="https://ui.shadcn.com" target="_blank" rel="noopener noreferrer" class="font-medium underline underline-offset-4">shadcn/ui</a>
                    approach to Blazor. Instead of importing components from a packaged UI library, you install the source code directly into your project.
                </p>

                <p class="leading-relaxed mt-6">
                    Traditional component libraries work well until you need deeper customization. At that point, you often end up wrapping library components, overriding styles, or mixing APIs from multiple libraries to get the result you want.
                </p>

                <p class="leading-relaxed mt-6">
                    Blazor ShadCN takes a different approach. Use the CLI to scaffold a project and install components into your app. Once added, the code is part of your project and can be customized freely.
                </p>

                <div class="rounded-xl border p-6 my-6">
                    <p class="font-medium leading-relaxed">
                        The CLI is distributed via NuGet as a .NET tool. The components themselves are not distributed as a UI library. They are installed into your project as source code, and the code is yours.
                    </p>
                </div>

                <p class="leading-relaxed mt-6">
                    There is no runtime dependency on a separate UI package.
                </p>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12">
                    Install
                </h2>

                <div class="mt-6 space-y-6">
                    <div class="space-y-3">
                        <p class="text-sm font-medium">Install the CLI:</p>
                        <CodeBlock RawText="@installToolCode">@installToolCode</CodeBlock>
                    </div>

                    <div class="space-y-3">
                        <p class="text-sm font-medium">Create a new project:</p>
                        <CodeBlock RawText="@createProjectCode">@createProjectCode</CodeBlock>
                    </div>

                    <div class="space-y-3">
                        <p class="text-sm font-medium">Add your first component:</p>
                        <CodeBlock RawText="@addComponentCode">@addComponentCode</CodeBlock>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@code {
    private const string referenceUrl = "https://ui.shadcn.com/docs";

    private const string installToolCode = "dotnet tool install -g blazor-shadcn";

    private const string createProjectCode = """
blazor-shadcn new MyApp
cd MyApp
""";

    private const string addComponentCode = "blazor-shadcn add button";
}
