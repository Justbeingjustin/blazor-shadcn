@page "/components/button-group"

<PageTitle>Button Group - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Button Group</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage />
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/button" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/calendar" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    A container that groups related buttons together with consistent styling.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@usageCode">
                    <Preview>
                        <ButtonGroup>
                            <Button Variant="ButtonVariant.Outline">Left</Button>
                            <Button Variant="ButtonVariant.Outline">Middle</Button>
                            <Button Variant="ButtonVariant.Outline">Right</Button>
                        </ButtonGroup>
                    </Preview>
                    <Code>@usageCode</Code>
                </ComponentExample>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6"><CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock></div>
                <div class="mt-4"><CodeBlock RawText="@usageCode">@usageCode</CodeBlock></div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>
                <div class="mt-6">
                    <ComponentExample Title="Orientation" Compact="true">
                        <Preview>
                            <div class="flex flex-wrap gap-4">
                                <ButtonGroup>
                                    <Button Variant="ButtonVariant.Outline">A</Button>
                                    <Button Variant="ButtonVariant.Outline">B</Button>
                                    <Button Variant="ButtonVariant.Outline">C</Button>
                                </ButtonGroup>
                                <ButtonGroup Orientation="ButtonGroup.GroupOrientation.Vertical">
                                    <Button Variant="ButtonVariant.Outline">Top</Button>
                                    <Button Variant="ButtonVariant.Outline">Middle</Button>
                                    <Button Variant="ButtonVariant.Outline">Bottom</Button>
                                </ButtonGroup>
                            </div>
                        </Preview>
                        <Code>@orientationCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Separator" Compact="true">
                        <Preview>
                            <ButtonGroup>
                                <Button>Publish</Button>
                                <ButtonGroupSeparator />
                                <Button Variant="ButtonVariant.Secondary">Preview</Button>
                            </ButtonGroup>
                        </Preview>
                        <Code>@separatorCode</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Input" Compact="true">
                        <Preview>
                            <ButtonGroup Class="w-full max-w-md">
                                <ButtonGroupText>https://</ButtonGroupText>
                                <Input Placeholder="example.com" Class="rounded-none border-x-0" />
                                <Button>Go</Button>
                            </ButtonGroup>
                        </Preview>
                        <Code>@inputCode</Code>
                    </ComponentExample>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <DocsPageLinks />
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
            </div>
        </div>
    </div>
</div>

@code {
    private const string usingStatement = "@using BlazorShadcn.Components.UI";
    private const string usageCode = """<ButtonGroup><Button>Button 1</Button><Button>Button 2</Button></ButtonGroup>""";
    private const string orientationCode = """<ButtonGroup Orientation="ButtonGroup.GroupOrientation.Vertical">...</ButtonGroup>""";
    private const string separatorCode = """<ButtonGroup><Button>Publish</Button><ButtonGroupSeparator /><Button Variant="ButtonVariant.Secondary">Preview</Button></ButtonGroup>""";
    private const string inputCode = """<ButtonGroup><ButtonGroupText>https://</ButtonGroupText><Input /><Button>Go</Button></ButtonGroup>""";
}
