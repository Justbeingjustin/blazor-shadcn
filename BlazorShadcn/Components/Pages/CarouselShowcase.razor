@page "/components/carousel"
@implements IDisposable

<PageTitle>Carousel - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Carousel</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/card" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/chart" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    Displays the Carousel component.
                </p>
            </div>

            <div class="w-full flex-1">
                @* Reference ComponentPreview: carousel-demo *@
                <ComponentExample Compact="true" CodeText="@usageCode">
                    <Preview>
                        <div class="mx-auto max-w-xs px-12">
                            <Carousel Class="w-full max-w-xs">
                                <CarouselContent>
                                    @foreach (var slide in slides)
                                    {
                                        <CarouselItem>
                                            <div class="p-1">
                                                <Card>
                                                    <CardContent Class="flex aspect-square items-center justify-center p-6">
                                                        <span class="text-4xl font-semibold">@slide</span>
                                                    </CardContent>
                                                </Card>
                                            </div>
                                        </CarouselItem>
                                    }
                                </CarouselContent>
                                <CarouselPrevious />
                                <CarouselNext />
                            </Carousel>
                        </div>
                    </Preview>
                    <Code>@usageCode</Code>
                </ComponentExample>

                <DocsInstallationSection ComponentLabel="carousel"
                                         InstallCommand="blazor-shadcn add carousel"
                                         SourcePaths="@_manualSourcePaths"
                                         ImportStep="@manualImportStep" />

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight" id="sizes">Sizes</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                    Use basis utilities on <code>CarouselItem</code> to control how many slides are visible at each breakpoint.
                </p>
                <div class="mt-6">
                    @* Reference ComponentPreview: carousel-size *@
                    <ComponentExample Compact="true" CodeText="@sizeCode">
                        <Preview>
                            <div class="mx-auto max-w-sm px-12">
                                <Carousel Class="w-full max-w-sm">
                                    <CarouselContent>
                                        @foreach (var slide in slides)
                                        {
                                            <CarouselItem Class="md:basis-1/2 lg:basis-1/3">
                                                <div class="p-1">
                                                    <Card>
                                                        <CardContent Class="flex aspect-square items-center justify-center p-6">
                                                            <span class="text-3xl font-semibold">@slide</span>
                                                        </CardContent>
                                                    </Card>
                                                </div>
                                            </CarouselItem>
                                        }
                                    </CarouselContent>
                                    <CarouselPrevious />
                                    <CarouselNext />
                                </Carousel>
                            </div>
                        </Preview>
                        <Code>@sizeCode</Code>
                    </ComponentExample>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight" id="spacing">Spacing</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                    Override the default spacing with matching negative margin on <code>CarouselContent</code> and padding on each <code>CarouselItem</code>.
                </p>
                <div class="mt-6">
                    @* Reference ComponentPreview: carousel-spacing *@
                    <ComponentExample Compact="true" CodeText="@spacingCode">
                        <Preview>
                            <div class="mx-auto max-w-sm px-12">
                                <Carousel Class="w-full max-w-sm">
                                    <CarouselContent Class="-ml-1">
                                        @foreach (var slide in slides)
                                        {
                                            <CarouselItem Class="pl-1 md:basis-1/2 lg:basis-1/3">
                                                <div class="p-1">
                                                    <Card>
                                                        <CardContent Class="flex aspect-square items-center justify-center p-6">
                                                            <span class="text-2xl font-semibold">@slide</span>
                                                        </CardContent>
                                                    </Card>
                                                </div>
                                            </CarouselItem>
                                        }
                                    </CarouselContent>
                                    <CarouselPrevious />
                                    <CarouselNext />
                                </Carousel>
                            </div>
                        </Preview>
                        <Code>@spacingCode</Code>
                    </ComponentExample>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight" id="orientation">Orientation</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                    Set <code>Orientation</code> to <code>Vertical</code> to stack slides and move the navigation controls above and below the viewport.
                </p>
                <div class="mt-6">
                    @* Reference ComponentPreview: carousel-orientation *@
                    <ComponentExample Compact="true" CodeText="@orientationCode">
                        <Preview>
                            <div class="mx-auto max-w-md px-12 py-12">
                                <Carousel Orientation="Carousel.CarouselOrientation.Vertical" Class="h-[220px] w-full max-w-md">
                                    <CarouselContent Class="-mt-1 h-full">
                                        @foreach (var slide in slides)
                                        {
                                            <CarouselItem Class="pt-1 basis-1/2">
                                                <div class="p-1">
                                                    <Card Class="h-full">
                                                        <CardContent Class="flex h-full items-center justify-center">
                                                            <span class="text-3xl font-semibold">@slide</span>
                                                        </CardContent>
                                                    </Card>
                                                </div>
                                            </CarouselItem>
                                        }
                                    </CarouselContent>
                                    <CarouselPrevious />
                                    <CarouselNext />
                                </Carousel>
                            </div>
                        </Preview>
                        <Code>@orientationCode</Code>
                    </ComponentExample>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight" id="api">API</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                    Use <code>ApiChanged</code> to capture the carousel API and <code>StateChanged</code> to react to selection changes.
                </p>
                <div class="mt-6">
                    @* Reference ComponentPreview: carousel-api *@
                    <ComponentExample Compact="true" CodeText="@apiCode">
                        <Preview>
                            <div class="mx-auto max-w-xs px-12">
                                <Carousel Class="w-full max-w-xs"
                                          ApiChanged="HandleApiExampleApiChanged"
                                          StateChanged="HandleApiExampleStateChanged">
                                    <CarouselContent>
                                        @foreach (var slide in slides)
                                        {
                                            <CarouselItem>
                                                <Card>
                                                    <CardContent Class="flex aspect-square items-center justify-center p-6">
                                                        <span class="text-4xl font-semibold">@slide</span>
                                                    </CardContent>
                                                </Card>
                                            </CarouselItem>
                                        }
                                    </CarouselContent>
                                    <CarouselPrevious />
                                    <CarouselNext />
                                </Carousel>
                                <div class="py-2 text-center text-sm text-muted-foreground">
                                    Slide @ApiExampleDisplayCurrent of @_apiExampleCount
                                </div>
                            </div>
                        </Preview>
                        <Code>@apiCode</Code>
                    </ComponentExample>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight" id="autoplay">Autoplay</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                    This mirrors the reference plugin demo with a timer-driven autoplay example that pauses while the preview is hovered.
                </p>
                <div class="mt-6">
                    @* Reference ComponentPreview: carousel-plugin *@
                    <ComponentExample Compact="true" CodeText="@autoplayCode">
                        <Preview>
                            <div class="mx-auto max-w-xs px-12"
                                 @onmouseenter="PauseAutoplay"
                                 @onmouseleave="ResumeAutoplay">
                                <Carousel Class="w-full max-w-xs"
                                          ApiChanged="HandleAutoplayApiChanged"
                                          StateChanged="HandleAutoplayStateChanged">
                                    <CarouselContent>
                                        @foreach (var slide in slides)
                                        {
                                            <CarouselItem>
                                                <div class="p-1">
                                                    <Card>
                                                        <CardContent Class="flex aspect-square items-center justify-center p-6">
                                                            <span class="text-4xl font-semibold">@slide</span>
                                                        </CardContent>
                                                    </Card>
                                                </div>
                                            </CarouselItem>
                                        }
                                    </CarouselContent>
                                    <CarouselPrevious />
                                    <CarouselNext />
                                </Carousel>
                                <div class="py-2 text-center text-sm text-muted-foreground">
                                    Hover to pause. Slide @AutoplayDisplayCurrent of @_autoplayCount.
                                </div>
                            </div>
                        </Preview>
                        <Code>@autoplayCode</Code>
                    </ComponentExample>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Carousel</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Orientation</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">Horizontal | Vertical</code></td><td class="px-4 py-2 text-left whitespace-nowrap">Horizontal</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ApiChanged</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">EventCallback&lt;CarouselApi&gt;</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">StateChanged</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">EventCallback&lt;CarouselApi&gt;</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">CarouselContent</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">CarouselItem</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">CarouselPrevious</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Variant</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">ButtonVariant</code></td><td class="px-4 py-2 text-left whitespace-nowrap">Outline</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Size</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">ButtonSize</code></td><td class="px-4 py-2 text-left whitespace-nowrap">Icon</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Disabled</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">CarouselNext</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Variant</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">ButtonVariant</code></td><td class="px-4 py-2 text-left whitespace-nowrap">Outline</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Size</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">ButtonSize</code></td><td class="px-4 py-2 text-left whitespace-nowrap">Icon</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Disabled</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">CarouselApi</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">
                    The <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">CarouselApi</code> instance exposes
                    <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">CanScrollPrev</code>,
                    <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">CanScrollNext</code>,
                    <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SelectedIndex</code>,
                    <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SlideCount</code>,
                    <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">ScrollPrevAsync()</code>,
                    <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">ScrollNextAsync()</code>, and
                    <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">ScrollToAsync(int index)</code>.
                    <span class="block mt-2">SelectedIndex is zero-based, so add 1 when rendering human-readable slide numbers.</span>
                </p>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <DocsPageLinks />
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#sizes" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Sizes</a>
