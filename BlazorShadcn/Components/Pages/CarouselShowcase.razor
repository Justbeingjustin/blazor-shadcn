    private Task HandleAutoplayApiChanged(CarouselApi carouselApi)
    {
        _autoplayApi = carouselApi;
        SyncAutoplayState(carouselApi);
        EnsureAutoplayTimer();
        return Task.CompletedTask;
    }

    private Task HandleAutoplayStateChanged(CarouselApi carouselApi)
    {
        _autoplayApi = carouselApi;
        SyncAutoplayState(carouselApi);
        return Task.CompletedTask;
    }

    private void SyncApiExampleState(CarouselApi carouselApi)
    {
        _apiExampleCurrent = carouselApi.SelectedIndex;
        _apiExampleCount = carouselApi.SlideCount == 0 ? slides.Length : carouselApi.SlideCount;
    }

    private void SyncAutoplayState(CarouselApi carouselApi)
    {
        _autoplayCurrent = carouselApi.SelectedIndex;
        _autoplayCount = carouselApi.SlideCount == 0 ? slides.Length : carouselApi.SlideCount;
    }

    private void EnsureAutoplayTimer()
    {
        _autoplayTimer ??= new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(HandleAutoplayTickAsync);
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private async Task HandleAutoplayTickAsync()
    {
        if (_autoplayTickInProgress || _autoplayPaused || _autoplayApi is null || _autoplayApi.SlideCount == 0)
        {
            return;
        }

        _autoplayTickInProgress = true;

        try
        {
            if (_autoplayApi.SelectedIndex >= _autoplayApi.SlideCount - 1)
            {
                await _autoplayApi.ScrollToAsync(0);
                return;
            }

            await _autoplayApi.ScrollNextAsync();
        }
        finally
        {
            _autoplayTickInProgress = false;
        }
    }

    private void PauseAutoplay(MouseEventArgs _)
    {
        _autoplayPaused = true;
    }

    private void ResumeAutoplay(MouseEventArgs _)
    {
        _autoplayPaused = false;
    }

    public void Dispose()
    {
        _autoplayTimer?.Dispose();
    }

