    private ManualSource LoadSource(string fileName)
    {
        var canonicalPath = Path.GetFullPath(Path.Combine(Environment.ContentRootPath, "..", canonicalDropdownMenuDirectory.Replace('/', Path.DirectorySeparatorChar), fileName));
        var content = File.Exists(canonicalPath)
            ? File.ReadAllText(canonicalPath)
            : $"Missing source: {canonicalDropdownMenuDirectory}/{fileName}";
        return new ManualSource($"{canonicalDropdownMenuDirectory}/{fileName}", content);
    }

