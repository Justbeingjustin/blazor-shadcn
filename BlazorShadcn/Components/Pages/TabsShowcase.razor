@page "/components/tabs"

<PageTitle>Tabs - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Tabs</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/table" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/textarea" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    A set of layered sections of content known as tab panels that are displayed one at a time.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@codeDemo">
                    <Preview>
                        <div class="flex w-full max-w-sm flex-col gap-6">
                            <Tabs DefaultValue="overview" Class="w-full">
                                <TabsList>
                                    <TabsTrigger Value="overview">Overview</TabsTrigger>
                                    <TabsTrigger Value="analytics">Analytics</TabsTrigger>
                                    <TabsTrigger Value="reports">Reports</TabsTrigger>
                                    <TabsTrigger Value="settings">Settings</TabsTrigger>
                                </TabsList>
                                <TabsContent Value="overview">
                                    <Card>
                                        <CardHeader>
                                            <CardTitle>Overview</CardTitle>
                                            <CardDescription>View your key metrics and recent project activity. Track progress across all your active projects.</CardDescription>
                                        </CardHeader>
                                        <CardContent Class="text-sm text-muted-foreground">
                                            You have 12 active projects and 3 pending tasks.
                                        </CardContent>
                                    </Card>
                                </TabsContent>
                                <TabsContent Value="analytics">
                                    <Card>
                                        <CardHeader>
                                            <CardTitle>Analytics</CardTitle>
                                            <CardDescription>Track performance and user engagement metrics. Monitor trends and identify growth opportunities.</CardDescription>
                                        </CardHeader>
                                        <CardContent Class="text-sm text-muted-foreground">
                                            Page views are up 25% compared to last month.
                                        </CardContent>
                                    </Card>
                                </TabsContent>
                                <TabsContent Value="reports">
                                    <Card>
                                        <CardHeader>
                                            <CardTitle>Reports</CardTitle>
                                            <CardDescription>Generate and download your detailed reports. Export data in multiple formats for analysis.</CardDescription>
                                        </CardHeader>
                                        <CardContent Class="text-sm text-muted-foreground">
                                            You have 5 reports ready and available to export.
                                        </CardContent>
                                    </Card>
                                </TabsContent>
                                <TabsContent Value="settings">
                                    <Card>
                                        <CardHeader>
                                            <CardTitle>Settings</CardTitle>
                                            <CardDescription>Manage your account preferences and options. Customize your experience to fit your needs.</CardDescription>
                                        </CardHeader>
                                        <CardContent Class="text-sm text-muted-foreground">
                                            Configure notifications, security, and themes.
                                        </CardContent>
                                    </Card>
                                </TabsContent>
                            </Tabs>
                        </div>
                    </Preview>
                    <Code>@codeDemo</Code>
                </ComponentExample>

                <DocsInstallationSection ComponentLabel="tabs"
                                         InstallCommand="blazor-shadcn add tabs"
                                         SourcePaths="@manualSourcePaths" />

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>

                <div class="mt-6" id="line">
                    <ComponentExample Title="Line" Compact="true" CodeText="@codeLine">
                        <Description>
                            <p class="text-muted-foreground text-sm">Use <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Variant="line"</code> on <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">TabsList</code> for the underline style.</p>
                        </Description>
                        <Preview>
                            <Tabs DefaultValue="overview">
                                <TabsList Variant="line">
                                    <TabsTrigger Value="overview">Overview</TabsTrigger>
                                    <TabsTrigger Value="analytics">Analytics</TabsTrigger>
                                    <TabsTrigger Value="reports">Reports</TabsTrigger>
                                </TabsList>
                            </Tabs>
                        </Preview>
                        <Code>@codeLine</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6" id="vertical">
                    <ComponentExample Title="Vertical" Compact="true" CodeText="@codeVertical">
                        <Description>
                            <p class="text-muted-foreground text-sm">Use <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Orientation="vertical"</code> for stacked tabs.</p>
                        </Description>
                        <Preview>
                            <Tabs DefaultValue="account" Orientation="vertical">
                                <TabsList>
                                    <TabsTrigger Value="account">Account</TabsTrigger>
                                    <TabsTrigger Value="password">Password</TabsTrigger>
                                    <TabsTrigger Value="notifications">Notifications</TabsTrigger>
                                </TabsList>
                            </Tabs>
                        </Preview>
                        <Code>@codeVertical</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6" id="disabled">
                    <ComponentExample Title="Disabled" Compact="true" CodeText="@codeDisabled">
                        <Preview>
                            <Tabs DefaultValue="home">
                                <TabsList>
                                    <TabsTrigger Value="home">Home</TabsTrigger>
                                    <TabsTrigger Value="settings" Disabled="true">Disabled</TabsTrigger>
                                </TabsList>
                            </Tabs>
                        </Preview>
                        <Code>@codeDisabled</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6" id="icons">
                    <ComponentExample Title="Icons" Compact="true" CodeText="@codeIcons">
                        <Preview>
                            <Tabs DefaultValue="preview">
                                <TabsList>
                                    <TabsTrigger Value="preview">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <rect x="3" y="4" width="18" height="14" rx="2" />
                                            <path d="M8 20h8" />
                                        </svg>
                                        Preview
                                    </TabsTrigger>
                                    <TabsTrigger Value="code">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path d="m8 9-3 3 3 3" />
                                            <path d="m16 9 3 3-3 3" />
                                        </svg>
                                        Code
                                    </TabsTrigger>
                                </TabsList>
                            </Tabs>
                        </Preview>
                        <Code>@codeIcons</Code>
                    </ComponentExample>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>
                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Tabs</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Value</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ValueChanged</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">EventCallback&lt;string?&gt;</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">DefaultValue</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Orientation</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">"horizontal" | "vertical"</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"horizontal"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Variant</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">"default" | "line"</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"default"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">TabsList</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Variant</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">"default" | "line"</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"default"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">TabsTrigger</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Value</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string</code></td><td class="px-4 py-2 text-left whitespace-nowrap">required</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Disabled</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">TabsContent</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Value</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string</code></td><td class="px-4 py-2 text-left whitespace-nowrap">required</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <DocsPageLinks />
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#line" class="text-muted-foreground hover:text-foreground pl-4 text-[0.8rem] no-underline transition-colors">Line</a>
                <a href="#vertical" class="text-muted-foreground hover:text-foreground pl-4 text-[0.8rem] no-underline transition-colors">Vertical</a>
                <a href="#disabled" class="text-muted-foreground hover:text-foreground pl-4 text-[0.8rem] no-underline transition-colors">Disabled</a>
                <a href="#icons" class="text-muted-foreground hover:text-foreground pl-4 text-[0.8rem] no-underline transition-colors">Icons</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

