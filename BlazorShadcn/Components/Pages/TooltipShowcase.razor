@page "/components/tooltip"
@inject IWebHostEnvironment Environment

<PageTitle>Tooltip - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Tooltip</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/toggle-group" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/typography" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">Tooltip examples and installation guidance for BlazorShadcn.</p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@codeDemo">
                    <Preview>
                        <div class="flex flex-col items-center py-6">
                            <Tooltip>
                                <TooltipTrigger>
                                    <Button Variant="ButtonVariant.Outline">Hover</Button>
                                </TooltipTrigger>
                                <TooltipContent>
                                    <p>Add to library</p>
                                </TooltipContent>
                            </Tooltip>
                        </div>
                    </Preview>
                    <Code>@codeDemo</Code>
                </ComponentExample>

                <DocsInstallationSection ComponentLabel="tooltip"
                                         InstallCommand="@installCommand"
                                         SourcePaths="@manualSourcePaths"
                                         DependencyCommands="@dependencyCommands" />

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>

                <div class="mt-6" id="side">
                    <ComponentExample Compact="true" Title="Side" CodeText="@codeSide">
                        <Preview>
                            <div class="flex flex-wrap justify-center gap-2 py-6">
                                <Tooltip>
                                    <TooltipTrigger>
                                        <Button Variant="ButtonVariant.Outline">Top</Button>
                                    </TooltipTrigger>
                                    <TooltipContent Side="top"><p>Add to library</p></TooltipContent>
                                </Tooltip>
                                <Tooltip>
                                    <TooltipTrigger>
                                        <Button Variant="ButtonVariant.Outline">Right</Button>
                                    </TooltipTrigger>
                                    <TooltipContent Side="right"><p>Add to library</p></TooltipContent>
                                </Tooltip>
                                <Tooltip>
                                    <TooltipTrigger>
                                        <Button Variant="ButtonVariant.Outline">Bottom</Button>
                                    </TooltipTrigger>
                                    <TooltipContent Side="bottom"><p>Add to library</p></TooltipContent>
                                </Tooltip>
                                <Tooltip>
                                    <TooltipTrigger>
                                        <Button Variant="ButtonVariant.Outline">Left</Button>
                                    </TooltipTrigger>
                                    <TooltipContent Side="left"><p>Add to library</p></TooltipContent>
                                </Tooltip>
                            </div>
                        </Preview>
                        <Code>@codeSide</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6" id="with-keyboard-shortcut">
                    <ComponentExample Compact="true" Title="With Keyboard Shortcut" CodeText="@codeKeyboardShortcut">
                        <Preview>
                            <div class="flex flex-col items-center py-6">
                                <Tooltip>
                                    <TooltipTrigger>
                                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Save changes">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><polyline points="17 21 17 13 7 13 7 21" /><polyline points="7 3 7 8 15 8" /></svg>
                                        </Button>
                                    </TooltipTrigger>
                                    <TooltipContent Class="pr-1.5">
                                        <div class="flex items-center gap-2">
                                            Save Changes <Kbd>S</Kbd>
                                        </div>
                                    </TooltipContent>
                                </Tooltip>
                            </div>
                        </Preview>
                        <Code>@codeKeyboardShortcut</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6" id="disabled-button">
                    <ComponentExample Compact="true" Title="Disabled Button" CodeText="@codeDisabledButton">
                        <Preview>
                            <div class="flex flex-col items-center py-6">
                                <Tooltip>
                                    <TooltipTrigger>
                                        <span class="inline-block w-fit">
                                            <Button Variant="ButtonVariant.Outline" Disabled="true">Disabled</Button>
                                        </span>
                                    </TooltipTrigger>
                                    <TooltipContent>
                                        <p>This feature is currently unavailable</p>
                                    </TooltipContent>
                                </Tooltip>
                            </div>
                        </Preview>
                        <Code>@codeDisabledButton</Code>
                    </ComponentExample>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">TooltipProvider</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">DelayDuration</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">int</code></td><td class="px-4 py-2 text-left whitespace-nowrap">0</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Tooltip</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Open</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">OpenChanged</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">EventCallback&lt;bool&gt;</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">TooltipContent</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Side</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">"top" | "right" | "bottom" | "left"</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"top"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ChildContent</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">RenderFragment?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <DocsPageLinks />
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#side" class="text-muted-foreground hover:text-foreground pl-4 text-[0.8rem] no-underline transition-colors">Side</a>
                <a href="#with-keyboard-shortcut" class="text-muted-foreground hover:text-foreground pl-4 text-[0.8rem] no-underline transition-colors">With Keyboard Shortcut</a>
                <a href="#disabled-button" class="text-muted-foreground hover:text-foreground pl-4 text-[0.8rem] no-underline transition-colors">Disabled Button</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

@code {
    private const string referenceUrl = "https://ui.shadcn.com/docs/components/tooltip";
    private const string installCommand = "blazor-shadcn add tooltip";
    private static readonly string[] dependencyCommands = ["npm install radix-ui"];
    private static readonly string[] manualSourcePaths =
    [
        "Components/UI/Tooltip.razor",
        "Components/UI/TooltipContent.razor",
        "Components/UI/TooltipContext.cs",
        "Components/UI/TooltipProvider.razor",
        "Components/UI/TooltipProviderContext.cs",
        "Components/UI/TooltipTrigger.razor"
    ];

    private const string usingStatement = """@using BlazorShadcn.Components.UI""";
    private const string usageCode = """
<TooltipProvider>
    <Tooltip>
        <TooltipTrigger>
            <Button Variant="@Button.ButtonVariant.Outline">Hover</Button>
        </TooltipTrigger>
        <TooltipContent>
            <p>Add to library</p>
        </TooltipContent>
    </Tooltip>
</TooltipProvider>
""";

    private const string codeDemo = """
<div class="flex flex-col items-center py-6">
    <Tooltip>
        <TooltipTrigger>
            <Button Variant="@Button.ButtonVariant.Outline">Hover</Button>
        </TooltipTrigger>
        <TooltipContent>
            <p>Add to library</p>
        </TooltipContent>
    </Tooltip>
</div>
""";

    private const string codeSide = """
<div class="flex flex-wrap justify-center gap-2 py-6">
    <Tooltip><TooltipTrigger><Button Variant="@Button.ButtonVariant.Outline">Top</Button></TooltipTrigger><TooltipContent Side="top"><p>Add to library</p></TooltipContent></Tooltip>
    <Tooltip><TooltipTrigger><Button Variant="@Button.ButtonVariant.Outline">Right</Button></TooltipTrigger><TooltipContent Side="right"><p>Add to library</p></TooltipContent></Tooltip>
    <Tooltip><TooltipTrigger><Button Variant="@Button.ButtonVariant.Outline">Bottom</Button></TooltipTrigger><TooltipContent Side="bottom"><p>Add to library</p></TooltipContent></Tooltip>
    <Tooltip><TooltipTrigger><Button Variant="@Button.ButtonVariant.Outline">Left</Button></TooltipTrigger><TooltipContent Side="left"><p>Add to library</p></TooltipContent></Tooltip>
</div>
""";

    private const string codeKeyboardShortcut = """
<div class="flex flex-col items-center py-6">
    <Tooltip>
        <TooltipTrigger>
            <Button Variant="@Button.ButtonVariant.Outline" Size="@Button.ButtonSize.IconSm" aria-label="Save changes">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><polyline points="17 21 17 13 7 13 7 21" /><polyline points="7 3 7 8 15 8" /></svg>
            </Button>
        </TooltipTrigger>
        <TooltipContent Class="pr-1.5">
            <div class="flex items-center gap-2">
                Save Changes <Kbd>S</Kbd>
            </div>
        </TooltipContent>
    </Tooltip>
</div>
""";

    private const string codeDisabledButton = """
<div class="flex flex-col items-center py-6">
    <Tooltip>
        <TooltipTrigger>
            <span class="inline-block w-fit">
                <Button Variant="@Button.ButtonVariant.Outline" Disabled="true">Disabled</Button>
            </span>
        </TooltipTrigger>
        <TooltipContent>
            <p>This feature is currently unavailable</p>
        </TooltipContent>
    </Tooltip>
</div>
""";
}
