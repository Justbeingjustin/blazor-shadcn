@page "/components/sidebar"

<PageTitle>Sidebar - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Sidebar</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/sheet" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/skeleton" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    A composable, themeable sidebar with collapsible, floating, inset, and right-side layouts.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@codeDemo">
                    <Preview>
                        <div class="h-[420px] w-full overflow-hidden rounded-xl border">
                            @RenderExample("sidebar", "icon", "left")
                        </div>
                    </Preview>
                    <Code>@codeDemo</Code>
                </ComponentExample>

                <DocsInstallationSection ComponentLabel="sidebar"
                                         InstallCommand="@installCommand"
                                         SourcePaths="@manualSourcePaths"
                                         ImportStep="@manualImportStep" />

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="structure">Structure</h2>
                <p class="text-muted-foreground mt-2 text-sm">
                    A sidebar is composed from <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SidebarProvider</code>, <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Sidebar</code>, <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SidebarHeader</code>, <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SidebarContent</code>, <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SidebarFooter</code>, groups, and menu primitives.
                </p>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>

                <div class="mt-6" id="basic">
                    <ComponentExample Title="Basic" Compact="true" CodeText="@codeBasic">
                        <Description>
                            <p class="text-muted-foreground text-sm">A collapsible sidebar that shrinks to icons.</p>
                        </Description>
                        <Preview>
                            <div class="h-[360px] w-full overflow-hidden rounded-xl border">
                                @RenderExample("sidebar", "icon", "left")
                            </div>
                        </Preview>
                        <Code>@codeBasic</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6" id="floating">
                    <ComponentExample Title="Floating" Compact="true" CodeText="@codeFloating">
                        <Description>
                            <p class="text-muted-foreground text-sm">Use <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Variant="floating"</code> for a detached card-like sidebar.</p>
                        </Description>
                        <Preview>
                            <div class="h-[360px] w-full overflow-hidden rounded-xl border">
                                @RenderExample("floating", "icon", "left")
                            </div>
                        </Preview>
                        <Code>@codeFloating</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6" id="inset">
                    <ComponentExample Title="Inset" Compact="true" CodeText="@codeInset">
                        <Description>
                            <p class="text-muted-foreground text-sm">Inset layouts wrap the content area with <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">SidebarInset</code>.</p>
                        </Description>
                        <Preview>
                            <div class="h-[360px] w-full overflow-hidden rounded-xl border">
                                @RenderExample("inset", "icon", "left")
                            </div>
                        </Preview>
                        <Code>@codeInset</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6" id="right-side">
                    <ComponentExample Title="Right Side" Compact="true" CodeText="@codeRight">
                        <Description>
                            <p class="text-muted-foreground text-sm">Set <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Side="right"</code> to anchor the sidebar to the opposite edge.</p>
                        </Description>
                        <Preview>
                            <div class="h-[360px] w-full overflow-hidden rounded-xl border">
                                @RenderExample("sidebar", "offcanvas", "right")
                            </div>
                        </Preview>
                        <Code>@codeRight</Code>
                    </ComponentExample>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>
                <p class="text-muted-foreground mt-2 text-sm">
                    This port follows the core shadcn composition model and supports the main layout primitives required for common application sidebars.
                </p>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">SidebarProvider</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">DefaultOpen</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">true</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Open</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">false</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">OpenChanged</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">EventCallback&lt;bool&gt;</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">SidebarWidth</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"16rem"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">SidebarWidthMobile</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"18rem"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">SidebarWidthIcon</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"3rem"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">ShortcutKey</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"b"</td></tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Sidebar</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Side</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">"left" | "right"</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"left"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Variant</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">"sidebar" | "floating" | "inset"</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"sidebar"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Collapsible</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">"offcanvas" | "icon" | "none"</code></td><td class="px-4 py-2 text-left whitespace-nowrap">"offcanvas"</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <DocsPageLinks />
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#structure" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Structure</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#basic" class="text-muted-foreground hover:text-foreground ml-4 text-[0.8rem] no-underline transition-colors">Basic</a>
                <a href="#floating" class="text-muted-foreground hover:text-foreground ml-4 text-[0.8rem] no-underline transition-colors">Floating</a>
                <a href="#inset" class="text-muted-foreground hover:text-foreground ml-4 text-[0.8rem] no-underline transition-colors">Inset</a>
                <a href="#right-side" class="text-muted-foreground hover:text-foreground ml-4 text-[0.8rem] no-underline transition-colors">Right Side</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

@code {
    private const string referenceUrl = "https://ui.shadcn.com/docs/components/sidebar";
    private const string installCommand = "blazor-shadcn add sidebar";
    private const string manualImportStep = """
Add @using ShadcnBlazor.Components.UI to Components/_Imports.razor
Copy components/sidebar/sidebar.js into your project and include it from Components/App.razor or your main layout.
""";
    private const string usingStatement = "@using BlazorShadcn.Components.UI";
    private static readonly string[] manualSourcePaths =
    [
        "components/sidebar/Sidebar.razor",
        "components/sidebar/SidebarProvider.razor",
        "components/sidebar/SidebarTrigger.razor",
        "components/sidebar/SidebarInset.razor",
        "components/sidebar/SidebarHeader.razor",
        "components/sidebar/SidebarFooter.razor",
        "components/sidebar/SidebarSeparator.razor",
        "components/sidebar/SidebarContent.razor",
        "components/sidebar/SidebarGroup.razor",
        "components/sidebar/SidebarGroupLabel.razor",
        "components/sidebar/SidebarGroupContent.razor",
        "components/sidebar/SidebarMenu.razor",
        "components/sidebar/SidebarMenuItem.razor",
        "components/sidebar/SidebarMenuButton.razor",
        "components/sidebar/SidebarMenuSub.razor",
        "components/sidebar/SidebarMenuSubItem.razor",
        "components/sidebar/SidebarMenuSubButton.razor",
        "components/sidebar/SidebarRail.razor",
        "components/sidebar/SidebarContext.cs",
        "components/sidebar/sidebar.js"
    ];

    private const string usageCode = """
<SidebarProvider>
    <Sidebar>
        <SidebarHeader />
        <SidebarContent>
            <SidebarGroup>
                <SidebarGroupLabel>Application</SidebarGroupLabel>
                <SidebarGroupContent>
                    <SidebarMenu>
                        <SidebarMenuItem>
                            <SidebarMenuButton Href="#" IsActive="true">
                                <span>Dashboard</span>
                            </SidebarMenuButton>
                        </SidebarMenuItem>
                    </SidebarMenu>
                </SidebarGroupContent>
            </SidebarGroup>
        </SidebarContent>
        <SidebarFooter />
    </Sidebar>
    <SidebarInset>
        <header class="flex h-12 items-center gap-2 border-b px-4">
            <SidebarTrigger />
        </header>
        <main class="p-4">
            @Body
        </main>
    </SidebarInset>
</SidebarProvider>
""";

    private const string codeBasic = """
<SidebarProvider>
    <Sidebar Collapsible="icon">
        <SidebarContent>
            <SidebarGroup>
                <SidebarGroupLabel>Application</SidebarGroupLabel>
                <SidebarGroupContent>
                    <SidebarMenu>
                        <SidebarMenuItem>
                            <SidebarMenuButton Href="#" IsActive="true">
                                <span>Home</span>
                            </SidebarMenuButton>
                        </SidebarMenuItem>
                    </SidebarMenu>
                </SidebarGroupContent>
            </SidebarGroup>
        </SidebarContent>
    </Sidebar>
    <SidebarInset>
        <SidebarTrigger />
    </SidebarInset>
</SidebarProvider>
""";

    private const string codeFloating = """
<SidebarProvider>
    <Sidebar Variant="floating" Collapsible="icon">
        ...
    </Sidebar>
    <SidebarInset>
        ...
    </SidebarInset>
</SidebarProvider>
""";

    private const string codeInset = """
<SidebarProvider>
    <Sidebar Variant="inset" Collapsible="icon">
        ...
    </Sidebar>
    <SidebarInset>
        ...
    </SidebarInset>
</SidebarProvider>
""";

    private const string codeRight = """
<SidebarProvider>
    <Sidebar Side="right">
        ...
    </Sidebar>
    <SidebarInset>
        ...
    </SidebarInset>
</SidebarProvider>
""";

    private const string codeDemo = """
<SidebarProvider>
    <Sidebar>
        <SidebarHeader>...</SidebarHeader>
        <SidebarContent>
            <SidebarGroup>
                <SidebarGroupLabel>Application</SidebarGroupLabel>
                <SidebarGroupContent>
                    <SidebarMenu>
                        <SidebarMenuItem>
                            <SidebarMenuButton Href="#" IsActive="true">
                                <span>Home</span>
                            </SidebarMenuButton>
                        </SidebarMenuItem>
                    </SidebarMenu>
                </SidebarGroupContent>
            </SidebarGroup>
        </SidebarContent>
        <SidebarFooter>...</SidebarFooter>
    </Sidebar>
    <SidebarInset>
        <header class="flex h-12 items-center gap-2 border px-3">
            <SidebarTrigger />
        </header>
    </SidebarInset>
</SidebarProvider>
""";

    private RenderFragment RenderExample(string variant, string collapsible, string side) => @<SidebarProvider>
        @if (side == "right")
        {
            <SidebarInset>
                <header class="flex h-16 shrink-0 items-center gap-2 px-4 transition-[width,height] ease-linear group-has-data-[collapsible=icon]/sidebar-wrapper:h-12">
                    <BlazorShadcn.Components.UI.SidebarTrigger Class="-ml-1" />
                </header>
                <div class="flex flex-1"></div>
            </SidebarInset>
        }
        <Sidebar Side="@side" Variant="@variant" Collapsible="@collapsible">
            <SidebarHeader>
                <SidebarMenu>
                    <SidebarMenuItem>
                        <SidebarMenuButton Size="lg" Class="gap-3">
                            <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
