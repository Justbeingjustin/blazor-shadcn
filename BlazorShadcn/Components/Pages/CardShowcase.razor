@page "/components/card"
@inject IWebHostEnvironment Environment

<PageTitle>Card - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    @* ── Content column ── *@
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            @* Page header *@
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <div class="flex items-center gap-2">
                        <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Card</h1>
                    </div>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="ButtonVariant.Secondary"
                                Size="ButtonSize.Icon"
                                Href="/components/button"
                                Class="extend-touch-target size-8 shadow-none md:size-7"
                                aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12l14 0" />
                                <path d="M5 12l6 6" />
                                <path d="M5 12l6 -6" />
                            </svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary"
                                Size="ButtonSize.Icon"
                                Href="/"
                                Class="extend-touch-target size-8 shadow-none md:size-7"
                                aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12l14 0" />
                                <path d="M13 18l6 -6" />
                                <path d="M13 6l6 6" />
                            </svg>
                        </Button>
                    </div>
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    Displays a card with header, content, and footer.
                </p>
            </div>

            @* Page content *@
            <div class="w-full flex-1">
                @* Main preview *@
                <ComponentExample Compact="true" CodeText="@codeMainDemo">
                    <Preview>
                        <Card Class="w-full max-w-sm">
                            <CardHeader>
                                <CardTitle>Login to your account</CardTitle>
                                <CardDescription>Enter your email below to login to your account.</CardDescription>
                                <CardAction>
                                    <Button Variant="ButtonVariant.Link">Sign Up</Button>
                                </CardAction>
                            </CardHeader>
                            <CardContent>
                                <form>
                                    <div class="flex flex-col gap-6">
                                        <div class="grid gap-2">
                                            <Label For="email">Email</Label>
                                            <Input Type="email" id="email" Placeholder="m@example.com" required />
                                        </div>
                                        <div class="grid gap-2">
                                            <div class="flex items-center">
                                                <Label For="password">Password</Label>
                                                <a href="#" class="ml-auto inline-block text-sm underline-offset-4 hover:underline">Forgot your password?</a>
                                            </div>
                                            <Input Type="password" id="password" required />
                                        </div>
                                    </div>
                                </form>
                            </CardContent>
                            <CardFooter Class="flex-col gap-2">
                                <Button Type="submit" Class="w-full">Login</Button>
                                <Button Variant="ButtonVariant.Outline" Class="w-full">Login with Google</Button>
                            </CardFooter>
                        </Card>
                    </Preview>
                    <Code>@codeMainDemo</Code>
                </ComponentExample>

                @* Installation *@
                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight first:mt-0 lg:mt-12" id="installation">Installation</h2>
                <p class="leading-relaxed mt-6">Install the card component using the command or manual steps.</p>
                <div class="mt-4">
                    <div class="inline-flex w-fit items-center justify-start gap-4 rounded-none bg-transparent px-0">
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Command"
                                data-state="@(_installationTab == InstallationTab.Command ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Command
                        </button>
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Manual"
                                data-state="@(_installationTab == InstallationTab.Manual ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Manual
                        </button>
                    </div>
                </div>

                @if (_installationTab == InstallationTab.Command)
                {
                    <div class="mt-4">
                        <CodeBlock RawText="@installCommand">@installCommand</CodeBlock>
                    </div>
                }
                else
                {
                    <div class="mt-6 space-y-6">
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">1</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Copy and paste the following files into your project.</p>

                                <p class="text-muted-foreground mt-2 text-sm">@canonicalCardSourcePath</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_cardManualSource">@_cardManualSource</CodeBlock>
                                </div>

                                <p class="text-muted-foreground mt-4 text-sm">@canonicalCardHeaderSourcePath</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_cardHeaderManualSource">@_cardHeaderManualSource</CodeBlock>
                                </div>

                                <p class="text-muted-foreground mt-4 text-sm">@canonicalCardTitleSourcePath</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_cardTitleManualSource">@_cardTitleManualSource</CodeBlock>
                                </div>

                                <p class="text-muted-foreground mt-4 text-sm">@canonicalCardDescriptionSourcePath</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_cardDescriptionManualSource">@_cardDescriptionManualSource</CodeBlock>
                                </div>

                                <p class="text-muted-foreground mt-4 text-sm">@canonicalCardContentSourcePath</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_cardContentManualSource">@_cardContentManualSource</CodeBlock>
                                </div>

                                <p class="text-muted-foreground mt-4 text-sm">@canonicalCardFooterSourcePath</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_cardFooterManualSource">@_cardFooterManualSource</CodeBlock>
                                </div>

                                <p class="text-muted-foreground mt-4 text-sm">@canonicalCardActionSourcePath</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_cardActionManualSource">@_cardActionManualSource</CodeBlock>
                                </div>
                            </div>
                        </div>

                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">2</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Update the import paths to match your project setup.</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@manualImportStep">@manualImportStep</CodeBlock>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @* Usage *@
                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                @* Examples *@
                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>

                <div class="mt-6">
                    <ComponentExample Title="Size" Compact="true">
                        <Preview>
                            <Card Size="sm" Class="mx-auto w-full max-w-sm">
                                <CardHeader>
                                    <CardTitle>Small Card</CardTitle>
                                    <CardDescription>
                                        This card uses the small size variant.
                                    </CardDescription>
                                </CardHeader>
                                <CardContent>
                                    <p>
                                        The card component supports a size prop that can be set to "sm" for a more compact appearance.
                                    </p>
                                </CardContent>
                                <CardFooter>
                                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" Class="w-full">Action</Button>
                                </CardFooter>
                            </Card>
                        </Preview>
                        <Code>@codeSize</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="Image" Compact="true">
                        <Preview>
                            <Card Class="relative mx-auto w-full max-w-sm pt-0">
                                <div class="absolute inset-0 z-30 aspect-video bg-black/35"></div>
                                <img src="https://avatar.vercel.sh/shadcn1"
                                     alt="Event cover"
                                     class="relative z-20 aspect-video w-full object-cover brightness-60 grayscale dark:brightness-40" />
                                <CardHeader>
                                    <CardAction>
                                        <Badge Variant="BadgeVariant.Secondary">Featured</Badge>
                                    </CardAction>
                                    <CardTitle>Design systems meetup</CardTitle>
                                    <CardDescription>
                                        A practical talk on component APIs, accessibility, and shipping faster.
                                    </CardDescription>
                                </CardHeader>
                                <CardFooter>
                                    <Button Class="w-full">View Event</Button>
                                </CardFooter>
                            </Card>
                        </Preview>
                        <Code>@codeImage</Code>
                    </ComponentExample>
                </div>

                @* API Reference *@
                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Component</th>
                                <th class="px-4 py-2 text-left font-bold">Description</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Card</td><td class="px-4 py-2 text-left text-muted-foreground">The main card container.</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">CardHeader</td><td class="px-4 py-2 text-left text-muted-foreground">Contains the title and description.</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">CardTitle</td><td class="px-4 py-2 text-left text-muted-foreground">The card heading.</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">CardDescription</td><td class="px-4 py-2 text-left text-muted-foreground">A muted description below the title.</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">CardContent</td><td class="px-4 py-2 text-left text-muted-foreground">The main content area.</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">CardFooter</td><td class="px-4 py-2 text-left text-muted-foreground">The footer area, typically for actions.</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">CardAction</td><td class="px-4 py-2 text-left text-muted-foreground">An action area positioned in the card header.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @* ── TOC sidebar ── *@
    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#size" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Size</a>
                <a href="#image" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Image</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

@code {
    private const string canonicalCardSourcePath = "components/cards/Card.razor";
    private const string canonicalCardHeaderSourcePath = "components/cards/CardHeader.razor";
    private const string canonicalCardTitleSourcePath = "components/cards/CardTitle.razor";
    private const string canonicalCardDescriptionSourcePath = "components/cards/CardDescription.razor";
    private const string canonicalCardContentSourcePath = "components/cards/CardContent.razor";
    private const string canonicalCardFooterSourcePath = "components/cards/CardFooter.razor";
    private const string canonicalCardActionSourcePath = "components/cards/CardAction.razor";

    private string _cardManualSource = string.Empty;
    private string _cardHeaderManualSource = string.Empty;
    private string _cardTitleManualSource = string.Empty;
    private string _cardDescriptionManualSource = string.Empty;
    private string _cardContentManualSource = string.Empty;
    private string _cardFooterManualSource = string.Empty;
    private string _cardActionManualSource = string.Empty;

    protected override void OnInitialized()
    {
        _cardManualSource = LoadCanonicalSource(canonicalCardSourcePath, _sourceCardRazor);
        _cardHeaderManualSource = LoadCanonicalSource(canonicalCardHeaderSourcePath, _sourceCardHeaderRazor);
        _cardTitleManualSource = LoadCanonicalSource(canonicalCardTitleSourcePath, _sourceCardTitleRazor);
        _cardDescriptionManualSource = LoadCanonicalSource(canonicalCardDescriptionSourcePath, _sourceCardDescriptionRazor);
        _cardContentManualSource = LoadCanonicalSource(canonicalCardContentSourcePath, _sourceCardContentRazor);
        _cardFooterManualSource = LoadCanonicalSource(canonicalCardFooterSourcePath, _sourceCardFooterRazor);
        _cardActionManualSource = LoadCanonicalSource(canonicalCardActionSourcePath, _sourceCardActionRazor);
    }

    private InstallationTab _installationTab = InstallationTab.Command;

    private enum InstallationTab
    {
        Command,
        Manual
    }

    private const string installCommand = "blazor-shadcn add card";
    private const string manualImportStep = "Add @using BlazorShadcn.Components.UI to Components/_Imports.razor";
    private const string referenceUrl = "https://ui.shadcn.com/docs/components/radix/card";

    private static readonly string _sourceCardRazor = """
<div data-slot="card"
     data-size="@Size"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public string Size { get; set; } = "default";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
        => string.IsNullOrWhiteSpace(Class)
            ? "ring-foreground/10 bg-card text-card-foreground group/card flex flex-col gap-4 overflow-hidden rounded-xl py-4 text-sm ring-1 has-data-[slot=card-footer]:pb-0 has-[>img:first-child]:pt-0 data-[size=sm]:gap-3 data-[size=sm]:py-3 data-[size=sm]:has-data-[slot=card-footer]:pb-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl"
            : $"ring-foreground/10 bg-card text-card-foreground group/card flex flex-col gap-4 overflow-hidden rounded-xl py-4 text-sm ring-1 has-data-[slot=card-footer]:pb-0 has-[>img:first-child]:pt-0 data-[size=sm]:gap-3 data-[size=sm]:py-3 data-[size=sm]:has-data-[slot=card-footer]:pb-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl {Class}";
}
""";

    private static readonly string _sourceCardHeaderRazor = """
<div data-slot="card-header"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
        => string.IsNullOrWhiteSpace(Class)
            ? "group/card-header @container/card-header grid auto-rows-min items-start gap-1 rounded-t-xl px-4 group-data-[size=sm]/card:px-3 has-data-[slot=card-action]:grid-cols-[1fr_auto] has-data-[slot=card-description]:grid-rows-[auto_auto] [.border-b]:pb-4 group-data-[size=sm]/card:[.border-b]:pb-3"
            : $"group/card-header @container/card-header grid auto-rows-min items-start gap-1 rounded-t-xl px-4 group-data-[size=sm]/card:px-3 has-data-[slot=card-action]:grid-cols-[1fr_auto] has-data-[slot=card-description]:grid-rows-[auto_auto] [.border-b]:pb-4 group-data-[size=sm]/card:[.border-b]:pb-3 {Class}";
}
""";

    private static readonly string _sourceCardTitleRazor = """
<div data-slot="card-title"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
        => string.IsNullOrWhiteSpace(Class)
            ? "text-base leading-snug font-medium group-data-[size=sm]/card:text-sm"
            : $"text-base leading-snug font-medium group-data-[size=sm]/card:text-sm {Class}";
}
""";

    private static readonly string _sourceCardDescriptionRazor = """
<div data-slot="card-description"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
        => string.IsNullOrWhiteSpace(Class)
            ? "text-muted-foreground text-sm"
            : $"text-muted-foreground text-sm {Class}";
}
""";

    private static readonly string _sourceCardContentRazor = """
<div data-slot="card-content"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
        => string.IsNullOrWhiteSpace(Class)
            ? "px-4 group-data-[size=sm]/card:px-3"
            : $"px-4 group-data-[size=sm]/card:px-3 {Class}";
}
""";

    private static readonly string _sourceCardFooterRazor = """
<div data-slot="card-footer"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
        => string.IsNullOrWhiteSpace(Class)
            ? "bg-muted/50 flex items-center rounded-b-xl border-t p-4 group-data-[size=sm]/card:p-3"
            : $"bg-muted/50 flex items-center rounded-b-xl border-t p-4 group-data-[size=sm]/card:p-3 {Class}";
}
""";

    private static readonly string _sourceCardActionRazor = """
<div data-slot="card-action"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
        => string.IsNullOrWhiteSpace(Class)
            ? "col-start-2 row-span-2 row-start-1 self-start justify-self-end"
            : $"col-start-2 row-span-2 row-start-1 self-start justify-self-end {Class}";
}
""";

    private const string codeMainDemo = @"<Card Class=""w-full max-w-sm"">
    <CardHeader>
        <CardTitle>Login to your account</CardTitle>
        <CardDescription>Enter your email below to login to your account.</CardDescription>
        <CardAction>
            <Button Variant=""@Button.ButtonVariant.Link"">Sign Up</Button>
        </CardAction>
    </CardHeader>
    <CardContent>
        <form>
            <div class=""flex flex-col gap-6"">
                <div class=""grid gap-2"">
                    <Label For=""email"">Email</Label>
                    <Input Type=""email"" id=""email"" Placeholder=""m@example.com"" required />
                </div>
                <div class=""grid gap-2"">
                    <div class=""flex items-center"">
                        <Label For=""password"">Password</Label>
                        <a href=""#"" class=""ml-auto inline-block text-sm underline-offset-4 hover:underline"">Forgot your password?</a>
                    </div>
                    <Input Type=""password"" id=""password"" required />
                </div>
            </div>
        </form>
    </CardContent>
    <CardFooter Class=""flex-col gap-2"">
        <Button Type=""submit"" Class=""w-full"">Login</Button>
        <Button Variant=""@Button.ButtonVariant.Outline"" Class=""w-full"">Login with Google</Button>
    </CardFooter>
</Card>";

    private const string usingStatement = @"@using BlazorShadcn.Components.UI";
    private const string usageCode = @"<Card>
    <CardHeader>
        <CardTitle>Card Title</CardTitle>
        <CardDescription>Card Description</CardDescription>
    </CardHeader>
    <CardContent>Content</CardContent>
    <CardFooter>Footer</CardFooter>
</Card>";

    private const string codeSize = @"<Card Size=""sm"" Class=""mx-auto w-full max-w-sm"">
    <CardHeader>
        <CardTitle>Small Card</CardTitle>
        <CardDescription>
            This card uses the small size variant.
        </CardDescription>
    </CardHeader>
    <CardContent>
        <p>
            The card component supports a size prop that can be set to ""sm"" for a more compact appearance.
        </p>
    </CardContent>
    <CardFooter>
        <Button Variant=""@Button.ButtonVariant.Outline"" Size=""@Button.ButtonSize.Sm"" Class=""w-full"">Action</Button>
    </CardFooter>
</Card>";

    private const string codeImage = @"<Card Class=""relative mx-auto w-full max-w-sm pt-0"">
    <div class=""absolute inset-0 z-30 aspect-video bg-black/35""></div>
    <img src=""https://avatar.vercel.sh/shadcn1""
         alt=""Event cover""
         class=""relative z-20 aspect-video w-full object-cover brightness-60 grayscale dark:brightness-40"" />
    <CardHeader>
        <CardAction>
