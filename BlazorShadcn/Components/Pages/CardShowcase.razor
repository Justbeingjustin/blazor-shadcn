</Card>";

    private string LoadCanonicalSource(string relativePath, string fallback)
    {
        var canonicalPath = Path.Combine(Environment.ContentRootPath, relativePath.Replace('/', Path.DirectorySeparatorChar));
        return File.Exists(canonicalPath) ? File.ReadAllText(canonicalPath) : fallback;
    }
