@page "/docs/components"

<PageTitle>Components - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Components</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                    </div>
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[90%]">
                    Browse the current BlazorShadcn component catalog, including the parity work from the component briefs in the reference folder.
                </p>
            </div>

            <div class="grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-x-8 lg:gap-x-16 lg:gap-y-6 xl:gap-x-20">
                @foreach (var component in _implementedComponents)
                {
                    <a href="@component.Href"
                       class="inline-flex items-center gap-2 text-lg font-medium underline-offset-4 hover:underline md:text-base">
                        @component.Name
                    </a>
                }
            </div>

           
        </div>
    </div>
</div>

