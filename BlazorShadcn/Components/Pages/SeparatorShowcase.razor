@page "/components/separator"

<PageTitle>Separator - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <div class="flex items-center gap-2">
                        <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Separator</h1>
                    </div>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="ButtonVariant.Secondary"
                                Size="ButtonSize.Icon"
                                Href="/components/select"
                                Class="extend-touch-target size-8 shadow-none md:size-7"
                                aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12l14 0" />
                                <path d="M5 12l6 6" />
                                <path d="M5 12l6 -6" />
                            </svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary"
                                Size="ButtonSize.Icon"
                                Href="/components/sheet"
                                Class="extend-touch-target size-8 shadow-none md:size-7"
                                aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12l14 0" />
                                <path d="M13 18l6 -6" />
                                <path d="M13 6l6 6" />
                            </svg>
                        </Button>
                    </div>
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    Visually or semantically separates content.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample CodeText="@codeMainDemo">
                    <Preview>
                        <div>
                            <div class="space-y-1">
                                <h4 class="text-sm leading-none font-medium">Radix Primitives</h4>
                                <p class="text-muted-foreground text-sm">
                                    An open-source UI component library.
                                </p>
                            </div>
                            <Separator Class="my-4" />
                            <div class="flex h-5 items-center space-x-4 text-sm">
                                <div>Blog</div>
                                <Separator Orientation="SeparatorOrientation.Vertical" />
                                <div>Docs</div>
                                <Separator Orientation="SeparatorOrientation.Vertical" />
                                <div>Source</div>
                            </div>
                        </div>
                    </Preview>
                    <Code>@codeMainDemo</Code>
                </ComponentExample>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight first:mt-0 lg:mt-12" id="installation">Installation</h2>
                <p class="leading-relaxed mt-6">Install the separator component using the command or manual steps.</p>
                <div class="mt-4">
                    <div class="inline-flex w-fit items-center justify-start gap-4 rounded-none bg-transparent px-0">
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Command"
                                data-state="@(_installationTab == InstallationTab.Command ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Command
                        </button>
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Manual"
                                data-state="@(_installationTab == InstallationTab.Manual ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Manual
                        </button>
                    </div>
                </div>

                @if (_installationTab == InstallationTab.Command)
                {
                    <div class="mt-4">
                        <CodeBlock RawText="@installCommand">@installCommand</CodeBlock>
                    </div>
                }
                else
                {
                    <div class="mt-6 space-y-6">
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">1</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Copy and paste the following code into your project.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/UI/Separator.razor</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@_sourceSeparatorRazor">@_sourceSeparatorRazor</CodeBlock>
                                </div>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">2</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Update the import paths to match your project setup.</p>
                                <div class="mt-3">
                                    <CodeBlock RawText="@manualImportStep">@manualImportStep</CodeBlock>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>

                <div class="mt-6">
                    <ComponentExample Title="Vertical" Compact="true" CodeText="@codeVertical">
                        <Description>
                            <p class="text-muted-foreground text-sm">Use <code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem]">Orientation="SeparatorOrientation.Vertical"</code> for vertical separators.</p>
                        </Description>
                        <Preview>
                            <div class="flex h-5 items-center space-x-4 text-sm">
                                <span>Blog</span>
                                <Separator Orientation="SeparatorOrientation.Vertical" />
                                <span>Docs</span>
                                <Separator Orientation="SeparatorOrientation.Vertical" />
                                <span>Source</span>
                            </div>
                        </Preview>
                        <Code>@codeVertical</Code>
                    </ComponentExample>
                </div>

                <div class="mt-6">
                    <ComponentExample Title="List" Compact="true" CodeText="@codeList">
                        <Preview>
                            <div class="w-full max-w-sm rounded-lg border">
                                <div class="p-4">
                                    <p class="text-sm font-medium leading-none">Settings</p>
                                    <p class="text-muted-foreground mt-1 text-sm">Manage your account preferences.</p>
                                </div>
                                <Separator />
                                <div class="p-4 text-sm">Profile</div>
                                <Separator />
                                <div class="p-4 text-sm">Billing</div>
                                <Separator />
                                <div class="p-4 text-sm">Notifications</div>
                            </div>
                        </Preview>
                        <Code>@codeList</Code>
                    </ComponentExample>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>
                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">Separator</h3>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead>
                            <tr class="m-0 border-b">
                                <th class="px-4 py-2 text-left font-bold">Prop</th>
                                <th class="px-4 py-2 text-left font-bold">Type</th>
                                <th class="px-4 py-2 text-left font-bold">Default</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Orientation</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">Horizontal | Vertical</code></td><td class="px-4 py-2 text-left whitespace-nowrap">Horizontal</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Decorative</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">bool</code></td><td class="px-4 py-2 text-left whitespace-nowrap">true</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap">Class</td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string?</code></td><td class="px-4 py-2 text-left whitespace-nowrap">null</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#vertical" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Vertical</a>
                <a href="#list" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">List</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

@code {
    private InstallationTab _installationTab = InstallationTab.Command;

    private enum InstallationTab
    {
        Command,
        Manual
    }

    private const string installCommand = "blazor-shadcn add separator";
    private const string referenceUrl = "https://ui.shadcn.com/docs/components/radix/separator";
    private const string manualImportStep = "Add @using MyApp.Components.UI to Components/_Imports.razor";

    private static readonly string _sourceSeparatorRazor = """
<div
    data-slot="separator"
    data-orientation="@OrientationValue"
    class="@GetClasses()"
    @attributes="GetAttributes()">
</div>

@code {
    [Parameter] public SeparatorOrientation Orientation { get; set; } = SeparatorOrientation.Horizontal;
    [Parameter] public bool Decorative { get; set; } = true;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const string BaseClasses =
        "bg-border shrink-0 data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full " +
        "data-[orientation=vertical]:h-full data-[orientation=vertical]:w-px";

    private string OrientationValue => Orientation.ToString().ToLowerInvariant();

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static c => !string.IsNullOrWhiteSpace(c)));

    private string GetClasses() => Cn(BaseClasses, Class);

    private IReadOnlyDictionary<string, object> GetAttributes()
    {
        var attributes = AdditionalAttributes is null
            ? new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase)
            : new Dictionary<string, object>(AdditionalAttributes, StringComparer.OrdinalIgnoreCase);

        if (Decorative)
        {
            attributes["aria-hidden"] = "true";
        }
        else
        {
            if (!attributes.ContainsKey("role"))
            {
                attributes["role"] = "separator";
            }

            if (Orientation == SeparatorOrientation.Vertical && !attributes.ContainsKey("aria-orientation"))
            {
                attributes["aria-orientation"] = "vertical";
            }
        }

        return attributes;
    }

    public enum SeparatorOrientation
    {
        Horizontal,
        Vertical
    }
}
""";

    private const string usingStatement = "@using BlazorShadcn.Components.UI";
    private const string usageCode = "<Separator />";

    private const string codeMainDemo = @"<div>
    <div class=""space-y-1"">
        <h4 class=""text-sm leading-none font-medium"">Radix Primitives</h4>
        <p class=""text-muted-foreground text-sm"">An open-source UI component library.</p>
    </div>
    <Separator Class=""my-4"" />
    <div class=""flex h-5 items-center space-x-4 text-sm"">
        <div>Blog</div>
        <Separator Orientation=""SeparatorOrientation.Vertical"" />
        <div>Docs</div>
        <Separator Orientation=""SeparatorOrientation.Vertical"" />
        <div>Source</div>
    </div>
</div>";

    private const string codeVertical = @"<div class=""flex h-5 items-center space-x-4 text-sm"">
    <span>Blog</span>
    <Separator Orientation=""SeparatorOrientation.Vertical"" />
    <span>Docs</span>
    <Separator Orientation=""SeparatorOrientation.Vertical"" />
    <span>Source</span>
</div>";

    private const string codeList = @"<div class=""w-full max-w-sm rounded-lg border"">
    <div class=""p-4"">
        <p class=""text-sm font-medium leading-none"">Settings</p>
        <p class=""text-muted-foreground mt-1 text-sm"">Manage your account preferences.</p>
    </div>
    <Separator />
    <div class=""p-4 text-sm"">Profile</div>
    <Separator />
    <div class=""p-4 text-sm"">Billing</div>
    <Separator />
    <div class=""p-4 text-sm"">Notifications</div>
</div>";
}

