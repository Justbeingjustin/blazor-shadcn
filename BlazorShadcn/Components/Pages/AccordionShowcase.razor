@code {
    private const string canonicalAccordionDirectory = "components/accordion";
    private string _accordionManualSource = string.Empty;
    private string _accordionItemManualSource = string.Empty;
    private string _accordionTriggerManualSource = string.Empty;
    private string _accordionContentManualSource = string.Empty;
    private string _accordionContextManualSource = string.Empty;

    protected override void OnInitialized()
    {
        _accordionManualSource = ReadCanonicalSource("Accordion.razor", _sourceAccordionRazor);
        _accordionItemManualSource = ReadCanonicalSource("AccordionItem.razor", _sourceAccordionItemRazor);
        _accordionTriggerManualSource = ReadCanonicalSource("AccordionTrigger.razor", _sourceAccordionTriggerRazor);
        _accordionContentManualSource = ReadCanonicalSource("AccordionContent.razor", _sourceAccordionContentRazor);
        _accordionContextManualSource = ReadCanonicalSource("AccordionContext.cs", _sourceAccordionContextCs);
    }

    private InstallationTab _installationTab = InstallationTab.Command;
    private static readonly string[] _multipleDefaults = ["notifications"];

    private enum InstallationTab
    {
        Command,
        Manual
    }

    private const string installCommand = "blazor-shadcn add accordion";
    private const string referenceUrl = "https://ui.shadcn.com/docs/components/radix/accordion";
    private static readonly string _sourceAccordionRazor = """
@namespace ShadcnBlazor.Components.UI

<div data-slot="accordion"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">
    <CascadingValue Value="_context" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    private readonly AccordionContext _context = new();
    private bool _defaultsInitialized;

    [Parameter] public AccordionType Type { get; set; } = AccordionType.Single;
    [Parameter] public bool Collapsible { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public IEnumerable<string>? DefaultValues { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const string BaseClasses = "flex w-full flex-col";

    protected override void OnParametersSet()
    {
        _context.Configure(Type, Collapsible, () => InvokeAsync(StateHasChanged));

        if (!_defaultsInitialized)
        {
            _context.InitializeDefaults(DefaultValue, DefaultValues);
            _defaultsInitialized = true;
        }
    }

    public enum AccordionType
    {
        Single,
        Multiple
    }

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static c => !string.IsNullOrWhiteSpace(c)));

    private string GetClasses() => Cn(BaseClasses, Class);
}
""";

    private static readonly string _sourceAccordionItemRazor = """
@namespace ShadcnBlazor.Components.UI

<div data-slot="accordion-item"
     data-state="@StateValue"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">
    <CascadingValue Value="_itemContext" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    [CascadingParameter] private AccordionContext? AccordionContext { get; set; }

    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private AccordionItemContext _itemContext = default!;
    private string _triggerId = string.Empty;
    private string _contentId = string.Empty;

    private const string BaseClasses = "border-border not-last:border-b";

    private string StateValue => IsOpen ? "open" : "closed";
    private bool IsOpen => AccordionContext?.IsOpen(Value) == true;

    protected override void OnInitialized()
    {
        var key = Guid.NewGuid().ToString("N", System.Globalization.CultureInfo.InvariantCulture);
        _triggerId = $"accordion-trigger-{key}";
        _contentId = $"accordion-content-{key}";
    }

    protected override void OnParametersSet()
    {
        if (AccordionContext is null)
        {
            throw new InvalidOperationException($"{nameof(AccordionItem)} must be used inside {nameof(Accordion)}.");
        }

        _itemContext = new AccordionItemContext
        {
            Root = AccordionContext,
            Value = Value,
            Disabled = Disabled,
            TriggerId = _triggerId,
            ContentId = _contentId
        };
    }

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static c => !string.IsNullOrWhiteSpace(c)));

    private string GetClasses() => Cn(BaseClasses, Class);
}
""";

    private static readonly string _sourceAccordionTriggerRazor = """
@namespace ShadcnBlazor.Components.UI

<div class="flex">
    <button data-slot="accordion-trigger"
            type="button"
            id="@ItemContext!.TriggerId"
            data-state="@StateValue"
            aria-expanded="@IsOpen.ToString().ToLowerInvariant()"
            aria-controls="@ItemContext!.ContentId"
            disabled="@ItemContext!.Disabled"
            class="@GetClasses()"
            @onclick="OnClick"
            @attributes="AdditionalAttributes">
        @ChildContent
        <svg xmlns="http://www.w3.org/2000/svg"
             width="16"
             height="16"
             viewBox="0 0 24 24"
             fill="none"
             stroke="currentColor"
             stroke-width="2"
             stroke-linecap="round"
             stroke-linejoin="round"
             class="@GetIconClasses()">
            <path d="m6 9 6 6 6-6" />
        </svg>
    </button>
</div>

@code {
    [CascadingParameter] private AccordionItemContext? ItemContext { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const string BaseClasses =
        "focus-visible:ring-ring/50 focus-visible:border-ring relative flex flex-1 items-start justify-between rounded-lg border border-transparent py-2.5 text-left text-sm font-medium transition-all outline-none hover:underline focus-visible:ring-3 disabled:pointer-events-none disabled:opacity-50";

    private bool IsOpen => ItemContext is not null && ItemContext.Root.IsOpen(ItemContext.Value);
    private string StateValue => IsOpen ? "open" : "closed";

    protected override void OnParametersSet()
    {
        if (ItemContext is null)
        {
            throw new InvalidOperationException($"{nameof(AccordionTrigger)} must be used inside {nameof(AccordionItem)}.");
        }
    }

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static c => !string.IsNullOrWhiteSpace(c)));

    private string GetClasses() => Cn(BaseClasses, Class);
    private string GetIconClasses()
        => Cn(
            "text-muted-foreground pointer-events-none ml-auto size-4 shrink-0 transition-transform duration-200",
            IsOpen ? "rotate-180" : null);

    private Task OnClick() => ItemContext!.Root.ToggleAsync(ItemContext.Value, ItemContext.Disabled);
}
""";

    private static readonly string _sourceAccordionContentRazor = """
@namespace ShadcnBlazor.Components.UI

<div data-slot="accordion-content"
     id="@ItemContext!.ContentId"
     role="region"
     data-state="@StateValue"
     aria-labelledby="@ItemContext!.TriggerId"
