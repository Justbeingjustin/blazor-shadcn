                                </div>

                                <p class="text-muted-foreground mt-4 text-sm">components/accordion/AccordionTrigger.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_accordionTriggerManualSource">@_accordionTriggerManualSource</CodeBlock>
                                </div>

                                <p class="text-muted-foreground mt-4 text-sm">components/accordion/AccordionContent.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_accordionContentManualSource">@_accordionContentManualSource</CodeBlock>
                                </div>

