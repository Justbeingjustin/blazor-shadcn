    private string ReadCanonicalSource(string fileName, string fallback)
    {
        var canonicalPath = Path.Combine(Environment.ContentRootPath, canonicalAccordionDirectory.Replace('/', Path.DirectorySeparatorChar), fileName);
        return File.Exists(canonicalPath)
            ? File.ReadAllText(canonicalPath)
            : fallback;
    }
