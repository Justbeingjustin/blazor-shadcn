        "Cras mattis consectetur purus sit amet fermentum. Lorem ipsum dolor sit amet, consectetur adipiscing elit."
    ];

    protected override void OnInitialized()
    {
        _sourceDialogContextCs = LoadSource("DialogContext.cs");
        _sourceDialogRazor = LoadSource("Dialog.razor");
        _sourceDialogTriggerRazor = LoadSource("DialogTrigger.razor");
        _sourceDialogContentRazor = LoadSource("DialogContent.razor");
        _sourceDialogCloseRazor = LoadSource("DialogClose.razor");
        _sourceDialogHeaderRazor = LoadSource("DialogHeader.razor");
        _sourceDialogFooterRazor = LoadSource("DialogFooter.razor");
        _sourceDialogTitleRazor = LoadSource("DialogTitle.razor");
        _sourceDialogDescriptionRazor = LoadSource("DialogDescription.razor");
    }

    private string LoadSource(string fileName)
    {
        var canonicalPath = Path.GetFullPath(Path.Combine(Environment.ContentRootPath, "..", canonicalDialogDirectory.Replace('/', Path.DirectorySeparatorChar), fileName));
        return File.Exists(canonicalPath)
            ? File.ReadAllText(canonicalPath)
            : $"Missing source: {canonicalDialogDirectory}/{fileName}";
    }

    private enum InstallationTab
    {
        Command,
        Manual
    }

