        <Spinner />
        Processing
    </Badge>
</div>
""";
    private const string inputGroupCode = """
<div class="flex w-full max-w-md flex-col gap-4">
    <div data-slot="input-group" role="group" class="group/input-group border-input dark:bg-input/30 relative flex h-9 min-w-0 w-full items-center rounded-md border shadow-xs transition-[color,box-shadow] outline-none">
        <Input Placeholder="Send a message..." Disabled="true" Class="flex-1 rounded-none border-0 bg-transparent shadow-none focus-visible:ring-0 dark:bg-transparent pr-2" />
        <div role="group" data-slot="input-group-addon" data-align="inline-end" class="text-muted-foreground order-last flex h-auto cursor-text items-center justify-center gap-2 py-1.5 pr-3 text-sm font-medium select-none [&>svg:not([class*='size-'])]:size-4">
            <Spinner />
        </div>
    </div>
    <div data-slot="input-group" role="group" class="group/input-group border-input dark:bg-input/30 relative flex h-auto min-w-0 w-full flex-col rounded-md border shadow-xs transition-[color,box-shadow] outline-none">
        <Textarea Placeholder="Send a message..." Disabled="true" Class="min-h-24 flex-1 resize-none rounded-none border-0 bg-transparent py-3 shadow-none focus-visible:ring-0 dark:bg-transparent" />
