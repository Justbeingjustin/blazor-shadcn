@page "/components/aspect-ratio"

<PageTitle>Aspect Ratio - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Aspect Ratio</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="@Button.ButtonVariant.Secondary" Size="@Button.ButtonSize.Icon" Href="/components/alert-dialog" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="@Button.ButtonVariant.Secondary" Size="@Button.ButtonSize.Icon" Href="/components/avatar" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    Displays content within a desired ratio.
                </p>
            </div>

            <div class="w-full flex-1">
                @* Reference ComponentPreview: aspect-ratio-demo *@
                <ComponentExample Compact="true" CodeText="@demoCode">
                    <Preview>
                        <div class="w-full max-w-md">
                            <AspectRatio Ratio="(16d / 9d)" Class="bg-muted rounded-lg">
                                <img src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=800&dpr=2&q=80" alt="Photo by Drew Beamer" class="h-full w-full rounded-lg object-cover dark:brightness-[0.2] dark:grayscale" />
                            </AspectRatio>
                        </div>
                    </Preview>
                    <Code>@demoCode</Code>
                </ComponentExample>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight first:mt-0 lg:mt-12" id="installation">Installation</h2>
                <p class="leading-relaxed mt-6">Install the aspect ratio component using the command or manual steps.</p>
                <div class="mt-4">
                    <div class="inline-flex w-fit items-center justify-start gap-4 rounded-none bg-transparent px-0">
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Command"
                                data-state="@(_installationTab == InstallationTab.Command ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Command
                        </button>
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Manual"
                                data-state="@(_installationTab == InstallationTab.Manual ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Manual
                        </button>
                    </div>
                </div>

                @if (_installationTab == InstallationTab.Command)
                {
                    <div class="mt-4">
                        <CodeBlock RawText="@installCommand">@installCommand</CodeBlock>
                    </div>
                }
                else
                {
                    <div class="mt-6 space-y-6">
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">1</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Install the following dependencies:</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@manualDependencyCommand">@manualDependencyCommand</CodeBlock>
                                </div>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">2</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Copy and paste the following code into your project.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/UI/AspectRatio.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@sourceAspectRatioRazor">@sourceAspectRatioRazor</CodeBlock>
                                </div>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">3</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Update the import paths to match your project setup.</p>
                            </div>
                        </div>
                    </div>
                }

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6"><CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock></div>
                <div class="mt-4"><CodeBlock RawText="@usageCode">@usageCode</CodeBlock></div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>
                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight" id="square">Square</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">A square aspect ratio component using the <code>ratio=1</code> prop. This is useful for displaying images in a square format.</p>
                <div class="mt-6">
                    @* Reference ComponentPreview: aspect-ratio-square *@
                    <ComponentExample Compact="true" CodeText="@squareCode">
                        <Preview>
                            <div class="w-full max-w-md">
                                <AspectRatio Ratio="1" Class="bg-muted rounded-lg">
                                    <img src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=800&dpr=2&q=80" alt="Photo by Drew Beamer" class="h-full w-full rounded-lg object-cover dark:brightness-[0.2] dark:grayscale" />
                                </AspectRatio>
                            </div>
                        </Preview>
                        <Code>@squareCode</Code>
                    </ComponentExample>
                </div>

                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight" id="portrait">Portrait</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">A portrait aspect ratio component using the <code>ratio=(9d / 16d)</code> prop. This is useful for displaying images in a portrait format.</p>
                <div class="mt-6">
                    @* Reference ComponentPreview: aspect-ratio-portrait *@
                    <ComponentExample Compact="true" CodeText="@portraitCode">
                        <Preview>
                            <div class="h-96 w-auto max-w-[13.5rem]">
                                <AspectRatio Ratio="(9d / 16d)" Class="bg-muted rounded-lg">
                                    <img src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=800&dpr=2&q=80" alt="Photo by Drew Beamer" class="h-full w-full rounded-lg object-cover dark:brightness-[0.2] dark:grayscale" />
                                </AspectRatio>
                            </div>
                        </Preview>
                        <Code>@portraitCode</Code>
                    </ComponentExample>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="api-reference">API Reference</h2>
                <h3 class="font-heading mt-8 scroll-m-28 text-lg font-medium tracking-tight">AspectRatio</h3>
                <p class="leading-relaxed mt-4">The <code>AspectRatio</code> component displays content within a desired ratio.</p>
                <div class="no-scrollbar my-6 w-full overflow-x-auto overflow-y-hidden rounded-xl border">
                    <table class="relative w-full min-w-max overflow-hidden border-none text-sm">
                        <thead><tr class="m-0 border-b"><th class="px-4 py-2 text-left font-bold">Prop</th><th class="px-4 py-2 text-left font-bold">Type</th><th class="px-4 py-2 text-left font-bold">Default</th><th class="px-4 py-2 text-left font-bold">Required</th></tr></thead>
                        <tbody class="[&_tr:last-child]:border-b-0">
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">ratio</code></td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">number</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td><td class="px-4 py-2 text-left whitespace-nowrap">Yes</td></tr>
                            <tr class="m-0 border-b"><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">className</code></td><td class="px-4 py-2 text-left whitespace-nowrap"><code class="bg-muted relative rounded-md px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] whitespace-nowrap">string</code></td><td class="px-4 py-2 text-left whitespace-nowrap">-</td><td class="px-4 py-2 text-left whitespace-nowrap">No</td></tr>
                        </tbody>
                    </table>
                </div>
                <p class="leading-relaxed">For more information, see the <a href="https://www.radix-ui.com/primitives/docs/components/aspect-ratio#api-reference" class="underline underline-offset-4">Radix UI documentation</a>.</p>
            </div>
        </div>
    </div>

    <div class="sticky top-14 z-30 ml-auto hidden h-[90svh] w-[280px] flex-col gap-4 overflow-hidden overscroll-none pb-8 xl:flex">
        <div class="no-scrollbar flex flex-col gap-8 overflow-y-auto px-8">
            <DocsPageLinks />
            <div class="flex flex-col gap-2 p-4 pt-0 text-sm">
                <p class="text-muted-foreground bg-background sticky top-0 h-6 text-xs font-medium">On This Page</p>
                <a href="#installation" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Installation</a>
                <a href="#usage" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Usage</a>
                <a href="#examples" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">Examples</a>
                <a href="#square" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Square</a>
                <a href="#portrait" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors pl-4" data-depth="3">Portrait</a>
                <a href="#api-reference" class="text-muted-foreground hover:text-foreground text-[0.8rem] no-underline transition-colors">API Reference</a>
            </div>
        </div>
    </div>
</div>

@code {
    private InstallationTab _installationTab = InstallationTab.Command;

    private enum InstallationTab
    {
        Command,
        Manual
    }

    private const string installCommand = "blazor-shadcn add aspect-ratio";
    private const string manualDependencyCommand = "npm install radix-ui";
    private const string referenceUrl = "https://ui.shadcn.com/docs/components/radix/aspect-ratio";
    private const string usingStatement = "@using BlazorShadcn.Components.UI";
    private const string usageCode = """
<AspectRatio Ratio="(16d / 9d)">
    <img src="..." alt="Image" class="rounded-md object-cover" />
</AspectRatio>
""";
    private const string demoCode = """
<div class="w-full max-w-md">
    <AspectRatio Ratio="(16d / 9d)" Class="bg-muted rounded-lg">
        <img src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=800&dpr=2&q=80"
             alt="Photo by Drew Beamer"
             class="h-full w-full rounded-lg object-cover dark:brightness-[0.2] dark:grayscale" />
    </AspectRatio>
</div>
""";
    private const string squareCode = """
<div class="w-full max-w-md">
    <AspectRatio Ratio="1" Class="bg-muted rounded-lg">
        <img src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=800&dpr=2&q=80"
             alt="Photo by Drew Beamer"
             class="h-full w-full rounded-lg object-cover dark:brightness-[0.2] dark:grayscale" />
    </AspectRatio>
</div>
""";
    private const string portraitCode = """
<div class="h-96 w-auto max-w-[13.5rem]">
    <AspectRatio Ratio="(9d / 16d)" Class="bg-muted rounded-lg">
        <img src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=800&dpr=2&q=80"
             alt="Photo by Drew Beamer"
             class="h-full w-full rounded-lg object-cover dark:brightness-[0.2] dark:grayscale" />
    </AspectRatio>
</div>
""";
    private const string sourceAspectRatioRazor = """
<div data-slot="aspect-ratio"
     class="@GetClasses()"
     style="@GetContainerStyle()"
     @attributes="GetAdditionalAttributes()">
    @ChildContent
</div>

@code {
    [Parameter] public double Ratio { get; set; } = 16d / 9d;
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses()
        => Tw.Merge("relative w-full", Class);

    private IReadOnlyDictionary<string, object>? GetAdditionalAttributes()
    {
        if (AdditionalAttributes is null || !AdditionalAttributes.ContainsKey("style"))
        {
            return AdditionalAttributes;
        }

        return AdditionalAttributes
            .Where(static pair => !string.Equals(pair.Key, "style", StringComparison.OrdinalIgnoreCase))
            .ToDictionary();
    }

    private string GetContainerStyle()
    {
        var ratio = Ratio <= 0 ? 16d / 9d : Ratio;
        var aspectRatio = ratio.ToString(System.Globalization.CultureInfo.InvariantCulture);

        if (AdditionalAttributes is not null &&
            AdditionalAttributes.TryGetValue("style", out var styleValue) &&
            styleValue is not null &&
            !string.IsNullOrWhiteSpace(styleValue.ToString()))
        {
            return $"aspect-ratio: {aspectRatio}; {styleValue}";
        }

        return $"aspect-ratio: {aspectRatio};";
    }
}
""";
}



