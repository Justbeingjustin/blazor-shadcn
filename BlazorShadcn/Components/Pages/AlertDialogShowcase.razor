@page "/components/alert-dialog"
@inject IWebHostEnvironment Environment

<PageTitle>Alert Dialog - blazor-shadcn</PageTitle>

<div data-slot="docs" class="flex scroll-mt-24 items-stretch pb-8 text-[15px] xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 md:px-0 lg:py-8">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between md:items-start">
                    <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Alert Dialog</h1>
                    <div class="ml-auto flex items-center gap-2">
                        <DocsCopyPage PageUrl="@referenceUrl" />
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/alert" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M5 12l6 6" /><path d="M5 12l6 -6" /></svg>
                            <span class="sr-only">Previous</span>
                        </Button>
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" Href="/components/aspect-ratio" Class="extend-touch-target size-8 shadow-none md:size-7" aria-label="Next">
                            <span class="sr-only">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                        </Button>
                    </div>
                </div>
                <div class="xl:hidden">
                    <DocsPageLinks Padded="false" />
                </div>
                <p class="text-muted-foreground text-base text-balance md:max-w-[80%]">
                    A modal dialog that interrupts the user with important content and expects a response.
                </p>
            </div>

            <div class="w-full flex-1">
                <ComponentExample Compact="true" CodeText="@demoCode">
                    <Preview>
                        <div class="grid w-full place-items-center">
                            <AlertDialog>
                                <AlertDialogTrigger>
                                    <Button Variant="ButtonVariant.Outline" @onclick="() => _showDemo = true">Show Dialog</Button>
                                </AlertDialogTrigger>
                                @if (_showDemo)
                                {
                                    <AlertDialogContent OnCancel="() => _showDemo = false">
                                        <AlertDialogHeader>
                                            <AlertDialogTitle>Are you absolutely sure?</AlertDialogTitle>
                                            <AlertDialogDescription>
                                                This action cannot be undone. This will permanently delete your account from our servers.
                                            </AlertDialogDescription>
                                        </AlertDialogHeader>
                                        <AlertDialogFooter>
                                            <AlertDialogCancel @onclick="() => _showDemo = false">Cancel</AlertDialogCancel>
                                            <AlertDialogAction @onclick="() => _showDemo = false">Continue</AlertDialogAction>
                                        </AlertDialogFooter>
                                    </AlertDialogContent>
                                }
                            </AlertDialog>
                        </div>
                    </Preview>
                    <Code>@demoCode</Code>
                </ComponentExample>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight first:mt-0 lg:mt-12" id="installation">Installation</h2>
                <p class="leading-relaxed mt-6">Install the alert-dialog component using the command or manual steps.</p>
                <div class="mt-4">
                    <div class="inline-flex w-fit items-center justify-start gap-4 rounded-none bg-transparent px-0">
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Command"
                                data-state="@(_installationTab == InstallationTab.Command ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Command
                        </button>
                        <button type="button"
                                @onclick="() => _installationTab = InstallationTab.Manual"
                                data-state="@(_installationTab == InstallationTab.Manual ? "active" : "inactive")"
                                class="focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:outline-ring relative inline-flex h-[calc(100%-1px)] items-center justify-center gap-1.5 rounded-none border-0 border-b-2 border-transparent bg-transparent px-0 pb-3 pt-1 text-base font-medium whitespace-nowrap transition-all focus-visible:ring-[3px] focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 text-muted-foreground hover:text-primary data-[state=active]:border-primary data-[state=active]:text-foreground data-[state=active]:bg-transparent data-[state=active]:shadow-none dark:data-[state=active]:bg-transparent">
                            Manual
                        </button>
                    </div>
                </div>

                @if (_installationTab == InstallationTab.Command)
                {
                    <div class="mt-4">
                        <CodeBlock RawText="@installCommand">@installCommand</CodeBlock>
                    </div>
                }
                else
                {
                    <div class="mt-6 space-y-6">
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">1</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Copy and paste the following files into your project.</p>
                                <p class="text-muted-foreground mt-2 text-sm">components/alert-dialog/AlertDialog.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogRazor">@_sourceAlertDialogRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">components/alert-dialog/AlertDialogTrigger.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogTriggerRazor">@_sourceAlertDialogTriggerRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">components/alert-dialog/AlertDialogContent.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogContentRazor">@_sourceAlertDialogContentRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">components/alert-dialog/AlertDialogHeader.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogHeaderRazor">@_sourceAlertDialogHeaderRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">components/alert-dialog/AlertDialogFooter.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogFooterRazor">@_sourceAlertDialogFooterRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">components/alert-dialog/AlertDialogTitle.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogTitleRazor">@_sourceAlertDialogTitleRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">components/alert-dialog/AlertDialogDescription.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogDescriptionRazor">@_sourceAlertDialogDescriptionRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">components/alert-dialog/AlertDialogMedia.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogMediaRazor">@_sourceAlertDialogMediaRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">components/alert-dialog/AlertDialogAction.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogActionRazor">@_sourceAlertDialogActionRazor</CodeBlock>
                                </div>
                                <p class="text-muted-foreground mt-4 text-sm">components/alert-dialog/AlertDialogCancel.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@_sourceAlertDialogCancelRazor">@_sourceAlertDialogCancelRazor</CodeBlock>
                                </div>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="bg-muted text-muted-foreground mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full text-xs font-semibold">2</div>
                            <div class="min-w-0 flex-1">
                                <p class="font-medium">Update the import paths to match your project setup.</p>
                                <p class="text-muted-foreground mt-2 text-sm">Components/_Imports.razor</p>
                                <div class="mt-2">
                                    <CodeBlock RawText="@manualImportsCode">@manualImportsCode</CodeBlock>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="usage">Usage</h2>
                <div class="mt-6">
                    <CodeBlock RawText="@usingStatement">@usingStatement</CodeBlock>
                </div>
                <div class="mt-4">
                    <CodeBlock RawText="@usageCode">@usageCode</CodeBlock>
                </div>

                <h2 class="font-heading mt-10 scroll-m-28 text-xl font-medium tracking-tight lg:mt-12" id="examples">Examples</h2>
                <div class="mt-6">
                    <ComponentExample Title="Basic" Compact="true" CodeText="@basicCode">
                        <Preview>
                            <div class="grid w-full place-items-center">
                                <AlertDialog>
                                    <AlertDialogTrigger><Button Variant="ButtonVariant.Outline" @onclick="() => _showBasic = true">Show Dialog</Button></AlertDialogTrigger>
                                    @if (_showBasic)
                                    {
                                        <AlertDialogContent OnCancel="() => _showBasic = false">
                                            <AlertDialogHeader>
                                                <AlertDialogTitle>Are you absolutely sure?</AlertDialogTitle>
                                                <AlertDialogDescription>This action cannot be undone. This will permanently delete your account and remove your data from our servers.</AlertDialogDescription>
                                            </AlertDialogHeader>
                                            <AlertDialogFooter>
                                                <AlertDialogCancel @onclick="() => _showBasic = false">Cancel</AlertDialogCancel>
                                                <AlertDialogAction @onclick="() => _showBasic = false">Continue</AlertDialogAction>
                                            </AlertDialogFooter>
                                        </AlertDialogContent>
                                    }
                                </AlertDialog>
                            </div>
                        </Preview>
                        <Code>@basicCode</Code>
                    </ComponentExample>
                </div>
                <div class="mt-6">
                    <ComponentExample Title="Small" Compact="true" CodeText="@smallCode">
                        <Preview>
                            <div class="grid w-full place-items-center">
                                <AlertDialog>
                                    <AlertDialogTrigger><Button Variant="ButtonVariant.Outline" @onclick="() => _showSmall = true">Show Dialog</Button></AlertDialogTrigger>
                                    @if (_showSmall)
                                    {
                                        <AlertDialogContent Size="AlertDialogContent.AlertDialogContentSize.Sm" OnCancel="() => _showSmall = false">
                                            <AlertDialogHeader>
                                                <AlertDialogTitle>Allow accessory to connect?</AlertDialogTitle>
                                                <AlertDialogDescription>Do you want to allow the USB accessory to connect to this device?</AlertDialogDescription>
                                            </AlertDialogHeader>
                                            <AlertDialogFooter>
                                                <AlertDialogCancel @onclick="() => _showSmall = false">Don't allow</AlertDialogCancel>
                                                <AlertDialogAction @onclick="() => _showSmall = false">Allow</AlertDialogAction>
                                            </AlertDialogFooter>
                                        </AlertDialogContent>
                                    }
                                </AlertDialog>
                            </div>
                        </Preview>
                        <Code>@smallCode</Code>
                    </ComponentExample>
                </div>
                <div class="mt-6">
                    <ComponentExample Title="Media" Compact="true" CodeText="@mediaCode">
                        <Preview>
                            <div class="grid w-full place-items-center">
                                <AlertDialog>
                                    <AlertDialogTrigger><Button Variant="ButtonVariant.Outline" @onclick="() => _showMedia = true">Share Project</Button></AlertDialogTrigger>
                                    @if (_showMedia)
                                    {
                                        <AlertDialogContent OnCancel="() => _showMedia = false">
                                            <AlertDialogHeader>
                                                <AlertDialogMedia>
                                                    <img src="https://files.svgcdn.io/lucide/circle-fading-plus.svg" alt="" class="size-6" />
                                                </AlertDialogMedia>
                                                <AlertDialogTitle>Share this project?</AlertDialogTitle>
                                                <AlertDialogDescription>Anyone with the link will be able to view and edit this project.</AlertDialogDescription>
                                            </AlertDialogHeader>
                                            <AlertDialogFooter>
                                                <AlertDialogCancel @onclick="() => _showMedia = false">Cancel</AlertDialogCancel>
                                                <AlertDialogAction @onclick="() => _showMedia = false">Share</AlertDialogAction>
                                            </AlertDialogFooter>
                                        </AlertDialogContent>
                                    }
                                </AlertDialog>
                            </div>
                        </Preview>
                        <Code>@mediaCode</Code>
                    </ComponentExample>
                </div>
                <div class="mt-6">
                    <ComponentExample Title="Small with Media" Compact="true" CodeText="@smallWithMediaCode">
                        <Preview>
                            <div class="grid w-full place-items-center">
                                <AlertDialog>
                                    <AlertDialogTrigger><Button Variant="ButtonVariant.Outline" @onclick="() => _showSmallWithMedia = true">Show Dialog</Button></AlertDialogTrigger>
                                    @if (_showSmallWithMedia)
                                    {
                                        <AlertDialogContent Size="AlertDialogContent.AlertDialogContentSize.Sm" OnCancel="() => _showSmallWithMedia = false">
                                            <AlertDialogHeader>
                                                <AlertDialogMedia>
                                                    <img src="https://files.svgcdn.io/lucide/bluetooth.svg" alt="" class="size-6" />
                                                </AlertDialogMedia>
                                                <AlertDialogTitle>Allow accessory to connect?</AlertDialogTitle>
                                                <AlertDialogDescription>Do you want to allow the USB accessory to connect to this device?</AlertDialogDescription>
                                            </AlertDialogHeader>
                                            <AlertDialogFooter>
                                                <AlertDialogCancel @onclick="() => _showSmallWithMedia = false">Don't allow</AlertDialogCancel>
                                                <AlertDialogAction @onclick="() => _showSmallWithMedia = false">Allow</AlertDialogAction>
                                            </AlertDialogFooter>
                                        </AlertDialogContent>
                                    }
                                </AlertDialog>
                            </div>
                        </Preview>
                        <Code>@smallWithMediaCode</Code>
                    </ComponentExample>
                </div>
                <div class="mt-6">
                    <ComponentExample Title="Destructive" Compact="true" CodeText="@destructiveCode">
                        <Preview>
                            <div class="grid w-full place-items-center">
                                <AlertDialog>
                                    <AlertDialogTrigger><Button Variant="ButtonVariant.Destructive" @onclick="() => _showDestructive = true">Delete Chat</Button></AlertDialogTrigger>
                                    @if (_showDestructive)
                                    {
                                        <AlertDialogContent Size="AlertDialogContent.AlertDialogContentSize.Sm" OnCancel="() => _showDestructive = false">
                                            <AlertDialogHeader>
                                                <AlertDialogMedia Class="bg-destructive/10 text-destructive dark:bg-destructive/20 dark:text-destructive">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M3 6h18" />
                                                        <path d="M8 6V4h8v2" />
                                                        <path d="M19 6l-1 14H6L5 6" />
                                                        <path d="M10 11v6" />
                                                        <path d="M14 11v6" />
                                                    </svg>
                                                </AlertDialogMedia>
                                                <AlertDialogTitle>Delete chat?</AlertDialogTitle>
                                                <AlertDialogDescription>This will permanently delete this chat conversation. View <a href="#">Settings</a> delete any memories saved during this chat.</AlertDialogDescription>
                                            </AlertDialogHeader>
                                            <AlertDialogFooter>
                                                <AlertDialogCancel Variant="ButtonVariant.Outline" @onclick="() => _showDestructive = false">Cancel</AlertDialogCancel>
                                                <AlertDialogAction Variant="ButtonVariant.Destructive" @onclick="() => _showDestructive = false">Delete</AlertDialogAction>
                                            </AlertDialogFooter>
                                        </AlertDialogContent>
                                    }
                                </AlertDialog>
                            </div>
                        </Preview>
                        <Code>@destructiveCode</Code>
                    </ComponentExample>
                </div>

