@namespace ShadcnBlazor.Components.UI

<kbd data-slot="kbd"
     class="@GetClasses()"
     @attributes="AdditionalAttributes">@ChildContent</kbd>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const string BaseClasses =
        "bg-muted text-muted-foreground pointer-events-none inline-flex h-5 w-fit min-w-5 " +
        "select-none items-center justify-center gap-1 rounded-sm px-1 font-sans text-xs font-medium " +
        "[&_svg:not([class*='size-'])]:size-3 [[data-slot=tooltip-content]_&]:bg-background/20 " +
        "[[data-slot=tooltip-content]_&]:text-background dark:[[data-slot=tooltip-content]_&]:bg-background/10";

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static c => !string.IsNullOrWhiteSpace(c)));

    private string GetClasses() => Cn(BaseClasses, Class);
}
