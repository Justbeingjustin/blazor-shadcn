@namespace ShadcnBlazor.Components.UI

<div data-slot="select"
     data-state="@(_context.IsOpen ? "open" : "closed")"
     class="@Cn("relative inline-flex w-fit flex-col data-[state=open]:z-50", Class)"
     @attributes="AdditionalAttributes">
    <CascadingValue Value="_context">
        @ChildContent
    </CascadingValue>
</div>

@code {
    private readonly SelectContext _context = new();
    private bool _defaultsInitialized;

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnParametersSet()
    {
        _context.Configure(
            Disabled,
            Value,
            ValueChanged,
            () => InvokeAsync(StateHasChanged));

        if (!_defaultsInitialized)
        {
            _context.InitializeDefault(DefaultValue);
            _defaultsInitialized = true;
        }
    }

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}

