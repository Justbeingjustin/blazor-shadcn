@namespace ShadcnBlazor.Components.UI
@inject IJSRuntime JS

@if (Context.IsOpen)
{
    <div data-slot="select-content"
         @ref="_contentRef"
         id="@Context.ContentId"
         role="listbox"
         tabindex="-1"
         class="@ContentClass"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}

@code {
    [CascadingParameter] internal SelectContext Context { get; set; } = default!;

    [Parameter] public string Position { get; set; } = "item-aligned";
    [Parameter] public string Align { get; set; } = "center";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private ElementReference _contentRef;
    private bool _positioned;

    private string ContentClass => Cn(
        "bg-popover text-popover-foreground fixed top-0 left-0 z-[60] max-h-96 min-w-[8rem] overflow-x-hidden overflow-y-auto rounded-md border p-1 shadow-md",
        Class);

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!Context.IsOpen)
        {
            _positioned = false;
            return;
        }

        await JS.InvokeVoidAsync("window.blazorShadcnSelect.position", Context.TriggerElement, _contentRef, Position);

        if (!_positioned)
        {
            _positioned = true;
            StateHasChanged();
        }
    }
}
