@namespace ShadcnBlazor.Components.UI

<span data-slot="select-value"
      data-placeholder="@IsPlaceholder"
      class="@Cn("line-clamp-1 flex min-w-0 flex-1 items-center gap-2 text-left", IsPlaceholder ? "text-muted-foreground" : null, Class)"
      @attributes="AdditionalAttributes">
    @if (ChildContent is not null && !IsPlaceholder)
    {
        @ChildContent
    }
    else if (IsPlaceholder)
    {
        @Placeholder
    }
    else
    {
        @Context.SelectedText
    }
</span>

@code {
    [CascadingParameter] internal SelectContext Context { get; set; } = default!;

    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsPlaceholder => string.IsNullOrWhiteSpace(Context.CurrentValue);

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
