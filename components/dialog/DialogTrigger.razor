@namespace ShadcnBlazor.Components.UI

@if (Context is not null)
{
    <span data-slot="dialog-trigger"
          class="@Cn("inline-flex", Class)"
          tabindex="0"
          role="button"
          @onclick="OpenAsync"
          @onkeydown="HandleKeyDown"
          @attributes="AdditionalAttributes">
        @ChildContent
    </span>
}

@code {
    [CascadingParameter(Name = "DialogContext")] private DialogContext? Context { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private Task OpenAsync() => Context?.SetOpenAsync(true) ?? Task.CompletedTask;

    private Task HandleKeyDown(KeyboardEventArgs args)
        => args.Key is "Enter" or " " ? OpenAsync() : Task.CompletedTask;

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
