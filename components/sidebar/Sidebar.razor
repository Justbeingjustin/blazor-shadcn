@namespace ShadcnBlazor.Components.UI

@if (Collapsible == "none")
{
    <div data-slot="sidebar"
         data-side="@Side"
         data-variant="@Variant"
         data-collapsible="@Collapsible"
         class="@Cn("flex h-full w-[var(--sidebar-width)] flex-col bg-sidebar text-sidebar-foreground", GetStaticClasses(), Class)"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}
else
{
    <div class="md:hidden">
        <Sheet Open="@(Context?.OpenMobile ?? false)" OpenChanged="HandleMobileOpenChanged">
            <SheetContent Side="@Side"
                          ShowCloseButton="false"
                          Class="@Cn("w-[var(--sidebar-width-mobile)] max-w-[var(--sidebar-width-mobile)] bg-sidebar p-0 text-sidebar-foreground [&>button]:hidden", GetStaticClasses())">
                <div data-slot="sidebar"
                     data-sidebar="sidebar"
                     data-mobile="true"
                     data-side="@Side"
                     data-variant="@Variant"
                     data-collapsible="@Collapsible"
                     class="flex h-full w-full flex-col">
                    @ChildContent
                </div>
            </SheetContent>
        </Sheet>
    </div>

    <div class="group peer relative hidden h-full text-sidebar-foreground md:block"
         data-slot="sidebar"
         data-sidebar="sidebar"
         data-state="@Context?.State"
         data-collapsible="@GetCollapsibleState()"
         data-variant="@Variant"
         data-side="@Side">
        <div data-slot="sidebar-gap"
             class="@Cn("relative h-full w-[var(--sidebar-width)] bg-transparent transition-[width] duration-200 ease-linear",
                        GetGapClasses())"></div>

        <div data-slot="sidebar-container"
             data-side="@Side"
             class="@Cn("absolute inset-y-0 z-10 hidden h-full w-[var(--sidebar-width)] transition-[left,right,width] duration-200 ease-linear md:flex",
                        GetContainerClasses(),
                        Class)"
             @attributes="AdditionalAttributes">
            <div data-slot="sidebar-inner"
                 data-sidebar="sidebar"
                 class="@Cn("flex size-full flex-col bg-sidebar",
                            GetStaticClasses())">
                @ChildContent
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter(Name = "SidebarContext")] private SidebarContext? Context { get; set; }

    [Parameter] public string Side { get; set; } = "left";
    [Parameter] public string Variant { get; set; } = "sidebar";
    [Parameter] public string Collapsible { get; set; } = "offcanvas";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private Task HandleMobileOpenChanged(bool value)
        => Context?.SetOpenMobileAsync(value) ?? Task.CompletedTask;

    private string GetCollapsibleState()
        => Context?.Open == false ? Collapsible : string.Empty;

    private string GetGapClasses()
        => (Variant, GetCollapsibleState(), Side) switch
        {
            (_, "offcanvas", "right") => "w-0 rotate-180",
            (_, "offcanvas", _) => "w-0",
            ("floating" or "inset", "icon", _) => "w-[calc(var(--sidebar-width-icon)+1rem)]",
            (_, "icon", _) => "w-[var(--sidebar-width-icon)]",
            _ => string.Empty
        };

    private string GetContainerClasses()
    {
        var sideClass = Side == "right" ? "right-0" : "left-0";
        var offcanvasClass = GetCollapsibleState() == "offcanvas"
            ? Side == "right"
                ? "right-[calc(var(--sidebar-width)*-1)]"
                : "left-[calc(var(--sidebar-width)*-1)]"
            : sideClass;

        var widthClass = (Variant, GetCollapsibleState()) switch
        {
            ("floating" or "inset", "icon") => "w-[calc(var(--sidebar-width-icon)+1rem)] p-2",
            ("floating" or "inset", _) => "p-2",
            (_, "icon") => "w-[var(--sidebar-width-icon)] border-r",
            _ => Side == "right" ? "border-l" : "border-r"
        };

        return $"{offcanvasClass} {widthClass}";
    }

    private string GetStaticClasses()
        => Variant switch
        {
            "floating" => "rounded-lg shadow-sm ring-1 ring-sidebar-border",
            _ => string.Empty
        };

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
