@namespace ShadcnBlazor.Components.UI
@using System.Globalization

<div data-slot="slider"
     data-orientation="@Orientation"
     data-disabled="@Disabled"
     class="@Cn("relative flex w-full touch-none items-center select-none", Orientation == "vertical" ? "h-full min-h-40 w-auto flex-col" : null, Disabled ? "opacity-50" : null, Class)"
     @attributes="AdditionalAttributes">
    <div data-slot="slider-track"
         class="@Cn("bg-muted relative grow overflow-hidden rounded-full", Orientation == "vertical" ? "h-full w-1.5" : "h-1.5 w-full")">
        <div data-slot="slider-range"
             class="@Cn("bg-primary absolute", Orientation == "vertical" ? "w-full" : "h-full")"
             style="@GetRangeStyle()"></div>
    </div>

    @for (var i = 0; i < _values.Count; i++)
    {
        var thumbIndex = i;
        <div data-slot="slider-thumb"
             aria-hidden="true"
             class="@GetThumbClass()"
             style="@GetThumbStyle(thumbIndex)"></div>
    }

    @for (var i = 0; i < _values.Count; i++)
    {
        var inputIndex = i;
        <input type="range"
               min="@Min.ToString(CultureInfo.InvariantCulture)"
               max="@Max.ToString(CultureInfo.InvariantCulture)"
               step="@Step.ToString(CultureInfo.InvariantCulture)"
               value="@_values[inputIndex].ToString(CultureInfo.InvariantCulture)"
               class="@GetInputClass()"
               style="@GetInputStyle(inputIndex)"
               disabled="@Disabled"
               @oninput="args => OnInputAsync(inputIndex, args)" />
    }
</div>

@code {
    private List<double> _values = [];
    private bool _defaultsInitialized;

    [Parameter] public double[]? Value { get; set; }
    [Parameter] public EventCallback<double[]> ValueChanged { get; set; }
    [Parameter] public double[]? DefaultValue { get; set; }
    [Parameter] public double Min { get; set; }
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public double Step { get; set; } = 1;
    [Parameter] public string Orientation { get; set; } = "horizontal";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnParametersSet()
    {
        if (Value is { Length: > 0 })
        {
            _values = [.. Value.Select(ClampValue)];
            return;
        }

        if (!_defaultsInitialized)
        {
            var initial = DefaultValue is { Length: > 0 }
                ? DefaultValue
                : [Min];

            _values = [.. initial.Select(ClampValue)];
            _defaultsInitialized = true;
        }
    }

    private async Task OnInputAsync(int index, ChangeEventArgs args)
    {
        if ((uint)index >= (uint)_values.Count)
        {
            return;
        }

        if (!double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var parsed))
        {
            return;
        }

        var next = _values.ToArray();
        next[index] = ClampValue(parsed);

        _values = [.. next];

        if (ValueChanged.HasDelegate)
        {
            await ValueChanged.InvokeAsync(next);
        }
    }

    private string GetRangeStyle()
    {
        if (_values.Count == 0 || Max <= Min)
        {
            return string.Empty;
        }

        var start = _values.Count == 1 ? Min : _values.Min();
        var end = _values.Max();
        var startPercent = ToPercent(start);
        var endPercent = ToPercent(end);

        return Orientation == "vertical"
            ? $"bottom:{startPercent.ToString("0.###", CultureInfo.InvariantCulture)}%;height:{(endPercent - startPercent).ToString("0.###", CultureInfo.InvariantCulture)}%;"
            : $"left:{startPercent.ToString("0.###", CultureInfo.InvariantCulture)}%;width:{(endPercent - startPercent).ToString("0.###", CultureInfo.InvariantCulture)}%;";
    }

    private string GetInputClass()
        => Orientation == "vertical"
            ? "pointer-events-none absolute inset-0 h-full w-6 -translate-x-1/2 left-1/2 appearance-none bg-transparent outline-none [&::-webkit-slider-runnable-track]:w-full [&::-webkit-slider-runnable-track]:bg-transparent [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:size-6 [&::-webkit-slider-thumb]:opacity-0 [&::-moz-range-track]:bg-transparent [&::-moz-range-thumb]:pointer-events-auto [&::-moz-range-thumb]:size-6 [&::-moz-range-thumb]:border-0 [&::-moz-range-thumb]:opacity-0"
            : "pointer-events-none absolute inset-0 h-6 w-full -translate-y-1/2 top-1/2 appearance-none bg-transparent outline-none [&::-webkit-slider-runnable-track]:h-full [&::-webkit-slider-runnable-track]:bg-transparent [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:-mt-1 [&::-webkit-slider-thumb]:size-6 [&::-webkit-slider-thumb]:opacity-0 [&::-moz-range-track]:h-full [&::-moz-range-track]:bg-transparent [&::-moz-range-thumb]:pointer-events-auto [&::-moz-range-thumb]:size-6 [&::-moz-range-thumb]:border-0 [&::-moz-range-thumb]:opacity-0";

    private string GetInputStyle(int index)
        => Orientation == "vertical"
            ? $"z-index:{_values.Count + index + 1};writing-mode:vertical-lr;direction:rtl;"
            : $"z-index:{index + 1};";

    private string GetThumbClass()
        => "border-primary pointer-events-none absolute block size-3 shrink-0 rounded-full border bg-white shadow-sm";

    private string GetThumbStyle(int index)
    {
        var percent = ToPercent(_values[index]).ToString("0.###", CultureInfo.InvariantCulture);

        return Orientation == "vertical"
            ? $"left:50%;bottom:{percent}%;transform:translate(-50%, 50%);z-index:{index + 1};"
            : $"left:{percent}%;top:50%;transform:translate(-50%, -50%);z-index:{index + 1};";
    }

    private double ClampValue(double value)
        => Math.Min(Max, Math.Max(Min, value));

    private double ToPercent(double value)
        => ((ClampValue(value) - Min) / (Max - Min)) * 100d;

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}

