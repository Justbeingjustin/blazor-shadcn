@namespace ShadcnBlazor.Components.UI

<legend data-slot="field-legend"
        data-variant="@ResolvedVariant"
        class="@Cn("mb-3 font-medium data-[variant=legend]:text-base data-[variant=label]:text-sm", Class)"
        @attributes="AdditionalAttributes">
    @ChildContent
</legend>

@code {
    [Parameter] public string Variant { get; set; } = "legend";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedVariant => Variant == "label" ? "label" : "legend";

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
