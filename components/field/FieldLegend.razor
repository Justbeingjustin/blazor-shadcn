@namespace ShadcnBlazor.Components.UI

<legend data-slot="field-legend"
        data-variant="@ResolvedVariant"
        class="@GetClasses()"
        @attributes="AdditionalAttributes">
    @ChildContent
</legend>

@code {
    [Parameter] public string Variant { get; set; } = "legend";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const string BaseClasses = "mb-3 font-medium data-[variant=legend]:text-base data-[variant=label]:text-sm";

    private string ResolvedVariant => Variant == "label" ? "label" : "legend";

    private string GetClasses()
        => string.IsNullOrWhiteSpace(Class) ? BaseClasses : $"{BaseClasses} {Class}";
}
