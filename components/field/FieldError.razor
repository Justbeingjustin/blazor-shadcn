@namespace ShadcnBlazor.Components.UI

@if (ChildContent is not null)
{
    <div role="alert"
         data-slot="field-error"
         class="@Cn(BaseClasses, Class)"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}
else if (_messages.Count == 1)
{
    <div role="alert"
         data-slot="field-error"
         class="@Cn(BaseClasses, Class)"
         @attributes="AdditionalAttributes">
        @_messages[0]
    </div>
}
else if (_messages.Count > 1)
{
    <div role="alert"
         data-slot="field-error"
         class="@Cn(BaseClasses, Class)"
         @attributes="AdditionalAttributes">
        <ul class="ml-4 flex list-disc flex-col gap-1">
            @foreach (var message in _messages)
            {
                <li>@message</li>
            }
        </ul>
    </div>
}

@code {
    private readonly List<string> _messages = [];

    [Parameter] public IEnumerable<string?>? Errors { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const string BaseClasses = "text-destructive text-sm font-normal";

    protected override void OnParametersSet()
    {
        _messages.Clear();

        if (Errors is null)
        {
            return;
        }

        var seen = new HashSet<string>(StringComparer.Ordinal);

        foreach (var error in Errors)
        {
            if (string.IsNullOrWhiteSpace(error) || !seen.Add(error))
            {
                continue;
            }

            _messages.Add(error);
        }
    }

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
