@namespace ShadcnBlazor.Components.UI

<div data-slot="tabs"
     data-orientation="@Orientation"
     class="@Cn("group/tabs flex gap-2", Orientation == "vertical" ? "flex-row" : "flex-col", Class)"
     @attributes="AdditionalAttributes">
    <CascadingValue Value="_context">
        @ChildContent
    </CascadingValue>
</div>

@code {
    private readonly TabsContext _context = new();
    private bool _defaultsInitialized;

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? DefaultValue { get; set; }
    [Parameter] public string Orientation { get; set; } = "horizontal";
    [Parameter] public string Variant { get; set; } = "default";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnParametersSet()
    {
        _context.Configure(
            Orientation,
            Variant,
            Value,
            ValueChanged,
            () => InvokeAsync(StateHasChanged));

        if (!_defaultsInitialized)
        {
            _context.InitializeDefault(DefaultValue);
            _defaultsInitialized = true;
        }
    }

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
