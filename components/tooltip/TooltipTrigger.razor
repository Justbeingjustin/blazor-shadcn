@namespace ShadcnBlazor.Components.UI

@namespace ShadcnBlazor.Components.UI

<span data-slot="tooltip-trigger"
      class="@Merge("inline-flex", Class)"
      tabindex="0"
      role="button"
      @onmouseenter="HandleMouseEnterAsync"
      @onmouseleave="@(() => SetOpenAsync(false))"
      @onfocus="HandleFocusAsync"
      @onblur="@(() => SetOpenAsync(false))"
      @attributes="AdditionalAttributes">
    @ChildContent
</span>

@code {
    [CascadingParameter(Name = "TooltipContext")] private Tooltip.TooltipContext? Context { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task HandleMouseEnterAsync()
    {
        if (Context is null)
        {
            return;
        }

        if (Context.DelayDuration > 0)
        {
            await Task.Delay(Context.DelayDuration);
        }

        await Context.SetOpenAsync(true);
    }

    private Task HandleFocusAsync(FocusEventArgs _)
        => SetOpenAsync(true);

    private Task SetOpenAsync(bool value)
        => Context?.SetOpenAsync(value) ?? Task.CompletedTask;

    private static string Merge(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
