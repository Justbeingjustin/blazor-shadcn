@namespace ShadcnBlazor.Components.UI

@if (Context?.Open == true)
{
    <button type="button"
            data-slot="popover-dismiss"
            class="fixed inset-0 z-[55] cursor-default bg-transparent"
            aria-label="Close popover"
            @onclick="CloseAsync"></button>

    <div data-slot="popover-content"
         id="@Context!.ContentId"
         data-align="@Align"
         data-side="@Side"
         dir="@Dir"
         tabindex="-1"
         class="@Cn("bg-popover text-popover-foreground absolute z-[60] flex flex-col gap-2.5 rounded-lg p-2.5 text-sm shadow-md ring-1 ring-foreground/10 outline-hidden", GetDefaultWidthClass(), GetPositionClasses(), Class)"
         @onkeydown="HandleKeyDown"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}

@code {
    [CascadingParameter(Name = "PopoverContext")] private PopoverContext? Context { get; set; }

    [Parameter] public string Align { get; set; } = "center";
    [Parameter] public string Side { get; set; } = "bottom";
    [Parameter] public string? Dir { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private Task CloseAsync() => Context?.SetOpenAsync(false) ?? Task.CompletedTask;

    private Task HandleKeyDown(KeyboardEventArgs args)
        => args.Key is "Escape" ? CloseAsync() : Task.CompletedTask;

    private string? GetDefaultWidthClass() => HasWidthClass(Class) ? null : "w-72";

    private string GetPositionClasses()
    {
        var align = Align.ToLowerInvariant();

        return ResolveSide() switch
        {
            "top" => align switch
            {
                "start" => "bottom-full left-0 mb-1",
                "end" => "bottom-full right-0 mb-1",
                _ => "bottom-full left-1/2 mb-1 -translate-x-1/2"
            },
            "right" => align switch
            {
                "start" => "left-full top-0 ml-1",
                "end" => "left-full bottom-0 ml-1",
                _ => "left-full top-1/2 ml-1 -translate-y-1/2"
            },
            "left" => align switch
            {
                "start" => "right-full top-0 mr-1",
                "end" => "right-full bottom-0 mr-1",
                _ => "right-full top-1/2 mr-1 -translate-y-1/2"
            },
            _ => align switch
            {
                "start" => "top-full left-0 mt-1",
                "end" => "top-full right-0 mt-1",
                _ => "top-full left-1/2 mt-1 -translate-x-1/2"
            }
        };
    }

    private string ResolveSide()
    {
        var side = Side.ToLowerInvariant();
        var isRtl = string.Equals(Dir, "rtl", StringComparison.OrdinalIgnoreCase);

        return side switch
        {
            "inline-start" => isRtl ? "right" : "left",
            "inline-end" => isRtl ? "left" : "right",
            "top" => "top",
            "right" => "right",
            "left" => "left",
            _ => "bottom"
        };
    }

    private static bool HasWidthClass(string? classes)
    {
        if (string.IsNullOrWhiteSpace(classes))
        {
            return false;
        }

        foreach (var token in classes.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries))
        {
            var (_, utility) = SplitVariants(token);
            var normalized = utility.Length > 0 && utility[0] == '!' ? utility[1..] : utility;

            if (normalized.StartsWith("w-", StringComparison.Ordinal))
            {
                return true;
            }
        }

        return false;
    }

    private static (string variants, string utility) SplitVariants(string token)
    {
        var bracketDepth = 0;
        var lastColon = -1;

        for (var i = 0; i < token.Length; i++)
        {
            switch (token[i])
            {
                case '[':
                    bracketDepth++;
                    break;
                case ']':
                    if (bracketDepth > 0)
                    {
                        bracketDepth--;
                    }
                    break;
                case ':':
                    if (bracketDepth == 0)
                    {
                        lastColon = i;
                    }
                    break;
            }
        }

        return lastColon < 0
            ? ("", token)
            : (token[..(lastColon + 1)], token[(lastColon + 1)..]);
    }

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
