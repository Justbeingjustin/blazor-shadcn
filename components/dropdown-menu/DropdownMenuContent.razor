@namespace ShadcnBlazor.Components.UI
@if (Context?.Open == true)
{
    <button type="button"
            data-slot="dropdown-menu-dismiss"
            class="fixed inset-0 z-40 cursor-default bg-transparent"
            aria-label="Close menu"
            @onclick="CloseAsync"></button>

    <CascadingValue Name="DropdownMenuSubGroupContext" Value="_subGroupContext" IsFixed="true">
        <div data-slot="dropdown-menu-content"
             class="@Cn("bg-popover text-popover-foreground absolute top-full left-0 z-50 mt-2 min-w-32 overflow-visible rounded-lg border p-1 shadow-md outline-none", Class)"
             @attributes="AdditionalAttributes">
            @ChildContent
        </div>
    </CascadingValue>
}

@code {
    [CascadingParameter(Name = "DropdownMenuContext")] private DropdownMenuContext? Context { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly DropdownMenuSubGroupContext _subGroupContext = new();

    private Task CloseAsync() => Context?.SetOpenAsync(false) ?? Task.CompletedTask;

    private static string Cn(params string?[] classes)
        => string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
