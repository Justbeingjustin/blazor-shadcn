@namespace ShadcnBlazor.Components.UI

<img data-slot="avatar-image"
     src="@Src"
     alt="@Alt"
     class="@GetClasses()"
     @attributes="AdditionalAttributes" />

@code {
    [CascadingParameter] private AvatarContext? AvatarContext { get; set; }

    [Parameter] public string? Src { get; set; }
    [Parameter] public string? Alt { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override Task OnParametersSetAsync()
    {
        return AvatarContext?.SetHasImageSourceAsync(!string.IsNullOrWhiteSpace(Src)) ?? Task.CompletedTask;
    }

    private string GetClasses()
    {
        var baseClasses = "aspect-square size-full";
        var customClass = string.IsNullOrWhiteSpace(Class) ? "" : $" {Class}";
        return $"{baseClasses}{customClass}";
    }
}
